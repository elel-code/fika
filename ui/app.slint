    private property <length> active-context-menu-height: root.context_menu_height(root.context-menu-kind, root.selected_count, root.context-metrics-is-dir, root.context-default-open-visible, root.context-add-place-visible, root.clipboard_has_paths, root.context-metrics-extra-bool, root.context-metrics-device-pending, root.menu-item-height / 1px, root.menu-separator-height / 1px, root.menu-title-height / 1px) * 1px;
