// Globals must be exported from app.slint (the root file) so that
// `include_modules!()` generates Rust types for `ui.global::<...>()`.
export { MenuGeometry } from "menu_geometry.slint";
export { MenuLifecycle } from "menu_lifecycle.slint";

export global DndApi {
    pure callback make-drag-place(path: string) -> data-transfer;
    pure callback make-drag-folder(path: string) -> data-transfer;
    pure callback make-drag-file(path: string) -> data-transfer;
    pure callback event-kind(event: DropEvent) -> DragKind;
    pure callback event-path(event: DropEvent) -> string;
}

import { DragKind } from "dnd_bridge.slint";
import { MenuLifecycle, MenuLifecycleController } from "menu_lifecycle.slint";
import { ScrollView } from "std-widgets.slint";
import {
    MenuDismissLayer,
    PlaceButton,
    SidebarAction,
    SidebarSection,
} from "widgets.slint";
import { ChooserChoice, ChooserChoiceOption, DesktopApp, DeviceEntry, FileEntry, PlaceEntry } from "models.slint";
import { DragOverlayLayer } from "dnd_overlay.slint";
import { SearchPanel } from "search_panel.slint";
import { SplitPaneView } from "split_pane.slint";
import { StatusBar } from "status_bar.slint";
import { PathBar, TopBar } from "top_bar.slint";
import { ChildSubmenuLayer, ChooserChoicePopupLayer, ChooserOptionPopupLayer, RootContextMenuLayer, TransferMenuLayer } from "menus.slint";
import { ConfirmationPopup, OtherApplicationsPopup, PrivilegedPromptPopup, PropertiesPopup, TextInputPopup, TransferConflictPopup } from "dialogs.slint";

component FilePane inherits Rectangle {
    in property <int> pane-side: 0;
    in property <bool> dark;
    in property <color> shell-base-color;
    in property <length> path-bar-height;
    in property <length> status-bar-height;
    in property <string> current-path;
    in property <bool> can-go-back;
    in property <bool> can-go-forward;
    in-out property <string> path-text;
    in-out property <bool> path-focused;
    in property <bool> search-panel-visible: false;
    in property <length> search-panel-height: 0px;
    in property <bool> search-loading: false;
    in property <bool> search-filters-active: false;
    in property <string> search-kind-label;
    in property <string> search-modified-label;
    in property <string> search-size-label;
    in-out property <string> search-query;
    in-out property <bool> recursive-search;
    in-out property <int> search-kind-filter;
    in-out property <int> search-modified-filter;
    in-out property <int> search-size-filter;
    in property <bool> content-interactive: true;
    in property <bool> drop-ready: true;
    in property <string> drop-trace-prefix;
    in property <int> entry-count;
    in property <[FileEntry]> entries;
    in property <int> virtual-start-index;
    in property <int> virtual-start-column;
    in-out property <float> viewport-x;
    in-out property <length> viewport-offset;
    in property <int> zoom-level;
    in property <int> selection-revision;
    in property <bool> show-location: false;
    in-out property <bool> drag-active;
    in-out property <bool> drag-rejected;
    in-out property <string> drag-target-path;
    in property <bool> empty-message-visible: true;
    in property <string> empty-title: "This folder is empty";
    in property <string> empty-subtitle: "";
    in property <string> status;
    in property <int> selected-count;
    in property <string> selected-status;
    in property <bool> external-edit-active;
    in property <string> external-edit-status;
    in property <bool> undo-available;
    in property <string> undo-label;
    in property <bool> chooser-mode;
    in property <bool> chooser-select-directories;
    in property <bool> chooser-save-mode;
    in property <string> chooser-accept-label;
    in property <string> selected-path;
    in property <int> chooser-filter-count;
    in property <string> chooser-filter-label;
    in property <[ChooserChoice]> chooser-choices;
    in-out property <string> chooser-save-name;

    callback focus_requested(int);
    callback path_submitted(int, string);
    callback go_back(int);
    callback go_forward(int);
    callback search_submitted(string);
    callback cancel_search();
    callback search_filters_changed(int, int, int);
    callback search_close_requested();
    callback view_changed(int);
    callback activated(int, string);
    callback request_select(int, string, bool, bool);
    callback select_rect(int, float, float, float, float, int, float, float, float, bool);
    callback clear_selection(int);
    callback request_context_menu(int, string, string, string, string, bool, length, length);
    callback request_blank_context_menu(int, length, length);
    callback zoom_in(int);
    callback zoom_out(int);
    callback drop_target_path(int, float, float, string) -> string;
    callback drop_allowed(int, float, float, string) -> bool;
    callback prepare_transfer(int, string, float, float) -> bool;
    callback transfer_menu_requested(int);
    callback trace_drop(string, string, string, float, float, bool, string);
    callback save_focus_changed(int, bool);
    callback commit_external_edit();
    callback discard_external_edit();
    callback undo_last_operation();
    callback chooser_accept(string);
    callback chooser_filter_requested(int, length, length);
    callback chooser_choice_requested(int, int, length, length);
    pure callback is_selected(int, string) -> bool;
    pure callback make_drag_data(int, string, bool) -> data-transfer;

    background: root.shell-base-color;
    clip: true;

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        padding: 0px;
        spacing: 0px;

        PathBar {
            horizontal-stretch: 1;
            height: root.path-bar-height;
            dark: root.dark;
            current-path: root.current-path;
            can-go-back: root.can-go-back;
            can-go-forward: root.can-go-forward;
            path-text <=> root.path-text;
            path-focused <=> root.path-focused;
            focus_requested => { root.focus_requested(root.pane-side); }
            go_back => { root.go_back(root.pane-side); }
            go_forward => { root.go_forward(root.pane-side); }
            path_submitted(path) => { root.path_submitted(root.pane-side, path); }
        }

        if (root.search-panel-visible) : SearchPanel {
            horizontal-stretch: 1;
            height: root.search-panel-height;
            dark: root.dark;
            loading: root.search-loading;
            filters-active: root.search-filters-active;
            kind-label: root.search-kind-label;
            modified-label: root.search-modified-label;
            size-label: root.search-size-label;
            query <=> root.search-query;
            recursive <=> root.recursive-search;
            kind-filter <=> root.search-kind-filter;
            modified-filter <=> root.search-modified-filter;
            size-filter <=> root.search-size-filter;
            submitted(query) => { root.search_submitted(query); }
            cancel_requested => { root.cancel_search(); }
            filters_changed(kind, modified, size) => {
                root.search_filters_changed(kind, modified, size);
            }
            close_requested => { root.search_close_requested(); }
        }

        pane-content := Rectangle {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            width: parent.width;
            height: max(1px, parent.height - root.path-bar-height - root.status-bar-height - (root.search-panel-visible ? root.search-panel-height : 0px));
            background: root.shell-base-color;
            clip: true;

            DropArea {
                width: parent.width;
                height: parent.height;
                enabled: true;
                changed contains-drag => {
                    if (!self.contains-drag) {
                        root.drag-active = false;
                        root.drag-rejected = false;
                        root.drag-target-path = "";
                    }
                }
                can-drop(event) => {
                    root.focus_requested(root.pane-side);
                    if (!root.drop-ready) {
                        root.drag-active = false;
                        root.drag-rejected = true;
                        root.drag-target-path = "";
                        return DragAction.none;
                    }
                    if (DndApi.event-kind(event) == DragKind.folder || DndApi.event-kind(event) == DragKind.file || DndApi.event-kind(event) == DragKind.place) {
                        root.drag-active = true;
                        root.drag-target-path = root.drop_target_path(root.pane-side, (self.absolute-position.x + event.position.x) / 1px, (self.absolute-position.y + event.position.y) / 1px, DndApi.event-path(event));
                        root.drag-rejected = !root.drop_allowed(root.pane-side, (self.absolute-position.x + event.position.x) / 1px, (self.absolute-position.y + event.position.y) / 1px, DndApi.event-path(event));
                        root.trace_drop(root.drop-trace-prefix + (root.drag-rejected ? "can-drop-rejected" : "can-drop-accepted"), DndApi.event-kind(event) == DragKind.place ? "place" : (DndApi.event-kind(event) == DragKind.folder ? "folder" : "file"), DndApi.event-path(event), (self.absolute-position.x + event.position.x) / 1px, (self.absolute-position.y + event.position.y) / 1px, root.drag-rejected, root.drag-target-path);
                        return DragAction.copy;
                    } else {
                        root.drag-active = false;
                        root.drag-rejected = false;
                        root.drag-target-path = "";
                        root.trace_drop(root.drop-trace-prefix + "can-drop-rejected:unsupported-dnd-payload", "unsupported", DndApi.event-path(event), (self.absolute-position.x + event.position.x) / 1px, (self.absolute-position.y + event.position.y) / 1px, true, "");
                        return DragAction.none;
                    }
                }
                dropped(event) => {
                    root.focus_requested(root.pane-side);
                    root.trace_drop(root.drop-trace-prefix + "dropped", DndApi.event-kind(event) == DragKind.place ? "place" : (DndApi.event-kind(event) == DragKind.folder ? "folder" : (DndApi.event-kind(event) == DragKind.file ? "file" : "unsupported")), DndApi.event-path(event), (self.absolute-position.x + event.position.x) / 1px, (self.absolute-position.y + event.position.y) / 1px, root.drag-rejected, root.drag-target-path);
                    if (!root.drag-rejected && root.drop-ready && (DndApi.event-kind(event) == DragKind.folder || DndApi.event-kind(event) == DragKind.file || DndApi.event-kind(event) == DragKind.place) && root.prepare_transfer(root.pane-side, DndApi.event-path(event), (self.absolute-position.x + event.position.x) / 1px, (self.absolute-position.y + event.position.y) / 1px)) {
                        root.transfer_menu_requested(root.pane-side);
                    }
                    root.drag-active = false;
                    root.drag-rejected = false;
                    root.drag-target-path = "";
                    return DragAction.copy;
                }
            }

            SplitPaneView {
                width: parent.width;
                height: parent.height;
                dark: root.dark;
                entry-count: root.entry-count;
                entries: root.entries;
                virtual-start-index: root.virtual-start-index;
                virtual-start-column: root.virtual-start-column;
                viewport-x <=> root.viewport-x;
                viewport-offset <=> root.viewport-offset;
                zoom-level: root.zoom-level;
                selection-revision: root.selection-revision;
                interactive: root.content-interactive;
                empty-message-visible: root.empty-message-visible;
                empty-title: root.empty-title;
                empty-subtitle: root.empty-subtitle;
                show-location: root.show-location;
                drag-active: root.drag-active;
                drag-rejected: root.drag-rejected;
                drag-target-path: root.drag-target-path;
                make_drag_data(path, is-dir) => {
                    root.make_drag_data(root.pane-side, path, is-dir)
                }
                focus_requested => { root.focus_requested(root.pane-side); }
                view_changed => { root.view_changed(root.pane-side); }
                zoom_in => { root.zoom_in(root.pane-side); }
                zoom_out => { root.zoom_out(root.pane-side); }
                activated(path) => { root.activated(root.pane-side, path); }
                request_select(path, toggle, range) => {
                    root.request_select(root.pane-side, path, toggle, range);
                }
                select_rect(x1, y1, x2, y2, rows-per-column, cell-width, row-height, padding, toggle) => {
                    root.select_rect(root.pane-side, x1, y1, x2, y2, rows-per-column, cell-width, row-height, padding, toggle);
                }
                clear_selection => { root.clear_selection(root.pane-side); }
                request_context_menu(path, name, size, modified, is-dir, x, y) => {
                    root.request_context_menu(root.pane-side, path, name, size, modified, is-dir, x, y);
                }
                request_blank_context_menu(x, y) => {
                    root.request_blank_context_menu(root.pane-side, x, y);
                }
                navigate_back => { root.go_back(root.pane-side); }
                navigate_forward => { root.go_forward(root.pane-side); }
                is_selected(path) => {
                    root.is_selected(root.pane-side, path)
                }
            }

            if (root.drag-active): Rectangle {
                width: parent.width;
                height: parent.height;
                background: root.drag-rejected ? (root.dark ? #3a1515aa : #fee2e2aa) : (root.dark ? #243b4daa : #dff0faaa);
                border-width: 1px;
                border-color: root.drag-rejected ? (root.dark ? #ef4444 : #dc2626) : (root.dark ? #58b4d8 : #2f8dbc);
            }
        }

        StatusBar {
            horizontal-stretch: 1;
            height: root.status-bar-height;
            dark: root.dark;
            status: root.status;
            selected-count: root.selected-count;
            selected-status: root.selected-status;
            external-edit-active: root.external-edit-active;
            external-edit-status: root.external-edit-status;
            undo-available: root.undo-available;
            undo-label: root.undo-label;
            chooser-mode: root.chooser-mode;
            chooser-select-directories: root.chooser-select-directories;
            chooser-save-mode: root.chooser-save-mode;
            chooser-accept-label: root.chooser-accept-label;
            selected-path: root.selected-path;
            chooser-filter-count: root.chooser-filter-count;
            chooser-filter-label: root.chooser-filter-label;
            chooser-choices: root.chooser-choices;
            chooser-save-name <=> root.chooser-save-name;
            save_focus_changed(focused) => { root.save_focus_changed(root.pane-side, focused); }
            commit_external_edit => { root.commit_external_edit(); }
            discard_external_edit => { root.discard_external_edit(); }
            undo_last_operation => { root.undo_last_operation(); }
            chooser_accept(value) => { root.chooser_accept(value); }
            chooser_filter_requested(x, y) => { root.chooser_filter_requested(root.pane-side, x, y); }
            chooser_choice_requested(index, x, y) => {
                root.chooser_choice_requested(root.pane-side, index, x, y);
            }
        }
    }
}

export component AppWindow inherits Window {
    in-out property <string> current_path;
    in-out property <string> items_path;
    in-out property <string> left_pane_path;
    in-out property <string> left_pane_path_input_text;
    in-out property <bool> left_pane_path_focused: false;
    in-out property <bool> left_pane_can_go_back: false;
    in-out property <bool> left_pane_can_go_forward: false;
    in-out property <bool> left_pane_in_trash: false;
    in property <string> current_name;
    in property <string> status;
    in-out property <string> left_pane_status;
    in-out property <int> left_pane_selected_count: 0;
    in-out property <string> left_pane_selected_status;
    in property <bool> chooser_mode;
    in property <bool> chooser_select_directories;
    in property <bool> chooser_multiple;
    in property <bool> chooser_save_mode;
    in-out property <string> chooser_title;
    in property <string> chooser_accept_label;
    in-out property <int> chooser_filter_count: 0;
    in-out property <int> chooser_filter_index: 0;
    in-out property <string> chooser_filter_label;
    in property <[ChooserChoiceOption]> chooser_filter_options;
    in property <[ChooserChoice]> chooser_choices;
    in-out property <int> entry_count: 0;
    in property <[FileEntry]> virtual_entries;
    in-out property <int> virtual_start_index: 0;
    in-out property <int> virtual_start_column: 0;
    in property <[FileEntry]> inactive_pane_entries;
    in-out property <string> inactive_pane_path;
    in-out property <string> inactive_pane_path_input_text;
    in-out property <bool> inactive_pane_path_focused: false;
    in-out property <bool> inactive_pane_can_go_back: false;
    in-out property <bool> inactive_pane_can_go_forward: false;
    in-out property <int> inactive_pane_entry_count: 0;
    in-out property <int> inactive_pane_virtual_start_index: 0;
    in-out property <int> inactive_pane_virtual_start_column: 0;
    in-out property <float> inactive_pane_viewport_x: 0;
    in-out property <length> inactive_pane_viewport_offset: 0px;
    in-out property <string> inactive_pane_status;
    in-out property <bool> inactive_pane_in_trash: false;
    in-out property <int> inactive_pane_selected_count: 0;
    in-out property <string> inactive_pane_selected_status;
    in property <[PlaceEntry]> places;
    in property <[DeviceEntry]> devices;
    in-out property <string> selected_path;
    in-out property <int> selected_count;
    in-out property <string> selected_status;
    in-out property <string> chooser_save_name;
    in-out property <bool> external_edit_active: false;
    in-out property <string> external_edit_status;
    in-out property <bool> undo_available: false;
    in-out property <string> undo_label;
    in-out property <int> selection_revision;
    in-out property <string> search_query;
    in-out property <bool> dark_mode;
    in-out property <bool> recursive_search: false;
    in-out property <int> search_kind_filter: 0;
    in-out property <int> search_modified_filter: 0;
    in-out property <int> search_size_filter: 0;
    in-out property <bool> search_bar_open: false;
    in-out property <bool> search_loading: false;
    in-out property <bool> clipboard_has_paths: false;
    in-out property <bool> clipboard_cut: false;
    in-out property <bool> current_in_trash: false;
    in-out property <bool> split_view_open: false;
    in-out property <float> split_pane_ratio: 0.5;
    in-out property <int> focused_pane: 0;

    in-out property <int> icon_zoom_level: 2;
    in-out property <float> sidebar_width_px: 280;
    in-out property <float> places_list_y_px: 108;
    in-out property <float> places_row_stride_px: 38;
    in-out property <bool> directory_loading: false;
    in-out property <float> main_viewport_x: 0;
    in-out property <length> main_viewport_offset: 0px;
    private property <length> shell-header-height: 56px;
    private property <length> path-bar-height: 56px;
    private property <length> status-bar-height: 36px;
    private property <length> sidebar-resize-hit-width: 8px;
    private property <string> sidebar-selected-path: root.focused_pane == 1 && root.split_view_open ? root.inactive_pane_path : root.left_pane_path;
    private property <length> main-content-left: root.sidebar_width_px * 1px;
    private property <bool> search-filters-active: root.search_kind_filter != 0 || root.search_modified_filter != 0 || root.search_size_filter != 0;
    private property <bool> search-panel-visible: root.search_bar_open || root.search_query != "" || root.search-filters-active;
    private property <length> search-panel-height: root.search-panel-visible ? (root.active-pane-width < 760px ? 78px : 44px) : 0px;
    private property <string> search-kind-filter-label: root.search_kind_filter == 1 ? "Type: Folders" : (root.search_kind_filter == 2 ? "Type: Files" : (root.search_kind_filter == 3 ? "Type: Images" : "Type: All"));
    private property <string> search-modified-filter-label: root.search_modified_filter == 1 ? "Modified: Today" : (root.search_modified_filter == 2 ? "Modified: 7 days" : (root.search_modified_filter == 3 ? "Modified: 30 days" : "Modified: Any"));
    private property <string> search-size-filter-label: root.search_size_filter == 1 ? "Size: < 1 MB" : (root.search_size_filter == 2 ? "Size: 1-100 MB" : (root.search_size_filter == 3 ? "Size: > 100 MB" : "Size: Any"));
    private property <length> main-pane-width: max(1px, root.width - root.main-content-left);
    private property <length> split-divider-width: root.split_view_open ? 1px : 0px;
    private property <length> split-resize-hit-width: 15px;
    private property <length> split-content-width: max(1px, root.main-pane-width - root.split-divider-width);
    private property <length> split-pane-min-width: min(260px, max(1px, root.split-content-width / 2));
    private property <length> split-ratio-pane-width: max(1px, floor((root.split-content-width * root.split_pane_ratio) / 1px) * 1px);
    private property <length> active-pane-width: root.split_view_open ? max(root.split-pane-min-width, min(root.split-content-width - root.split-pane-min-width, root.split-ratio-pane-width)) : root.main-pane-width;
    private property <length> inactive-pane-x: root.active-pane-width + root.split-divider-width;
    private property <length> inactive-pane-width: root.split_view_open ? max(1px, root.main-pane-width - root.inactive-pane-x) : 0px;
    private property <length> main-content-height: max(1px, root.height - root.shell-header-height);
    private property <color> shell-base-color: root.dark_mode ? #101418 : #f6f8fa;
    private property <color> sidebar-surface-color: root.dark_mode ? #181e24 : #ffffff;
    private property <color> sidebar-border-color: root.dark_mode ? #313a43 : #d8e1ea;
    private property <color> shell-separator-color: root.dark_mode ? #242b33 : #e5eaf0;
    private property <length> sidebar-panel-radius: 16px;
    private property <length> sidebar-bottom-gap: 14px;
    private property <length> sidebar-content-bottom-padding: 22px;
    private property <length> sidebar-content-height: 10px + 30px + root.places.length * 38px + 30px + 30px + root.devices.length * 38px + (root.places.length + root.devices.length + 2) * 4px + root.sidebar-content-bottom-padding;
    private property <float> sidebar-resize-start-width-px: 280;
    private property <length> sidebar-resize-press-x: 0px;
    private property <float> split-resize-start-ratio: 0.5;
    private property <length> split-resize-press-x: 0px;
    private property <bool> split-resize-active: false;
    private property <bool> context-menu-open: false;
    private property <int> context-menu-kind: 0;
    private property <string> context-menu-path;
    private property <string> context-menu-name;
    private property <string> context-menu-properties-size;
    private property <string> context-menu-properties-modified;
    private property <bool> context-menu-is-dir: false;
    private property <int> context-menu-place-index: -1;
    private property <bool> context-menu-place-builtin: false;
    private property <string> context-menu-device-path;
    private property <string> context-menu-device-open-path;
    private property <bool> context-menu-device-mounted: false;
    private property <bool> context-menu-device-can-mount: false;
    private property <bool> context-menu-device-can-unmount: false;
    private property <bool> context-menu-device-can-eject: false;
    private property <string> context-menu-device-pending-action: "";
    private property <length> context-menu-x: 0px;
    private property <length> context-menu-y: 0px;
    private property <length> menu-pointer-gap: 8px;
    private property <length> menu-screen-margin: 12px;
    private property <length> menu-item-height: 38px;
    private property <length> menu-separator-height: 8px;
    private property <length> menu-title-height: 30px;
    private property <length> context-file-menu-width: 220px;
    private property <length> context-place-menu-width: 220px;
    private property <length> context-blank-menu-width: 220px;
    private property <bool> context-default-open-visible: root.default_open_app_name != "" && root.open_with_path == root.context-menu-path;
    private property <bool> context-add-place-visible: root.context-menu-kind == 4 ? (root.current_path != "" && !root.is_place(root.current_path)) : (root.context-menu-is-dir && !root.is_place(root.context-menu-path));
    private property <length> child-menu-gap: 3px;
    private property <bool> rename-place-open: false;
    private property <int> rename-place-index: -1;
    private property <string> rename-place-label;
    in-out property <bool> privileged_prompt_open: false;
    in-out property <string> privileged_prompt_title;
    in-out property <string> privileged_prompt_message;
