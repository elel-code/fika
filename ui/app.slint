    private property <length> chooser-choice-menu-x: 0px;
    private property <length> chooser-choice-menu-y: 0px;
    private property <length> chooser-choice-menu-width: 220px;
    private property <bool> chooser-filter-menu-open: false;
    private property <length> chooser-filter-menu-x: 0px;
    private property <length> chooser-filter-menu-y: 0px;
    private property <length> chooser-filter-menu-width: 220px;
