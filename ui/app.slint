    function stop-submenu-close-timers() {
        open-with-close-timer.stop();
        create-new-close-timer.stop();
    }

    function set-child-submenu-hover(menu: int, is-hovered: bool) {
        if (menu == 1) {
            open-with-close-timer.stop();
            if (!is-hovered) {
                open-with-close-timer.start();
            }
        } else if (menu == 2) {
            create-new-close-timer.stop();
            if (!is-hovered) {
                create-new-close-timer.start();
            }
        }
    }

    function show-open-with-submenu(path: string, row-y: length) {
        root.stop-submenu-close-timers();
        root.prepare_open_with(path);
        root.open_with_path = path;
        root.open-with-menu-y = row-y;
        root.create-new-menu-open = false;
        root.open-with-menu-open = true;
    }

    function show-create-new-submenu(row-y: length) {
        root.stop-submenu-close-timers();
        root.open-with-menu-open = false;
        root.create-new-menu-y = row-y;
        root.create-new-menu-open = true;
    }

    function open-with-submenu-hover(path: string, row-y: length, is-hovered: bool) {
        if (is-hovered) {
            root.show-open-with-submenu(path, row-y);
        } else {
            root.set-child-submenu-hover(1, false);
        }
    }

    function create-new-submenu-hover(row-y: length, is-hovered: bool) {
        if (is-hovered) {
            root.show-create-new-submenu(row-y);
        } else {
            root.set-child-submenu-hover(2, false);
        }
    }

    function close-context-popups() {
        root.context-menu-open = false;
        root.open-with-menu-open = false;
        root.create-new-menu-open = false;
        root.stop-submenu-close-timers();
    }

    function show-context-menu(kind: int, x: length, y: length) {
        root.context-menu-kind = kind;
        root.context-menu-x = x;
        root.context-menu-y = y;
        root.open-with-menu-open = false;
        root.create-new-menu-open = false;
        root.stop-submenu-close-timers();
        root.context-menu-open = true;
    }

    function sync-main-viewport() {
        root.main_viewport_x = root.entry_count == 0 ? 0 : max(0, min(root.main-scroll-max-x, root.main_viewport_x));
        root.main_viewport_offset = -root.main_viewport_x * 1px;
    }

    function zoom-main-in() {
        root.icon_zoom_level = min(4, root.icon_zoom_level + 1);
        root.sync-main-viewport();
        root.persist_ui_state();
    }

    function zoom-main-out() {
        root.icon_zoom_level = max(0, root.icon_zoom_level - 1);
        root.sync-main-viewport();
        root.persist_ui_state();
    }

    function pan-main-horizontal(delta: length) {
        root.main_viewport_x = root.entry_count == 0 ? 0 : max(0, min(root.main-scroll-max-x, root.main_viewport_x + delta / 1px));
        root.main_viewport_offset = -root.main_viewport_x * 1px;
    }

    function handle-main-scroll(delta-x: length, delta-y: length, control: bool) {
        if (control && delta-y < 0px) {
            root.zoom-main-out();
        } else if (control && delta-y > 0px) {
            root.zoom-main-in();
        } else {
            root.pan-main-horizontal(-(delta-y + delta-x));
        }
    }

    open-with-close-timer := Timer {
        running: false;
        interval: 240ms;
        triggered => {
            self.running = false;
            root.open-with-menu-open = false;
        }
    }

    create-new-close-timer := Timer {
        running: false;
        interval: 240ms;
        triggered => {
            self.running = false;
            root.create-new-menu-open = false;
        }
    }

    title: chooser_mode ? (chooser_title == "" ? "Fika File Chooser" : chooser_title) : "Fika File Manager";
    preferred-width: 1100px;
    preferred-height: 760px;
    min-width: 780px;
    min-height: 460px;
    background: dark_mode ? #101314 : #ffffff;

    changed width => { root.main_view_changed(); }
    changed height => { root.main_view_changed(); }
    changed main_viewport_x => { root.main_view_changed(); }
    changed icon_zoom_level => { root.main_view_changed(); }
    changed transfer_conflict_open => {
        if (root.transfer_conflict_open) {
            root.transfer-conflict-apply-all = false;
        }
    }

    app-focus := FocusScope {
        width: parent.width;
        height: parent.height;

        KeyBinding {
            keys: @keys(F5);
            activated => { root.refresh(); }
        }

        KeyBinding {
            keys: @keys(Control + A);
            activated => {
                if (!root.file-operation-shortcuts-blocked) {
                    root.select_all_visible();
                }
            }
        }

        KeyBinding {
            keys: @keys(Control + F);
            activated => { root.search_bar_open = true; }
        }

        KeyBinding {
            keys: @keys(Control + C);
            activated => {
                if (!root.file-operation-shortcuts-blocked && root.selected_count > 0) {
                    root.copy_paths(root.selected_path, false);
                }
            }
        }

        KeyBinding {
            keys: @keys(Control + X);
            activated => {
                if (!root.file-operation-shortcuts-blocked && root.selected_count > 0) {
                    root.copy_paths(root.selected_path, true);
                }
            }
        }

        KeyBinding {
            keys: @keys(Control + V);
            activated => {
                if (!root.file-operation-shortcuts-blocked) {
                    root.refresh_clipboard_availability();
                    root.paste_into(root.current_path);
                }
            }
        }

        KeyBinding {
            keys: @keys(Control + Z);
            activated => {
                if (!root.file-operation-shortcuts-blocked && root.undo_available) {
                    root.undo_last_operation();
                }
            }
        }

        KeyBinding {
            keys: @keys(Escape);
            activated => {
                if (root.context-menu-open || root.open-with-menu-open || root.create-new-menu-open) {
                    root.close-context-popups();
                } else if (root.rename-place-open) {
                    root.rename-place-open = false;
                } else if (root.privileged_prompt_open) {
                    root.privileged_prompt_dismiss();
                } else if (root.search_bar_open || root.search_query != "" || root.search-filters-active) {
                    root.search_query = "";
                    root.search_kind_filter = 0;
                    root.search_modified_filter = 0;
                    root.search_size_filter = 0;
                    root.search_filters_changed(root.search_kind_filter, root.search_modified_filter, root.search_size_filter);
                    root.search_submitted("");
                    root.search_bar_open = false;
                } else {
                    root.clear_selection();
                }
            }
        }

        VerticalLayout {
            padding: 0px;
            spacing: 0px;

        Rectangle {
            height: 64px;
            background: root.dark_mode ? #25292d : #f8fafc;
            border-color: root.dark_mode ? #43484d : #d6dce2;
            border-width: 1px;

            HorizontalLayout {
                padding-left: 18px;
                padding-right: 18px;
                padding-top: 12px;
                padding-bottom: 12px;
                spacing: 14px;

                HorizontalLayout {
                    spacing: 6px;

                    ToolButton {
                        label: "<";
                        dark: root.dark_mode;
                        clicked => { root.go_parent(); }
                    }
                    ToolButton {
                        label: "H";
                        dark: root.dark_mode;
                        clicked => { root.go_home(); }
                    }
                }

                LineEdit {
                    horizontal-stretch: 1;
                    min-width: 260px;
                    height: 40px;
                    text <=> root.path_input_text;
                    placeholder-text: "/path/to/folder";
                    accepted => { root.path_submitted(self.text); }
                    changed has-focus => {
                        root.path-input-focused = self.has-focus;
                        if (!self.has-focus) {
                            self.text = root.current_path;
                        } else if (self.text == "") {
                            self.text = root.current_path;
                        }
                    }
                }

                HorizontalLayout {
                    spacing: 16px;

                    Text {
                        text: "Split";
                        color: root.dark_mode ? #f1f1f1 : #334155;
                        font-size: 14px;
                        font-weight: 500;
                        height: 40px;
                        min-width: 34px;
                        vertical-alignment: center;
                    }

                    ToolButton {
                        label: "S";
                        dark: root.dark_mode;
                        clicked => { root.search_bar_open = true; }
                    }

                    ToolButton {
                        label: root.dark_mode ? "L" : "D";
                        dark: root.dark_mode;
                        clicked => {
                            root.dark_mode = !root.dark_mode;
                            root.persist_ui_state();
                        }
                    }
                }
            }
        }

        HorizontalLayout {
            vertical-stretch: 1;
            spacing: 0px;

            Rectangle {
                width: root.sidebar_width_px * 1px;
                background: root.dark_mode ? #222629 : #f3f6f8;
                border-color: root.dark_mode ? #454a50 : #d6dce2;
                border-width: 1px;

                TouchArea {
                    width: parent.width;
                    height: parent.height;
                    pointer-event(event) => {
                        if (event.button == PointerEventButton.right && event.kind == PointerEventKind.down) {
                            root.context-menu-place-index = -1;
                            root.context-menu-place-builtin = false;
                            root.rename-place-label = "Places";
                            root.show-context-menu(4, self.absolute-position.x + self.mouse-x, self.absolute-position.y + self.mouse-y);
                        }
                    }
                }

                sidebar-scroll := ScrollView {
                    width: parent.width;
                    height: parent.height;
                    horizontal-scrollbar-policy: always-off;
                    vertical-scrollbar-policy: as-needed;
                    viewport-width: parent.width;
                    viewport-height: max(parent.height, 520px + (root.places.length + root.devices.length) * 38px);
                    changed viewport-y => {
                        root.places_list_y_px = (self.absolute-position.y + 44px - self.viewport-y) / 1px;
                    }

                VerticalLayout {
                    padding-top: 10px;
                    spacing: 4px;
                    width: sidebar-scroll.viewport-width;
                    height: sidebar-scroll.viewport-height;

                    SidebarSection { label: "Places"; dark: root.dark_mode; }

                    for place[index] in root.places: PlaceButton {
                        label: place.label;
                        path: place.path;
                        marker: place.marker;
                        selected: root.current_path == place.path;
                        dark: root.dark_mode;
                        index: index;
                        place_count: root.places.length;
                        builtin: place.is_builtin;
                        list_y: parent.absolute-position.y + 44px - sidebar-scroll.viewport-y;
                        reorderable: true;
                        dragged: root.place_drag_active && root.place_drag_from == index;
                        drop-target: (root.folder_drag_active || root.place_drag_active) && root.folder_drag_over_place_item && !root.place_drag_rejected && root.folder_drag_place_target == index;
                        clicked => { root.open_place(place.path); }
                        context_requested(index, label, builtin, path, x, y) => {
                            root.context-menu-place-index = index;
                            root.context-menu-place-builtin = builtin;
                            root.rename-place-label = label;
                            root.show-context-menu(2, x, y);
                        }
                        drag_cancelled => {
                            root.place_drag_active = false;
                            root.place_drag_from = -1;
                            root.place_drag_target_path = "";
                            root.place_drag_target_label = "";
                        }
                    }

                    SidebarAction {
                        label: "Cancel Operations";
                        dark: root.dark_mode;
                        clicked => { root.cancel_queued_operations(); }
                    }

                    SidebarSection { label: "Remote"; dark: root.dark_mode; }
                    PlaceButton {
                        label: "Network";
                        path: "";
                        marker: "N";
                        selected: false;
                        dark: root.dark_mode;
                        clicked => { }
                    }

                    SidebarSection { label: "Devices"; dark: root.dark_mode; }
                    for device in root.devices: PlaceButton {
                        label: device.label;
                        path: device.path;
                        marker: device.marker;
                        selected: root.current_path == device.path;
                        dark: root.dark_mode;
                        reorderable: false;
                        dragged: false;
                        drop-target: false;
                        builtin: true;
                        available: device.mounted;
                        pending-action: device.pending_action;
                        error: device.error;
                        clicked => { root.open_device(device.mounted ? device.path : device.device_path, device.mounted); }
                        context_requested(index, label, builtin, path, x, y) => {
                            root.context-menu-device-path = device.device_path;
                            root.context-menu-device-open-path = device.path;
                            root.context-menu-device-mounted = device.mounted;
                            root.context-menu-device-can-eject = device.can_eject;
                            root.context-menu-device-pending-action = device.pending_action;
                            root.rename-place-label = label;
                            root.show-context-menu(5, x, y);
                        }
                    }

                    Rectangle { vertical-stretch: 1; }
                }
                }

                places-folder-drop := DropArea {
                    enabled: true;
                    changed contains-drag => {
                        if (!self.contains-drag) {
                            root.folder_drag_active = false;
                            root.place_drag_active = false;
                            root.folder_drag_over_place_item = false;
                            root.place_drag_rejected = false;
                        }
                    }
                    can-drop(event) => {
                        root.trace_places_drop("can-drop", event.mime-type, event.data, (self.absolute-position.x + event.position.x) / 1px, (self.absolute-position.y + event.position.y) / 1px, root.folder_drag_slot, root.folder_drag_place_target, root.folder_drag_over_place_gap, root.folder_drag_over_place_item);
                        if (root.places_drop_supported(event.mime-type)) {
                            root.folder_drag_path = event.data;
                            root.folder_drag_label = event.data;
                            root.folder_drag_x = self.absolute-position.x + event.position.x;
                            root.folder_drag_y = self.absolute-position.y + event.position.y;
                            root.place_drag_x = root.folder_drag_x;
                            root.place_drag_y = root.folder_drag_y;
                            root.folder_drag_active = event.mime-type == "application/x-fika-folder-path" || root.places_drop_force_gap(event.mime-type);
                            root.place_drag_active = event.mime-type == "application/x-fika-place-path";
                            root.place_drag_label = event.data;
                            root.place_drag_marker = "P";
                            root.place_list_y = self.absolute-position.y + 44px - sidebar-scroll.viewport-y;
                            root.places_list_y_px = root.place_list_y / 1px;
                            root.folder_drag_place_target = root.place_drop_target((self.absolute-position.y + event.position.y) / 1px, root.places_drop_force_gap(event.mime-type));
                            root.folder_drag_over_place_gap = root.place_drop_over_gap((self.absolute-position.y + event.position.y) / 1px, root.places_drop_force_gap(event.mime-type));
                            root.folder_drag_over_place_item = root.place_drop_over_item((self.absolute-position.y + event.position.y) / 1px, root.places_drop_force_gap(event.mime-type));
                            root.place_drag_rejected = root.folder_drag_over_place_item && !root.place_drop_allowed(event.data, root.folder_drag_place_target);
                            root.folder_drag_slot = root.place_drop_slot((self.absolute-position.y + event.position.y) / 1px, root.places_drop_force_gap(event.mime-type));
                            root.place_drag_slot = root.folder_drag_slot;
                            root.trace_places_drop("can-drop-accepted", event.mime-type, event.data, root.folder_drag_x / 1px, root.folder_drag_y / 1px, root.folder_drag_slot, root.folder_drag_place_target, root.folder_drag_over_place_gap, root.folder_drag_over_place_item);
                            true
                        } else {
                            root.folder_drag_active = false;
                            root.folder_drag_over_place_item = false;
                            root.place_drag_rejected = false;
                            root.trace_places_drop("can-drop-rejected", event.mime-type, event.data, (self.absolute-position.x + event.position.x) / 1px, (self.absolute-position.y + event.position.y) / 1px, -1, -1, false, false);
                            false
                        }
                    }
                    dropped(event) => {
                        root.trace_places_drop("dropped", event.mime-type, event.data, (self.absolute-position.x + event.position.x) / 1px, (self.absolute-position.y + event.position.y) / 1px, root.folder_drag_slot, root.folder_drag_place_target, root.folder_drag_over_place_gap, root.folder_drag_over_place_item);
                        if (event.position.y + sidebar-scroll.viewport-y >= 44px && event.position.y + sidebar-scroll.viewport-y <= 44px + root.places.length * 38px) {
                            if (root.folder_drag_over_place_gap || root.folder_drag_slot >= root.places.length) {
                                if (event.mime-type == "application/x-fika-place-path") {
                                    root.reorder_place_path(event.data, root.folder_drag_slot);
                                } else if (root.places_drop_force_gap(event.mime-type)) {
                                    root.add_external_place_at_slot(event.data, root.folder_drag_slot, event.mime-type);
                                } else {
                                    root.add_place_at_slot(event.data, root.folder_drag_slot);
                                }
                            } else {
                                if (root.prepare_place_transfer(event.data, root.folder_drag_place_target, (self.absolute-position.x + event.position.x) / 1px, (self.absolute-position.y + event.position.y) / 1px)) {
                                    root.transfer-menu-open = true;
                                }
                            }
                        }
                        root.folder_drag_active = false;
                        root.place_drag_active = false;
                        root.folder_drag_over_place_item = false;
                        root.place_drag_rejected = false;
                    }
                }
            }

            Rectangle {
                width: 8px;
                background: resize-touch.has-hover || resize-touch.pressed ? (root.dark_mode ? #2f6f91 : #c7ddea) : (root.dark_mode ? #15191c : #edf2f6);

                Rectangle {
                    x: 3px;
                    width: 1px;
                    height: parent.height;
                    background: root.dark_mode ? #454a50 : #cbd5e1;
                }

                resize-touch := TouchArea {
                    mouse-cursor: ew-resize;

                    pointer-event(event) => {
                        if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                            root.sidebar-resize-start-width-px = root.sidebar_width_px;
                            root.sidebar-resize-press-x = self.absolute-position.x + self.mouse-x;
                        } else if (event.button == PointerEventButton.left && event.kind == PointerEventKind.up) {
                            root.persist_ui_state();
                        }
                    }

                    moved => {
                        if (self.pressed) {
                            root.sidebar_width_px = max(220, min((root.width - 360px) / 1px, root.sidebar-resize-start-width-px + (self.absolute-position.x + self.mouse-x - root.sidebar-resize-press-x) / 1px));
                        }
                    }
                }
            }

            main-pane := Rectangle {
                horizontal-stretch: 1;
                background: root.dark_mode ? #101314 : #ffffff;

                main-focus := FocusScope {
                    width: 0px;
                    height: 0px;
                }

                main-blank-touch := TouchArea {
                    width: parent.width;
                    height: parent.height;

                    pointer-event(event) => {
                        if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                            main-focus.focus();
                            root.clear_selection();
                        } else if (event.button == PointerEventButton.right && event.kind == PointerEventKind.down) {
                            main-focus.focus();
                            root.clear_selection();
                            root.refresh_clipboard_availability();
                            root.show-context-menu(3, self.absolute-position.x + self.mouse-x, self.absolute-position.y + self.mouse-y);
                        }
                    }
                    scroll-event(event) => {
                        root.handle-main-scroll(event.delta-x, event.delta-y, event.modifiers.control);
                        return accept;
                    }
                }

                VerticalLayout {
                    padding: 0px;
                    spacing: 0px;

                    if (root.search-panel-visible) : Rectangle {
                        height: root.search-panel-height;
                        background: root.dark_mode ? #171b1f : #f8fafc;
                        border-color: root.dark_mode ? #343a40 : #d6dce2;
                        border-width: 1px;

                        VerticalLayout {
                            padding-left: 14px;
                            padding-right: 14px;
                            padding-top: 8px;
                            padding-bottom: 8px;
                            spacing: 6px;

                            HorizontalLayout {
                                spacing: 10px;

                                Text {
                                    text: "Search";
                                    color: root.dark_mode ? #d8dee5 : #334155;
                                    font-size: 13px;
                                    font-weight: 700;
                                    min-width: 52px;
                                    vertical-alignment: center;
                                }

                                LineEdit {
                                    horizontal-stretch: 1;
                                    min-width: 180px;
                                    height: 34px;
                                    text <=> root.search_query;
                                    placeholder-text: "Search in current folder";
                                    accepted => { root.search_submitted(self.text); }
                                    changed has-focus => {
                                        root.search-input-focused = self.has-focus;
                                    }
                                }

                                if (root.search_loading): SidebarAction {
                                    width: 70px;
                                    label: "Cancel";
                                    dark: root.dark_mode;
                                    clicked => { root.cancel_search(); }
                                }

                                if (root.search_query != "" || root.search-filters-active): SidebarAction {
                                    width: 64px;
                                    label: "Clear";
                                    dark: root.dark_mode;
                                    clicked => {
                                        root.search_query = "";
                                        root.search_kind_filter = 0;
                                        root.search_modified_filter = 0;
                                        root.search_size_filter = 0;
                                        root.search_filters_changed(root.search_kind_filter, root.search_modified_filter, root.search_size_filter);
                                        root.search_submitted("");
                                    }
                                }

                                ToolButton {
                                    label: "X";
                                    dark: root.dark_mode;
                                    clicked => {
                                        root.search_query = "";
                                        root.search_kind_filter = 0;
                                        root.search_modified_filter = 0;
                                        root.search_size_filter = 0;
                                        root.search_filters_changed(root.search_kind_filter, root.search_modified_filter, root.search_size_filter);
                                        root.search_submitted("");
                                        root.search_bar_open = false;
                                    }
                                }
                            }

                            HorizontalLayout {
                                spacing: 8px;

                                CheckOption {
                                    width: 150px;
                                    label: "Search subfolders";
                                    dark: root.dark_mode;
                                    checked <=> root.recursive_search;
                                    toggled(_) => {
                                        if (root.search_query != "") {
                                            root.search_submitted(root.search_query);
                                        }
                                    }
                                }

                                FilterButton {
                                    width: 90px;
                                    label: root.search-kind-filter-label;
                                    dark: root.dark_mode;
                                    clicked => {
                                        root.search_kind_filter = mod(root.search_kind_filter + 1, 4);
                                        root.search_filters_changed(root.search_kind_filter, root.search_modified_filter, root.search_size_filter);
                                    }
                                }

                                FilterButton {
                                    width: 96px;
                                    label: root.search-modified-filter-label;
                                    dark: root.dark_mode;
                                    clicked => {
                                        root.search_modified_filter = mod(root.search_modified_filter + 1, 4);
                                        root.search_filters_changed(root.search_kind_filter, root.search_modified_filter, root.search_size_filter);
                                    }
                                }

                                FilterButton {
                                    width: 90px;
                                    label: root.search-size-filter-label;
                                    dark: root.dark_mode;
                                    clicked => {
                                        root.search_size_filter = mod(root.search_size_filter + 1, 4);
                                        root.search_filters_changed(root.search_kind_filter, root.search_modified_filter, root.search_size_filter);
                                    }
                                }
                            }
                        }
                    }

                    if (root.entry_count == 0) : Rectangle {
                        vertical-stretch: 1;
                        background: root.dark_mode ? #101314 : #ffffff;

                        VerticalLayout {
                            alignment: center;
                            spacing: 8px;

                            Text {
                                text: root.directory_loading ? "Loading folder..." : (root.search_loading ? "Searching..." : (root.search_query == "" ? "This folder is empty" : "No matching items"));
                                color: root.dark_mode ? #e6e6e6 : #334155;
                                font-size: 15px;
                                font-weight: 600;
                                horizontal-alignment: center;
                            }

                            Text {
                                text: root.directory_loading ? "Preparing the next view." : (root.search_loading ? "Scanning subfolders." : (root.search_query == "" ? "This directory has no visible files." : "Try another search term."));
                                color: root.dark_mode ? #a8a8a8 : #94a3b8;
                                font-size: 13px;
                                horizontal-alignment: center;
                            }
                        }
                    }

                    if (root.entry_count > 0) : grid := ScrollView {
                        vertical-stretch: 1;
                        horizontal-scrollbar-policy: as-needed;
                        vertical-scrollbar-policy: always-off;

                        property <int> rows-per-column: root.main-rows-per-column;
                        property <int> column-count: root.main-column-count;
                        viewport-width: root.main-viewport-width;
                        viewport-height: 2 * root.icon-grid-padding + root.main-rows-per-column * root.icon-row-height;
                        viewport-x <=> root.main_viewport_offset;
                        viewport-y: 0px;

                        changed viewport-x => {
                            root.main_viewport_x = max(0, min(root.main-scroll-max-x, -self.viewport-x / 1px));
                        }

                        DropArea {
                            width: grid.viewport-width;
                            height: grid.viewport-height;
                            enabled: true;
                            changed contains-drag => {
                                if (!self.contains-drag) {
                                    root.main_drag_active = false;
                                    root.main_drag_rejected = false;
                                    root.place_drag_target_path = "";
                                    root.place_drag_target_label = "";
                                }
                            }
                            can-drop(event) => {
                                if (event.mime-type == "application/x-fika-folder-path" || event.mime-type == "application/x-fika-place-path") {
                                    root.main_drag_active = true;
                                    root.main_drag_rejected = !root.main_drop_allowed((self.absolute-position.x + event.position.x) / 1px, (self.absolute-position.y + event.position.y) / 1px, event.data);
                                    root.place_drag_target_path = root.main_drop_target_path((self.absolute-position.x + event.position.x) / 1px, (self.absolute-position.y + event.position.y) / 1px, event.data);
                                    true
                                } else {
                                    root.main_drag_active = false;
                                    root.main_drag_rejected = false;
                                    root.place_drag_target_path = "";
                                    false
                                }
                            }
                            dropped(event) => {
                                root.main_drag_active = false;
                                root.main_drag_rejected = false;
                                if (root.prepare_path_main_transfer(event.data, (self.absolute-position.x + event.position.x) / 1px, (self.absolute-position.y + event.position.y) / 1px)) {
                                    root.transfer-menu-open = true;
                                }
                            }

                        TouchArea {
                            width: parent.width;
                            height: parent.height;
                            pointer-event(event) => {
                                if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                                    main-focus.focus();
                                    root.selection_rect_pending = true;
                                    root.selection_rect_active = false;
                                    root.selection_rect_toggle = event.modifiers.control;
                                    root.selection_rect_start_x = self.mouse-x;
                                    root.selection_rect_start_y = self.mouse-y;
                                    root.selection_rect_current_x = self.mouse-x;
                                    root.selection_rect_current_y = self.mouse-y;
                                } else if (event.button == PointerEventButton.left && event.kind == PointerEventKind.up) {
                                    if (root.selection_rect_active) {
                                        root.select_rect(
                                            min(root.selection_rect_start_x, root.selection_rect_current_x) / 1px,
                                            min(root.selection_rect_start_y, root.selection_rect_current_y) / 1px,
                                            max(root.selection_rect_start_x, root.selection_rect_current_x) / 1px,
                                            max(root.selection_rect_start_y, root.selection_rect_current_y) / 1px,
                                            grid.rows-per-column,
                                            root.icon-cell-width / 1px,
                                            root.icon-row-height / 1px,
                                            root.icon-grid-padding / 1px,
                                            root.selection_rect_toggle
                                        );
                                    } else if (root.selection_rect_pending) {
                                        root.clear_selection();
                                    }
                                    root.selection_rect_active = false;
                                    root.selection_rect_pending = false;
                                } else if (event.button == PointerEventButton.right && event.kind == PointerEventKind.down) {
                                    main-focus.focus();
                                    root.clear_selection();
                                    root.refresh_clipboard_availability();
                                    root.show-context-menu(3, self.absolute-position.x + self.mouse-x, self.absolute-position.y + self.mouse-y);
                                }
                            }
                            moved => {
                                if (self.pressed && root.selection_rect_pending) {
                                    root.selection_rect_current_x = self.mouse-x;
                                    root.selection_rect_current_y = self.mouse-y;
                                    if (!root.selection_rect_active && (self.mouse-x > root.selection_rect_start_x + 5px || self.mouse-x + 5px < root.selection_rect_start_x || self.mouse-y > root.selection_rect_start_y + 5px || self.mouse-y + 5px < root.selection_rect_start_y)) {
                                        root.selection_rect_active = true;
                                    }
                                }
                            }
                            scroll-event(event) => {
                                root.handle-main-scroll(event.delta-x, event.delta-y, event.modifiers.control);
                                return accept;
                            }
                        }
                        }

                        virtual-layer := Rectangle {
                            x: root.icon-grid-padding + root.virtual_start_column * root.icon-cell-width;
                            y: 0px;
                            width: max(1px, root.main-viewport-width - self.x);
                            height: grid.viewport-height;

                            for item[index] in root.virtual_entries: FileTile {
                                property <int> local-index: index + root.virtual_start_index - root.virtual_start_column * grid.rows-per-column;
                                x: floor(local-index / grid.rows-per-column) * root.icon-cell-width;
                                y: root.icon-grid-padding + mod(local-index, grid.rows-per-column) * root.icon-row-height;
                                width: root.icon-cell-width - 12px;
                                entry: item;
                                selected: root.selection_revision >= 0 && root.is_selected(item.path);
                                dark: root.dark_mode;
                                zoom-level: root.icon_zoom_level;
                                show-location: root.recursive_search && root.search_query != "";
                                drop-target: root.main_drag_active && !root.main_drag_rejected && root.place_drag_target_path == item.path;
                                request_select(path, toggle, range) => {
                                    main-focus.focus();
                                    root.select_path(path, toggle, range);
                                }
                                request_context_menu(path, name, x, y) => {
                                    main-focus.focus();
                                    root.refresh_clipboard_availability();
                                    if (!root.is_selected(path)) {
                                        root.select_path(path, false, false);
                                    }
                                    root.context-menu-kind = 1;
                                    root.context-menu-path = path;
                                    root.context-menu-name = name;
                                    root.context-menu-properties-size = item.size;
                                    root.context-menu-properties-modified = item.modified;
                                    root.context-menu-is-dir = item.is_dir;
                                    if (!item.is_dir && root.selected_count <= 1) {
                                        root.open_with_path = path;
                                        root.default_open_app_name = "";
                                        root.prepare_open_with(path);
                                    }
                                    root.show-context-menu(1, x, y);
                                }
                                activated(path) => { root.open_path(path); }
                                zoom_in => {
                                    root.zoom-main-in();
                                }
                                zoom_out => {
                                    root.zoom-main-out();
                                }
                                pan_horizontal(delta) => {
                                    root.pan-main-horizontal(delta);
                                }
                            }
                        }

                        if (root.selection_rect_active): Rectangle {
                            x: min(root.selection_rect_start_x, root.selection_rect_current_x);
                            y: min(root.selection_rect_start_y, root.selection_rect_current_y);
                            width: max(1px, max(root.selection_rect_start_x, root.selection_rect_current_x) - min(root.selection_rect_start_x, root.selection_rect_current_x));
                            height: max(1px, max(root.selection_rect_start_y, root.selection_rect_current_y) - min(root.selection_rect_start_y, root.selection_rect_current_y));
                            background: root.dark_mode ? #38bdf833 : #0284c733;
                            border-width: 1px;
                            border-color: root.dark_mode ? #38bdf8 : #0284c7;
                        }
                    }

                    Rectangle {
                        height: 36px;
                        background: root.dark_mode ? #111416 : #ffffff;
                        border-color: root.dark_mode ? #454a50 : #d6dce2;
                        border-width: 1px;

                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 12px;
                            spacing: 8px;

                            Text {
                                horizontal-stretch: 1;
                                text: root.selected_count == 0 ? root.status : root.selected_status;
                                color: root.dark_mode ? #f1f1f1 : #334155;
                                font-size: 13px;
                                overflow: elide;
                                vertical-alignment: center;
                            }

                            if (root.external_edit_active): Text {
                                text: root.external_edit_status;
                                color: root.dark_mode ? #fbbf24 : #92400e;
                                font-size: 12px;
                                overflow: elide;
                                vertical-alignment: center;
                            }

                            if (root.external_edit_active): ToolButton {
                                label: "Save Back";
                                dark: root.dark_mode;
                                clicked => { root.commit_external_edit(); }
                            }

                            if (root.external_edit_active): ToolButton {
                                label: "Discard";
                                dark: root.dark_mode;
                                clicked => { root.discard_external_edit(); }
                            }

                            if (root.undo_available): ActionButton {
                                label: root.undo_label == "" ? "Undo" : root.undo_label;
                                dark: root.dark_mode;
                                clicked => { root.undo_last_operation(); }
                            }

                            if (root.chooser_mode && root.chooser_save_mode): LineEdit {
                                text <=> root.chooser_save_name;
                                height: 28px;
                                min-width: 220px;
                                placeholder-text: "File name";
                                accepted => { root.chooser_accept(self.text); }
                                changed has-focus => {
                                    root.chooser-save-input-focused = self.has-focus;
                                }
                            }

                            if (root.chooser_mode && root.chooser_filter_count > 0): ActionButton {
                                width: 150px;
                                label: root.chooser_filter_label == "" ? "Filter: All" : ("Filter: " + root.chooser_filter_label);
                                dark: root.dark_mode;
                                clicked => { root.chooser_next_filter(); }
                            }

                            for choice[index] in root.chooser_choices: ActionButton {
                                width: 180px;
                                label: choice.label + ": " + choice.selected_label;
                                dark: root.dark_mode;
                                clicked => {
                                    root.chooser-choice-menu-index = index;
                                    root.chooser-choice-menu-x = self.absolute-position.x;
                                    root.chooser-choice-menu-y = self.absolute-position.y;
                                    root.chooser-choice-menu-open = true;
                                }
                            }

                            if (root.chooser_mode): ActionButton {
                                label: root.chooser_accept_label != "" ? root.chooser_accept_label : (root.chooser_save_mode ? "Save" : "Choose");
                                dark: root.dark_mode;
                                enabled: root.chooser_save_mode ? root.chooser_save_name != "" : (root.chooser_select_directories || root.selected_path != "");
                                clicked => { root.chooser_accept(root.chooser_save_name); }
                            }
                        }
                    }
                }

                if (root.directory_loading && root.entry_count > 0): Rectangle {
                    width: parent.width;
                    height: parent.height - 36px;
                    background: root.dark_mode ? #10131444 : #ffffff66;

                    TouchArea {
                        width: parent.width;
                        height: parent.height;

                        pointer-event(event) => {
                            // Side-button navigation is handled once in the winit event layer,
                            // scoped to the whole main pane like cosmic-files' mouse area.
                        }
                    }

                    Rectangle {
                        x: 14px;
                        y: 12px;
                        width: 170px;
                        height: 30px;
                        border-radius: 6px;
                        background: root.dark_mode ? #25292dcc : #f8fafccc;
                        border-width: 1px;
                        border-color: root.dark_mode ? #454a50 : #d6dce2;

                        Text {
                            text: "Loading folder...";
                            x: 12px;
                            width: parent.width - 24px;
                            color: root.dark_mode ? #f1f1f1 : #334155;
                            font-size: 12px;
                            font-weight: 600;
                            overflow: elide;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
        }
    }

    if (root.place_drag_active && root.folder_drag_over_place_gap && root.place_drag_x < root.sidebar_width_px * 1px && root.place_drag_y >= root.place_list_y && root.place_drag_y <= root.place_list_y + root.places.length * 38px): Rectangle {
        x: 14px;
        y: root.place_list_y + root.place_drag_slot * 38px - 2px;
        width: max(120px, root.sidebar_width_px * 1px - 28px);
        height: 4px;
        border-radius: 2px;
        background: root.dark_mode ? #38bdf8 : #0284c7;
    }

    if ((root.folder_drag_active || root.place_drag_active) && root.place_drag_rejected && root.place_drag_x < root.sidebar_width_px * 1px && root.place_drag_y >= root.place_list_y && root.place_drag_y <= root.place_list_y + root.places.length * 38px): Rectangle {
        x: 14px;
        y: root.place_list_y + root.folder_drag_place_target * 38px + 2px;
        width: max(120px, root.sidebar_width_px * 1px - 28px);
        height: 30px;
        border-radius: 6px;
        background: root.dark_mode ? #3a1818 : #fee2e2;
        border-width: 1px;
        border-color: root.dark_mode ? #ef4444 : #dc2626;
    }

    if (root.place_drag_active): Rectangle {
        x: root.place_drag_x + 10px;
        y: root.place_drag_y + 10px;
        width: 180px;
        height: 34px;
        border-radius: 6px;
        background: root.dark_mode ? #2c3339 : #ffffff;
        border-width: 1px;
        border-color: root.dark_mode ? #5b6670 : #b8c7d4;

        HorizontalLayout {
            padding-left: 12px;
            padding-right: 10px;
            spacing: 10px;

            Rectangle {
                width: 24px;
                height: parent.height;
                background: transparent;

                Rectangle {
                    y: (parent.height - self.height) / 2;
                    width: 24px;
                    height: 22px;
                    border-radius: 3px;
                    background: root.dark_mode ? #4f93d9 : #4f94dc;

                    Text {
                        text: root.place_drag_marker;
                        color: #102033;
                        font-size: 11px;
                        font-weight: 800;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }

            Text {
                text: root.place_drag_label;
                color: root.dark_mode ? #f5f5f5 : #17212b;
                font-size: 14px;
                overflow: elide;
                vertical-alignment: center;
            }
        }
    }

    if (root.folder_drag_active): Rectangle {
        x: root.folder_drag_x + 10px;
        y: root.folder_drag_y + 10px;
        width: 180px;
        height: 34px;
        border-radius: 6px;
        background: root.dark_mode ? #2c3339 : #ffffff;
        border-width: 1px;
        border-color: root.dark_mode ? #5b6670 : #b8c7d4;

        Text {
            text: root.folder_drag_label;
            x: 12px;
            width: parent.width - 24px;
            color: root.dark_mode ? #f5f5f5 : #17212b;
            font-size: 13px;
            overflow: elide;
            vertical-alignment: center;
        }
    }

    if (root.main_drag_active && root.main_drag_rejected): Rectangle {
        x: root.sidebar_width_px * 1px + 20px;
        y: 84px;
        width: 250px;
        height: 32px;
        border-radius: 6px;
        background: root.dark_mode ? #3a1818 : #fee2e2;
        border-width: 1px;
        border-color: root.dark_mode ? #ef4444 : #dc2626;

        Text {
            text: "Cannot drop item here";
            x: 12px;
            width: parent.width - 24px;
            color: root.dark_mode ? #fecaca : #991b1b;
            font-size: 12px;
            font-weight: 700;
            overflow: elide;
            vertical-alignment: center;
        }
    }

    if (root.folder_drag_active && root.folder_drag_over_place_gap && root.folder_drag_x < root.sidebar_width_px * 1px && root.folder_drag_y >= root.place_list_y && root.folder_drag_y <= root.place_list_y + root.places.length * 38px): Rectangle {
        x: 14px;
        y: root.place_list_y + root.folder_drag_slot * 38px - 2px;
        width: max(120px, root.sidebar_width_px * 1px - 28px);
        height: 4px;
        border-radius: 2px;
        background: root.dark_mode ? #38bdf8 : #0284c7;
    }

    if (root.context-menu-open || root.rename-place-open || root.transfer-menu-open || root.transfer_conflict_open || root.open-with-menu-open || root.create-new-menu-open || root.chooser-choice-menu-open || root.custom-open-with-open || root.new-folder-open || root.rename-entry-open || root.properties-open || root.privileged_prompt_open): MenuDismissLayer {
        width: parent.width;
        height: parent.height;
        dismissed => {
            root.close-context-popups();
            root.rename-place-open = false;
            root.transfer-menu-open = false;
            if (root.transfer_conflict_open) {
                root.transfer_conflict_choice("skip");
            }
            root.chooser-choice-menu-open = false;
            root.custom-open-with-open = false;
            root.new-folder-open = false;
            root.rename-entry-open = false;
            root.properties-open = false;
            if (root.privileged_prompt_open) {
                root.privileged_prompt_dismiss();
            }
        }
    }

    if (root.context-menu-open && root.context-menu-kind == 1): FileContextMenu {
        x: root.context-menu-left;
        y: root.context-menu-top;
        width: root.context-file-menu-width;
        height: root.active-context-menu-height;
        dark: root.dark_mode;
        selected-count: root.selected_count;
        selected-status: root.selected_status;
        is-dir: root.context-menu-is-dir;
        default-open-visible: root.context-default-open-visible;
        default-open-app-name: root.default_open_app_name;
        clipboard-has-paths: root.clipboard_has_paths;
        add-to-places-visible: root.context-add-place-visible;
        open_folder_with_hover(is-hovered) => {
            root.open-with-submenu-hover(root.context-menu-path, root.context-menu-top, is-hovered);
        }
        open_folder_with_clicked => {
            root.show-open-with-submenu(root.context-menu-path, root.context-menu-top);
        }
        default_open_requested => {
            root.open_path(root.context-menu-path);
            root.close-context-popups();
        }
        open_with_hover(is-hovered) => {
            root.open-with-submenu-hover(root.context-menu-path, root.context-menu-top + root.context-open-with-row-offset, is-hovered);
        }
        open_with_clicked => {
            root.show-open-with-submenu(root.context-menu-path, root.context-menu-top + root.context-open-with-row-offset);
        }
        paste_into_folder => {
            root.paste_into(root.context-menu-path);
            root.close-context-popups();
        }
        add_to_places => {
            root.add_place(root.context-menu-path);
            root.close-context-popups();
        }
        rename_requested => {
            root.rename-entry-path = root.context-menu-path;
            root.rename-entry-name = root.context-menu-name;
            root.rename-entry-open = true;
            root.close-context-popups();
        }
        duplicate_requested => {
            root.duplicate_path(root.context-menu-path);
            root.close-context-popups();
        }
        cut_requested => {
            root.copy_paths(root.context-menu-path, true);
            root.close-context-popups();
        }
        copy_requested => {
            root.copy_paths(root.context-menu-path, false);
            root.close-context-popups();
        }
        copy_location_requested => {
            root.copy_location(root.context-menu-path);
            root.close-context-popups();
        }
        properties_requested => {
            root.properties-name = root.context-menu-name;
            root.properties-path = root.context-menu-path;
            root.properties-kind = root.context-menu-is-dir ? "Folder" : "File";
            root.properties-size = root.context-menu-properties-size;
            root.properties-modified = root.context-menu-properties-modified;
            root.properties-open = true;
            root.close-context-popups();
        }
        trash_requested => {
            if (root.selected_count > 1) {
                root.trash_selected();
            } else {
                root.trash_path(root.context-menu-path);
            }
            root.close-context-popups();
        }
    }

    if (root.context-menu-open && root.context-menu-kind == 2): PlaceContextMenu {
        x: root.context-menu-left;
        y: root.context-menu-top;
        width: root.context-place-menu-width;
        height: root.active-context-menu-height;
        title: root.rename-place-label;
        dark: root.dark_mode;
        builtin: root.context-menu-place-builtin;
        open_new_window => {
            root.open_place_new_window(root.context-menu-place-index);
            root.close-context-popups();
        }
        rename_requested => {
            root.rename-place-index = root.context-menu-place-index;
            root.rename-place-open = true;
            root.close-context-popups();
        }
        remove_requested => {
            root.remove_place(root.context-menu-place-index);
            root.close-context-popups();
        }
    }

    if (root.context-menu-open && root.context-menu-kind == 5): DeviceContextMenu {
        x: root.context-menu-left;
        y: root.context-menu-top;
        width: root.context-place-menu-width;
        height: root.active-context-menu-height;
        title: root.rename-place-label;
        dark: root.dark_mode;
        mounted: root.context-menu-device-mounted;
        can-eject: root.context-menu-device-can-eject;
        pending-action: root.context-menu-device-pending-action;
        open_requested => {
            root.open_device(root.context-menu-device-open-path, true);
            root.close-context-popups();
        }
        mount_requested => {
            root.open_device(root.context-menu-device-path, false);
            root.close-context-popups();
        }
        unmount_requested => {
            root.unmount_device(root.context-menu-device-path, root.context-menu-device-open-path);
            root.close-context-popups();
        }
        eject_requested => {
            root.eject_device(root.context-menu-device-path, root.context-menu-device-open-path);
            root.close-context-popups();
        }
    }

    if (root.context-menu-open && root.context-menu-kind == 4): PlacesBlankMenu {
        x: root.context-menu-left;
        y: root.context-menu-top;
        width: root.context-blank-menu-width;
        height: root.active-context-menu-height;
        dark: root.dark_mode;
        add-current-visible: root.context-add-place-visible;
        add_current_folder => {
            root.add_place(root.current_path);
            root.close-context-popups();
        }
        restore_defaults => {
            root.restore_default_places();
            root.close-context-popups();
        }
    }

    if (root.context-menu-open && root.context-menu-kind == 3): ViewportContextMenu {
        x: root.context-menu-left;
        y: root.context-menu-top;
        width: root.context-blank-menu-width;
        height: root.active-context-menu-height;
        dark: root.dark_mode;
        clipboard-has-paths: root.clipboard_has_paths;
        clipboard-cut: root.clipboard_cut;
        create_new_hover(is-hovered) => {
            root.create-new-submenu-hover(root.context-menu-top, is-hovered);
        }
        create_new_clicked => {
            root.show-create-new-submenu(root.context-menu-top);
        }
        paste_requested => {
            root.paste_into(root.current_path);
            root.close-context-popups();
        }
        open_folder_with_hover(is-hovered) => {
            root.open-with-submenu-hover(root.current_path, root.context-menu-top + root.context-open-with-row-offset, is-hovered);
        }
        open_folder_with_clicked => {
            root.show-open-with-submenu(root.current_path, root.context-menu-top + root.context-open-with-row-offset);
        }
        open_terminal_here => {
            root.open_terminal_here();
            root.close-context-popups();
        }
    }

    if (root.create-new-menu-open && root.context-menu-open): MenuHoverBridge {
        x: root.active-child-bridge-left;
        y: root.active-child-bridge-top;
        width: root.active-child-bridge-width;
        height: root.active-child-bridge-height;
        hovered(is-hovered) => {
            root.set-child-submenu-hover(2, is-hovered);
        }
    }

    if (root.create-new-menu-open): CreateNewMenu {
        x: root.active-child-menu-left;
        y: root.active-child-menu-top;
        width: root.create-new-menu-width;
        height: root.create-new-menu-height;
        dark: root.dark_mode;
        keep_alive(is-hovered) => {
            root.set-child-submenu-hover(2, is-hovered);
        }
        folder_selected => {
            root.new-folder-name = "New Folder";
            root.new-folder-open = true;
            root.close-context-popups();
        }
    }

    if (root.rename-place-open): Rectangle {
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;
        width: 360px;
        height: 132px;
        background: transparent;

        TextInputDialog {
            width: parent.width;
            height: parent.height;
            dark: root.dark_mode;
            title: "Rename Place";
            accept-label: "Rename";
            value <=> root.rename-place-label;
            accepted(value) => {
                root.rename_place(root.rename-place-index, value);
                root.rename-place-open = false;
            }
            cancelled => { root.rename-place-open = false; }
        }
    }

    if (root.new-folder-open): Rectangle {
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;
        width: 360px;
        height: 132px;
        background: transparent;

        TextInputDialog {
            width: parent.width;
            height: parent.height;
            dark: root.dark_mode;
            title: "New Folder";
            accept-label: "Create";
            value <=> root.new-folder-name;
            accepted(value) => {
                root.create_folder(value);
                root.new-folder-open = false;
            }
            cancelled => { root.new-folder-open = false; }
        }
    }

    if (root.rename-entry-open): Rectangle {
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;
        width: 380px;
        height: 132px;
        background: transparent;

        TextInputDialog {
            width: parent.width;
            height: parent.height;
            dark: root.dark_mode;
            title: "Rename";
            accept-label: "Rename";
            value <=> root.rename-entry-name;
            accepted(value) => {
                root.rename_path(root.rename-entry-path, value);
                root.rename-entry-open = false;
            }
            cancelled => { root.rename-entry-open = false; }
        }
    }

    if (root.properties-open): Rectangle {
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;
        width: 440px;
        height: 260px;
        background: transparent;

        PropertiesDialog {
            width: parent.width;
            height: parent.height;
            dark: root.dark_mode;
            name: root.properties-name;
            kind: root.properties-kind;
            size: root.properties-size;
            modified: root.properties-modified;
            path: root.properties-path;
            closed => { root.properties-open = false; }
        }
    }

    if (root.privileged_prompt_open): Rectangle {
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;
        width: 430px;
        height: 190px;
        background: transparent;

        PrivilegedPromptDialog {
            width: parent.width;
            height: parent.height;
            dark: root.dark_mode;
            title: root.privileged_prompt_title;
            message: root.privileged_prompt_message;
            detail: root.privileged_prompt_detail;
            cancelled => { root.privileged_prompt_dismiss(); }
            accepted => { root.privileged_prompt_accept(); }
        }
    }

    if (root.transfer_conflict_open): Rectangle {
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;
        width: 480px;
        height: 310px;
        background: transparent;

        TransferConflictDialog {
            width: parent.width;
            height: parent.height;
            dark: root.dark_mode;
            source: root.transfer_conflict_source;
            target: root.transfer_conflict_target;
            rename-name <=> root.transfer_conflict_rename_name;
            apply-all <=> root.transfer-conflict-apply-all;
            choice(decision) => { root.transfer_conflict_choice(decision); }
        }
    }

    if (root.transfer-menu-open): TransferMenu {
        x: root.transfer-menu-left;
        y: root.transfer-menu-top;
        width: root.transfer-menu-width;
        height: root.transfer-menu-height;
        title: root.transfer_source_label + " -> " + root.transfer_target_label;
        dark: root.dark_mode;
        operation_selected(operation) => {
            root.transfer_operation(operation, root.transfer_source_path, root.transfer_target_path);
            root.transfer-menu-open = false;
        }
        cancelled => {
            root.transfer-menu-open = false;
        }
    }

    if (root.open-with-menu-open && root.context-menu-open): MenuHoverBridge {
        x: root.active-child-bridge-left;
        y: root.active-child-bridge-top;
        width: root.active-child-bridge-width;
        height: root.active-child-bridge-height;
        hovered(is-hovered) => {
            root.set-child-submenu-hover(1, is-hovered);
        }
    }

    if (root.open-with-menu-open): OpenWithMenu {
        x: root.active-child-menu-left;
        y: root.active-child-menu-top;
        width: root.open-with-menu-width;
        height: root.open-with-menu-height;
        title: root.open_with_mime == "" ? "Open With" : "Open With - " + root.open_with_mime;
        dark: root.dark_mode;
        apps: root.open_with_apps;
        item-height: root.menu-item-height;
        keep_alive(is-hovered) => {
            root.set-child-submenu-hover(1, is-hovered);
        }
        app_selected(app-id) => {
            root.open_with_app(root.open_with_path, app-id);
            root.close-context-popups();
        }
        other_applications => {
            root.prepare_other_applications(root.open_with_path);
            root.custom_open_command = "";
            root.other_application_filter = "";
            root.other_application_set_default = false;
            root.custom-open-with-open = true;
            root.close-context-popups();
        }
    }

    for choice[index] in root.chooser_choices: ChooserChoicePopup {
        visible: root.chooser-choice-menu-open && root.chooser-choice-menu-index == index;
        x: root.anchored_menu_left(root.width / 1px, root.height / 1px, root.chooser-choice-menu-x / 1px, root.chooser-choice-menu-y / 1px, root.chooser-choice-menu-width / 1px, (root.menu-title-height + max(1, choice.options.length) * root.menu-item-height) / 1px, root.menu-screen-margin / 1px, root.menu-pointer-gap / 1px, root.child-menu-gap / 1px) * 1px;
        y: root.anchored_menu_top(root.width / 1px, root.height / 1px, root.chooser-choice-menu-x / 1px, root.chooser-choice-menu-y / 1px, root.chooser-choice-menu-width / 1px, (root.menu-title-height + max(1, choice.options.length) * root.menu-item-height) / 1px, root.menu-screen-margin / 1px, root.menu-pointer-gap / 1px, root.child-menu-gap / 1px) * 1px;
        width: root.chooser-choice-menu-width;
        dark: root.dark_mode;
        title: choice.label;
        options: choice.options;
        selected-index: choice.selected_index;
        title-height: root.menu-title-height;
        item-height: root.menu-item-height;
        option_selected(option-index) => {
            root.chooser_select_choice(index, option-index);
            root.chooser-choice-menu-open = false;
        }
    }

    if (root.custom-open-with-open): Rectangle {
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;
        width: 460px;
        height: 460px;
        background: transparent;

        OtherApplicationsDialog {
            width: parent.width;
            height: parent.height;
            dark: root.dark_mode;
            apps: root.other_application_apps;
            filter <=> root.other_application_filter;
            custom-command <=> root.custom_open_command;
            set-default <=> root.other_application_set_default;
            filter_changed(query) => { root.filter_other_applications(query); }
            app_selected(app-id, set-default) => {
                if (set-default) {
                    root.set_default_app(root.open_with_path, app-id);
                }
                root.open_with_app(root.open_with_path, app-id);
                root.custom-open-with-open = false;
            }
            custom_open(command) => {
                root.open_with_custom_command(root.open_with_path, command);
                root.custom-open-with-open = false;
            }
            cancelled => { root.custom-open-with-open = false; }
        }
    }
}
