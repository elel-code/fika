    in-out property <int> icon_zoom_level: 2;
    in-out property <float> sidebar_width_px: 280;
    in-out property <float> places_list_y_px: 108;
    in-out property <float> places_row_stride_px: 38;
    in-out property <bool> directory_loading: false;
    private property <length> shell-header-height: 56px;
    private property <length> path-bar-height: 56px;
    private property <length> status-bar-height: 36px;
    private property <length> sidebar-resize-hit-width: 8px;
    private property <string> sidebar-selected-path: root.focused_pane_path;
    private property <length> main-content-left: root.sidebar_width_px * 1px;
    private property <bool> search-filters-active: root.search_kind_filter != 0 || root.search_modified_filter != 0 || root.search_size_filter != 0;
    private property <bool> search-panel-visible: root.search_bar_open || root.search_query != "" || root.search-filters-active;
    private property <length> search-panel-height: root.search-panel-visible ? (root.pane-slot-0-width < 760px ? 78px : 44px) : 0px;
    private property <string> search-kind-filter-label: root.search_kind_filter == 1 ? "Type: Folders" : (root.search_kind_filter == 2 ? "Type: Files" : (root.search_kind_filter == 3 ? "Type: Images" : "Type: All"));
    private property <string> search-modified-filter-label: root.search_modified_filter == 1 ? "Modified: Today" : (root.search_modified_filter == 2 ? "Modified: 7 days" : (root.search_modified_filter == 3 ? "Modified: 30 days" : "Modified: Any"));
    private property <string> search-size-filter-label: root.search_size_filter == 1 ? "Size: < 1 MB" : (root.search_size_filter == 2 ? "Size: 1-100 MB" : (root.search_size_filter == 3 ? "Size: > 100 MB" : "Size: Any"));
    private property <length> main-pane-width: max(1px, root.width - root.main-content-left);
    private property <length> split-divider-width: root.split_view_open ? 1px : 0px;
    private property <length> split-resize-hit-width: 15px;
    private property <length> split-content-width: max(1px, root.main-pane-width - root.split-divider-width);
    private property <length> split-pane-min-width: min(260px, max(1px, root.split-content-width / 2));
    private property <length> split-ratio-pane-width: max(1px, floor((root.split-content-width * root.split_pane_ratio) / 1px) * 1px);
    private property <length> pane-slot-0-width: root.split_view_open ? max(root.split-pane-min-width, min(root.split-content-width - root.split-pane-min-width, root.split-ratio-pane-width)) : root.main-pane-width;
    private property <length> pane-slot-1-x: root.pane-slot-0-width + root.split-divider-width;
    private property <length> pane-slot-1-width: root.split_view_open ? max(1px, root.main-pane-width - root.pane-slot-1-x) : 0px;
    private property <int> visible-pane-count: max(1, root.pane_slots.length);
    private property <length> main-content-height: max(1px, root.height - root.shell-header-height);
    private property <color> shell-base-color: root.dark_mode ? #101418 : #f6f8fa;
    private property <color> sidebar-surface-color: root.dark_mode ? #181e24 : #ffffff;
    private property <color> sidebar-border-color: root.dark_mode ? #313a43 : #d8e1ea;
    private property <color> shell-separator-color: root.dark_mode ? #242b33 : #e5eaf0;
    private property <length> sidebar-panel-radius: 16px;
    private property <length> sidebar-bottom-gap: 22px;
    private property <length> sidebar-content-bottom-padding: 28px;
    private property <length> sidebar-content-height: 10px + 30px + root.places.length * 38px + 30px + 30px + root.devices.length * 38px + (root.places.length + root.devices.length + 2) * 4px + root.sidebar-content-bottom-padding;
    private property <float> sidebar-resize-start-width-px: 280;
    private property <length> sidebar-resize-press-x: 0px;
    private property <float> split-resize-start-ratio: 0.5;
    private property <length> split-resize-press-x: 0px;
    private property <bool> split-resize-active: false;
    private property <bool> context-menu-open: false;
    private property <int> context-menu-kind: 0;
    private property <string> context-menu-path;
    private property <string> context-menu-name;
    private property <string> context-menu-properties-size;
    private property <string> context-menu-properties-modified;
    private property <bool> context-menu-is-dir: false;
    private property <int> context-menu-place-index: -1;
    private property <bool> context-menu-place-builtin: false;
    private property <string> context-menu-device-path;
    private property <string> context-menu-device-open-path;
    private property <bool> context-menu-device-mounted: false;
