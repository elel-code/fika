    private property <bool> search-filters-active: root.search_kind_filter != 0 || root.search_modified_filter != 0 || root.search_size_filter != 0;
    private property <bool> search-panel-visible: root.search_bar_open || root.search_query != "" || root.search-filters-active;
    private property <length> search-panel-height: root.search-panel-visible ? 92px : 0px;
    private property <string> search-kind-filter-label: root.search_kind_filter == 1 ? "Type: Folders" : (root.search_kind_filter == 2 ? "Type: Files" : (root.search_kind_filter == 3 ? "Type: Images" : "Type: All"));
    private property <string> search-modified-filter-label: root.search_modified_filter == 1 ? "Modified: Today" : (root.search_modified_filter == 2 ? "Modified: 7 days" : (root.search_modified_filter == 3 ? "Modified: 30 days" : "Modified: Any"));
    private property <string> search-size-filter-label: root.search_size_filter == 1 ? "Size: < 1 MB" : (root.search_size_filter == 2 ? "Size: 1-100 MB" : (root.search_size_filter == 3 ? "Size: > 100 MB" : "Size: Any"));
    private property <length> main-pane-width: max(1px, root.width - root.sidebar_width_px * 1px - 8px);
    private property <length> main-available-grid-height: max(root.icon-row-height, root.height - 64px - 36px - root.search-panel-height - 2 * root.icon-grid-padding);
    private property <int> main-rows-per-column: max(1, floor(root.main-available-grid-height / root.icon-row-height));
    private property <int> main-column-count: max(1, ceil(root.entry_count / root.main-rows-per-column));
    private property <length> main-viewport-width: 2 * root.icon-grid-padding + root.main-column-count * root.icon-cell-width;
    private property <float> main-scroll-max-x: max(0, (root.main-viewport-width - root.main-pane-width) / 1px);

    private property <length> icon-cell-width: root.icon_zoom_level == 0 ? 172px : (root.icon_zoom_level == 1 ? 208px : (root.icon_zoom_level == 2 ? 248px : (root.icon_zoom_level == 3 ? 292px : 340px)));
    private property <length> icon-row-height: root.icon_zoom_level == 0 ? 78px : (root.icon_zoom_level == 1 ? 90px : (root.icon_zoom_level == 2 ? 104px : (root.icon_zoom_level == 3 ? 124px : 146px)));
    private property <length> icon-grid-padding: 14px;
