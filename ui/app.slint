    callback prepare_entry_transfer(string, int, float, float) -> bool;
    callback prepare_current_dir_transfer(string, string, float, float) -> bool;
    callback pane_prepare_transfer(int, string, float, float) -> bool;
    callback pane_drop_target_path(int, float, float, string) -> string;
    callback pane_drop_allowed(int, float, float, string) -> bool;
    callback pane_view_changed(int);
    callback pane_layout_changed();
