    function close-child-submenus() {
        menu-lifecycle.close-child-submenus();
    }

    function set-child-submenu-hover(menu: int, is-hovered: bool) {
        menu-lifecycle.set-child-submenu-hover(menu, is-hovered);
    }

    function show-open-with-submenu(path: string, row-y: length) {
        root.open_with_path = path;
        menu-lifecycle.show-open-with-submenu(path, row-y);
    }

    function show-create-new-submenu(row-y: length) {
        menu-lifecycle.show-create-new-submenu(row-y);
    }

    function open-with-submenu-hover(path: string, row-y: length, is-hovered: bool) {
        if (is-hovered) { root.open_with_path = path; }
        menu-lifecycle.open-with-submenu-hover(path, row-y, is-hovered);
    }

    function create-new-submenu-hover(row-y: length, is-hovered: bool) {
        menu-lifecycle.create-new-submenu-hover(row-y, is-hovered);
    }

    function close-context-popups() {
        root.context-menu-open = false;
        root.close-child-submenus();
    }

    function close-chooser-popups() {
        root.chooser-choice-menu-open = false;
        root.chooser-filter-menu-open = false;
    }

    function dismiss-transient-popups() {
        root.close-context-popups();
        root.rename-place-open = false;
        root.transfer-menu-open = false;
        if (root.transfer_conflict_open) {
            root.transfer_conflict_choice("skip");
        }
        root.close-chooser-popups();
        root.custom-open-with-open = false;
        root.new-folder-open = false;
        root.new-file-open = false;
        root.rename-entry-open = false;
        root.properties-open = false;
        if (root.privileged_prompt_open) {
            root.privileged_prompt_dismiss();
        }
        root.trash-confirm-open = false;
    }

    function confirm-permanent-delete(path: string, selected: bool) {
        root.close-context-popups();
        root.trash-confirm-action = selected ? "delete-selected" : "delete-path";
        root.trash-confirm-path = path;
        root.trash-confirm-title = selected ? "Delete Selected Permanently?" : "Delete Permanently?";
        root.trash-confirm-message = selected ? "Delete the selected Trash items permanently?" : "Delete this Trash item permanently?";
        root.trash-confirm-detail = selected ? (root.selected_status + "\nThis cannot be undone.") : (path + "\nThis cannot be undone.");
        root.trash-confirm-accept-label = "Delete";
        root.trash-confirm-open = true;
    }

    function confirm-empty-trash() {
        root.close-context-popups();
        root.trash-confirm-action = "empty-trash";
        root.trash-confirm-path = "";
        root.trash-confirm-title = "Empty Trash?";
        root.trash-confirm-message = "Delete all items in Trash permanently?";
        root.trash-confirm-detail = "This cannot be undone.";
        root.trash-confirm-accept-label = "Empty Trash";
        root.trash-confirm-open = true;
    }

    function accept-trash-confirmation() {
        root.trash-confirm-open = false;
        if (root.trash-confirm-action == "delete-selected") {
            root.delete_permanently_selected();
        } else if (root.trash-confirm-action == "delete-path") {
            root.delete_permanently_path(root.trash-confirm-path);
        } else if (root.trash-confirm-action == "empty-trash") {
            root.empty_trash();
        }
        root.trash-confirm-action = "";
        root.trash-confirm-path = "";
    }

    function show-context-menu(kind: int, x: length, y: length) {
        root.context-menu-kind = kind;
        root.context-menu-x = x;
        root.context-menu-y = y;
        root.close-chooser-popups();
        root.close-child-submenus();
        root.context-menu-open = true;
    }

    function sync-main-viewport() {
        root.main_viewport_x = root.entry_count == 0 ? 0 : max(0, root.main_viewport_x);
        root.main_viewport_offset = -root.main_viewport_x * 1px;
    }

    function zoom-main-in() {
        root.icon_zoom_level = min(4, root.icon_zoom_level + 1);
        root.sync-main-viewport();
        root.persist_ui_state();
    }

    function zoom-main-out() {
        root.icon_zoom_level = max(0, root.icon_zoom_level - 1);
        root.sync-main-viewport();
        root.persist_ui_state();
    }

    function pane-focus(side: int) {
        main-focus.focus();
        if (side == 1) {
            root.focus_right_pane();
        } else {
            root.focus_left_pane();
        }
    }

    function pane-path-submitted(side: int, path: string) {
        if (side == 1) {
            root.inactive_path_submitted(path);
        } else {
            root.left_pane_path_submitted(path);
        }
    }

    function pane-go-back(side: int) {
        if (side == 1) {
            root.inactive_go_back();
        } else {
            root.left_pane_go_back();
        }
    }

    function pane-go-forward(side: int) {
        if (side == 1) {
            root.inactive_go_forward();
        } else {
            root.left_pane_go_forward();
        }
    }

    function pane-view-changed(side: int) {
        if (side == 1) {
            root.inactive_pane_view_changed();
        } else {
            root.main_view_changed();
        }
    }

    function pane-activated(side: int, path: string) {
        if (side == 1) {
            root.open_inactive_path(path);
        } else {
            root.open_path(path);
        }
    }

    function pane-request-select(side: int, path: string, toggle: bool, range: bool) {
        if (side == 1) {
            root.select_inactive_path(path, toggle, range);
        } else {
            root.select_path(path, toggle, range);
        }
    }

    function pane-select-rect(side: int, x1: float, y1: float, x2: float, y2: float, rows-per-column: int, cell-width: float, row-height: float, padding: float, toggle: bool) {
        if (side == 1) {
            root.select_inactive_rect(x1, y1, x2, y2, rows-per-column, cell-width, row-height, padding, toggle);
        } else {
            root.select_rect(x1, y1, x2, y2, rows-per-column, cell-width, row-height, padding, toggle);
        }
    }

    function pane-clear-selection(side: int) {
        root.pane-focus(side);
        root.clear_selection();
    }

    function pane-request-context-menu(side: int, path: string, name: string, size: string, modified: string, is-dir: bool, x: length, y: length) {
        root.pane-focus(side);
        root.refresh_clipboard_availability();
        if (side == 1 && !root.is_inactive_selected(path)) {
            root.select_inactive_path(path, false, false);
        } else if (side != 1 && !root.is_selected(path)) {
            root.select_path(path, false, false);
        }
        root.context-menu-kind = 1;
        root.context-menu-path = path;
        root.context-menu-name = name;
        root.context-menu-properties-size = size;
        root.context-menu-properties-modified = modified;
        root.context-menu-is-dir = is-dir;
        if (!is-dir && root.selected_count <= 1) {
            root.open_with_path = path;
            root.default_open_app_name = "";
            root.prepare_open_with(path);
        }
        root.show-context-menu(1, x, y);
    }

    function pane-request-blank-context-menu(side: int, x: length, y: length) {
        root.pane-clear-selection(side);
        root.refresh_clipboard_availability();
        root.show-context-menu(3, x, y);
    }

    function pane-zoom-in(side: int) {
        root.pane-focus(side);
        root.zoom-main-in();
    }

    function pane-zoom-out(side: int) {
        root.pane-focus(side);
        root.zoom-main-out();
    }

    function pane-drop-target-path(side: int, x: float, y: float, source: string) -> string {
        return side == 1 ? root.inactive_pane_drop_target_path(x, y, source) : root.main_drop_target_path(x, y, source);
    }

    function pane-drop-allowed(side: int, x: float, y: float, source: string) -> bool {
        return side == 1 ? root.inactive_pane_drop_allowed(x, y, source) : root.main_drop_allowed(x, y, source);
    }

    function pane-prepare-transfer(side: int, source: string, x: float, y: float) -> bool {
        return side == 1 ? root.prepare_inactive_pane_transfer(source, x, y) : root.prepare_path_main_transfer(source, x, y);
    }

    function pane-transfer-menu-requested(side: int) {
        root.pane-focus(side);
        root.transfer-menu-open = true;
    }

    function pane-save-focus-changed(side: int, focused: bool) {
        root.chooser-save-input-focused = focused;
        if (focused) {
            root.pane-focus(side);
        }
    }

    function pane-chooser-filter-requested(side: int, x: length, y: length) {
        root.pane-focus(side);
        root.chooser-choice-menu-open = false;
        root.chooser-filter-menu-x = x;
        root.chooser-filter-menu-y = y;
        root.chooser-filter-menu-open = true;
    }

    function pane-chooser-choice-requested(side: int, index: int, x: length, y: length) {
        root.pane-focus(side);
        root.chooser-filter-menu-open = false;
        root.chooser-choice-menu-index = index;
        root.chooser-choice-menu-x = x;
        root.chooser-choice-menu-y = y;
        root.chooser-choice-menu-open = true;
    }

    title: chooser_mode ? (chooser_title == "" ? "Fika File Chooser" : chooser_title) : "Fika File Manager";
    preferred-width: 1100px;
    preferred-height: 760px;
    min-width: 780px;
    min-height: 460px;
    background: root.shell-base-color;

    changed width => {
        root.main_view_changed();
        root.inactive_pane_view_changed();
    }
    changed height => {
        root.main_view_changed();
        root.inactive_pane_view_changed();
    }
    changed sidebar_width_px => {
        root.sync-main-viewport();
        root.main_view_changed();
        root.inactive_pane_view_changed();
    }
    changed search-panel-height => {
        root.sync-main-viewport();
        root.main_view_changed();
    }
    changed active-pane-width => {
        root.sync-main-viewport();
        root.main_view_changed();
        root.inactive_pane_view_changed();
    }
    changed split_pane_ratio => {
        root.sync-main-viewport();
        root.main_view_changed();
        root.inactive_pane_view_changed();
    }
    changed split_view_open => {
        if (!root.split_view_open) {
            root.split-resize-active = false;
        }
    }
    changed main_viewport_x => { root.main_view_changed(); }
    changed icon_zoom_level => {
        root.main_view_changed();
        root.inactive_pane_view_changed();
    }
    changed transfer_conflict_open => {
        if (root.transfer_conflict_open) {
            root.transfer-conflict-apply-all = false;
        }
    }

    app-focus := FocusScope {
        width: 0px;
        height: 0px;

        menu-lifecycle := MenuLifecycleController {
            prepare_open_with(path) => { root.prepare_open_with(path); }
        }

        KeyBinding {
            keys: @keys(F5);
            activated => { root.refresh(); }
        }

        KeyBinding {
            keys: @keys(Control + A);
            activated => {
                if (!root.file-operation-shortcuts-blocked) {
                    root.select_all_visible();
                }
            }
        }

        KeyBinding {
            keys: @keys(Control + F);
            activated => { root.search_bar_open = true; }
        }

        KeyBinding {
            keys: @keys(Control + C);
            activated => {
                if (!root.file-operation-shortcuts-blocked && root.selected_count > 0) {
                    root.copy_paths(root.selected_path, false);
                }
            }
        }

        KeyBinding {
            keys: @keys(Control + X);
            activated => {
                if (!root.file-operation-shortcuts-blocked && root.selected_count > 0) {
                    root.copy_paths(root.selected_path, true);
                }
            }
        }

        KeyBinding {
            keys: @keys(Control + V);
            activated => {
                if (!root.file-operation-shortcuts-blocked) {
                    root.refresh_clipboard_availability();
                    root.paste_into(root.current_path);
                }
            }
        }

        KeyBinding {
            keys: @keys(Control + Z);
            activated => {
                if (!root.file-operation-shortcuts-blocked && root.undo_available) {
                    root.undo_last_operation();
                }
            }
        }

        KeyBinding {
            keys: @keys(Delete);
            activated => {
                if (!root.file-operation-shortcuts-blocked && root.selected_count > 0 && !root.current_in_trash) {
                    if (root.selected_count > 1) {
                        root.trash_selected();
                    } else {
                        root.trash_path(root.selected_path);
                    }
                }
            }
        }

        KeyBinding {
            keys: @keys(Escape);
            activated => {
                if (root.context-menu-open || MenuLifecycle.open-with-open || MenuLifecycle.create-new-open) {
                    root.close-context-popups();
                } else if (root.chooser-choice-menu-open || root.chooser-filter-menu-open) {
                    root.close-chooser-popups();
                } else if (root.rename-place-open) {
                    root.rename-place-open = false;
                } else if (root.privileged_prompt_open) {
                    root.privileged_prompt_dismiss();
                } else if (root.trash-confirm-open) {
                    root.trash-confirm-open = false;
                } else if (root.search_bar_open || root.search_query != "" || root.search-filters-active) {
                    root.search_query = "";
                    root.search_kind_filter = 0;
                    root.search_modified_filter = 0;
                    root.search_size_filter = 0;
                    root.search_filters_changed(root.search_kind_filter, root.search_modified_filter, root.search_size_filter);
                    root.search_submitted("");
                    root.search_bar_open = false;
                } else {
                    root.clear_selection();
                }
            }
        }
    }

    shell-layout := Rectangle {
        width: root.width;
        height: root.height;
        background: root.shell-base-color;

        VerticalLayout {
            width: parent.width;
            height: parent.height;
            padding: 0px;
            spacing: 0px;

            shell-header := Rectangle {
                height: root.shell-header-height;
                background: root.shell-base-color;

                TopBar {
                    width: parent.width;
                    height: root.shell-header-height;
                    dark: root.dark_mode;
                    search-active: root.search-panel-visible;
                    split-view-open: root.split_view_open;
                    search-query <=> root.search_query;
                    search-focused <=> root.search-input-focused;
                    search_requested => { root.search_bar_open = true; }
                    search_submitted(query) => {
                        root.search_bar_open = true;
                        root.search_submitted(query);
                    }
                    search_close_requested => {
                        root.search_query = "";
                        root.search_kind_filter = 0;
                        root.search_modified_filter = 0;
                        root.search_size_filter = 0;
                        root.search_filters_changed(root.search_kind_filter, root.search_modified_filter, root.search_size_filter);
                        root.search_submitted("");
                        root.search_bar_open = false;
                    }
                    toggle_split_view => { root.toggle_split_view(); }
                    dark_toggled => {
                        root.dark_mode = !root.dark_mode;
                        root.persist_ui_state();
                    }
                }
            }

            content-row := HorizontalLayout {
                vertical-stretch: 1;
                spacing: 0px;

            sidebar-column := Rectangle {
                width: root.main-content-left;
                background: transparent;

                    sidebar-surface := Rectangle {
                        width: parent.width;
                        height: max(1px, parent.height - root.sidebar-bottom-gap);
                        border-radius: root.sidebar-panel-radius;
                        background: root.sidebar-surface-color;
                        border-color: root.sidebar-border-color;
                        border-width: 1px;

                TouchArea {
                    width: parent.width;
                    height: parent.height;
                    pointer-event(event) => {
                        if (event.button == PointerEventButton.right && event.kind == PointerEventKind.down) {
                            root.context-menu-place-index = -1;
                            root.context-menu-place-builtin = false;
                            root.rename-place-label = "Places";
                            root.show-context-menu(4, self.absolute-position.x + self.mouse-x, self.absolute-position.y + self.mouse-y);
                        }
                    }
                }

                sidebar-scroll := ScrollView {
                    width: parent.width;
                    height: parent.height;
                    horizontal-scrollbar-policy: always-off;
                    vertical-scrollbar-policy: as-needed;
                    viewport-width: parent.width;
                    viewport-height: max(parent.height, root.sidebar-content-height);
                    changed viewport-y => {
                        root.places_list_y_px = (self.absolute-position.y + 44px - self.viewport-y) / 1px;
                    }

                VerticalLayout {
                    padding-left: 8px;
                    padding-right: 8px;
                    padding-top: 10px;
                    padding-bottom: root.sidebar-content-bottom-padding;
                    spacing: 4px;
                    width: sidebar-scroll.viewport-width;
                    height: sidebar-scroll.viewport-height;

                    SidebarSection { label: "Places"; dark: root.dark_mode; }

                    for place[index] in root.places: PlaceButton {
                        label: place.label;
                        path: place.path;
                        drag-data-source: DndApi.make-drag-place(place.path);
                        marker: place.marker;
                        selected: root.sidebar-selected-path == place.path;
                        dark: root.dark_mode;
                        index: index;
                        place_count: root.places.length;
                        builtin: place.is_builtin;
                        list_y: parent.absolute-position.y + 44px - sidebar-scroll.viewport-y;
                        reorderable: true;
                        dragged: root.place_drag_active && root.place_drag_from == index;
                        drop-target: (root.folder_drag_active || root.place_drag_active) && root.folder_drag_over_place_item && !root.place_drag_rejected && root.folder_drag_place_target == index;
                        clicked => { root.open_place(place.path); }
                        context_requested(index, label, builtin, path, x, y) => {
                            root.context-menu-place-index = index;
                            root.context-menu-place-builtin = builtin;
                            root.rename-place-label = label;
                            root.show-context-menu(2, x, y);
                        }
                        drag_cancelled => {
                            root.place_drag_active = false;
                            root.place_drag_from = -1;
                            root.place_drag_target_path = "";
                            root.place_drag_target_label = "";
                        }
                    }

                    SidebarAction {
                        label: "Cancel Operations";
                        dark: root.dark_mode;
                        clicked => { root.cancel_queued_operations(); }
                    }

                    SidebarSection { label: "Devices"; dark: root.dark_mode; }
                    for device in root.devices: PlaceButton {
                        label: device.label;
                        path: device.path;
                        marker: device.marker;
                        selected: root.sidebar-selected-path == device.path;
                        dark: root.dark_mode;
                        reorderable: false;
                        dragged: false;
                        drop-target: false;
                        builtin: true;
                        available: device.mounted;
                        pending-action: device.pending_action;
                        error: device.error;
                        clicked => { root.open_device(device.mounted ? device.path : device.device_path, device.mounted); }
                        context_requested(index, label, builtin, path, x, y) => {
                            root.context-menu-device-path = device.device_path;
                            root.context-menu-device-open-path = device.path;
                            root.context-menu-device-mounted = device.mounted;
                            root.context-menu-device-can-mount = device.can_mount;
                            root.context-menu-device-can-unmount = device.can_unmount;
                            root.context-menu-device-can-eject = device.can_eject;
                            root.context-menu-device-pending-action = device.pending_action;
                            root.rename-place-label = label;
                            root.show-context-menu(5, x, y);
                        }
                    }
                }
                }

                places-folder-drop := DropArea {
                    enabled: true;
                    changed contains-drag => {
                        if (!self.contains-drag) {
                            root.folder_drag_active = false;
                            root.place_drag_active = false;
                            root.folder_drag_over_place_item = false;
                            root.place_drag_rejected = false;
                        }
                    }
                    can-drop(event) => {
                        root.trace_places_drop("can-drop", DndApi.event-kind(event) == DragKind.place ? "place" : (DndApi.event-kind(event) == DragKind.folder ? "folder" : (DndApi.event-kind(event) == DragKind.file ? "file" : "unsupported")), DndApi.event-path(event), (self.absolute-position.x + event.position.x) / 1px, (self.absolute-position.y + event.position.y) / 1px, root.folder_drag_slot, root.folder_drag_place_target, root.folder_drag_over_place_gap, root.folder_drag_over_place_item);
                        if (DndApi.event-kind(event) == DragKind.place || DndApi.event-kind(event) == DragKind.folder || DndApi.event-kind(event) == DragKind.file) {
                            root.folder_drag_path = DndApi.event-path(event);
                            root.folder_drag_label = DndApi.event-path(event);
                            root.folder_drag_x = self.absolute-position.x + event.position.x;
                            root.folder_drag_y = self.absolute-position.y + event.position.y;
                            root.place_drag_x = root.folder_drag_x;
                            root.place_drag_y = root.folder_drag_y;
                            root.folder_drag_active = DndApi.event-kind(event) == DragKind.folder || DndApi.event-kind(event) == DragKind.file;
                            root.place_drag_active = DndApi.event-kind(event) == DragKind.place;
                            root.place_drag_label = DndApi.event-path(event);
                            root.place_drag_marker = "P";
                            root.place_list_y = self.absolute-position.y + 44px - sidebar-scroll.viewport-y;
                            root.places_list_y_px = root.place_list_y / 1px;
                            root.folder_drag_place_target = root.place_drop_target((self.absolute-position.y + event.position.y) / 1px);
                            root.folder_drag_over_place_gap = root.place_drop_over_gap((self.absolute-position.y + event.position.y) / 1px);
                            root.folder_drag_over_place_item = root.place_drop_over_item((self.absolute-position.y + event.position.y) / 1px);
                            root.place_drag_rejected = root.folder_drag_over_place_item && !root.place_drop_allowed(DndApi.event-path(event), root.folder_drag_place_target);
                            root.folder_drag_slot = root.place_drop_slot((self.absolute-position.y + event.position.y) / 1px);
                            root.place_drag_slot = root.folder_drag_slot;
                            if (DndApi.event-kind(event) == DragKind.file && !root.folder_drag_over_place_item) {
                                root.folder_drag_active = false;
                                root.place_drag_rejected = false;
                                root.trace_places_drop("can-drop-rejected:file-gap", "file", DndApi.event-path(event), root.folder_drag_x / 1px, root.folder_drag_y / 1px, root.folder_drag_slot, root.folder_drag_place_target, root.folder_drag_over_place_gap, root.folder_drag_over_place_item);
                                return DragAction.none;
                            } else {
                                root.trace_places_drop("can-drop-accepted", DndApi.event-kind(event) == DragKind.place ? "place" : (DndApi.event-kind(event) == DragKind.folder ? "folder" : (DndApi.event-kind(event) == DragKind.file ? "file" : "unsupported")), DndApi.event-path(event), root.folder_drag_x / 1px, root.folder_drag_y / 1px, root.folder_drag_slot, root.folder_drag_place_target, root.folder_drag_over_place_gap, root.folder_drag_over_place_item);
                                return DragAction.copy;
                            }
                        } else {
                            root.folder_drag_active = false;
                            root.folder_drag_over_place_item = false;
                            root.place_drag_rejected = false;
                            root.trace_places_drop("can-drop-rejected:unsupported-dnd-payload", "unsupported", DndApi.event-path(event), (self.absolute-position.x + event.position.x) / 1px, (self.absolute-position.y + event.position.y) / 1px, -1, -1, false, false);
                            return DragAction.none;
                        }
                    }
                    dropped(event) => {
                        root.trace_places_drop("dropped", DndApi.event-kind(event) == DragKind.place ? "place" : (DndApi.event-kind(event) == DragKind.folder ? "folder" : (DndApi.event-kind(event) == DragKind.file ? "file" : "unsupported")), DndApi.event-path(event), (self.absolute-position.x + event.position.x) / 1px, (self.absolute-position.y + event.position.y) / 1px, root.folder_drag_slot, root.folder_drag_place_target, root.folder_drag_over_place_gap, root.folder_drag_over_place_item);
                        if (event.position.y + sidebar-scroll.viewport-y >= 44px && event.position.y + sidebar-scroll.viewport-y <= 44px + root.places.length * 38px) {
                            if (root.folder_drag_over_place_gap || root.folder_drag_slot >= root.places.length) {
                                if (DndApi.event-kind(event) == DragKind.place) {
                                    root.reorder_place_path(DndApi.event-path(event), root.folder_drag_slot);
                                } else if (DndApi.event-kind(event) == DragKind.folder) {
                                    root.add_place_at_slot(DndApi.event-path(event), root.folder_drag_slot);
                                }
                            } else {
                                if (root.prepare_place_transfer(DndApi.event-path(event), root.folder_drag_place_target, (self.absolute-position.x + event.position.x) / 1px, (self.absolute-position.y + event.position.y) / 1px)) {
                                    root.transfer-menu-open = true;
                                }
                            }
                        }
                        root.folder_drag_active = false;
                        root.place_drag_active = false;
                        root.folder_drag_over_place_item = false;
                        root.place_drag_rejected = false;
                        return DragAction.copy;
                    }
                    }
                }

                resize-touch := TouchArea {
                    x: max(0px, parent.width - root.sidebar-resize-hit-width);
                    width: root.sidebar-resize-hit-width;
                    height: parent.height;
                    mouse-cursor: ew-resize;

                    pointer-event(event) => {
                        if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                            root.sidebar-resize-start-width-px = root.sidebar_width_px;
                            root.sidebar-resize-press-x = self.absolute-position.x + self.mouse-x;
                        } else if (event.button == PointerEventButton.left && event.kind == PointerEventKind.up) {
                            root.persist_ui_state();
                        }
                    }

                    moved => {
                        if (self.pressed) {
                            root.sidebar_width_px = max(220, min((root.width - 360px) / 1px, root.sidebar-resize-start-width-px + (self.absolute-position.x + self.mouse-x - root.sidebar-resize-press-x) / 1px));
                        }
                    }
                }
            }

        main-pane := Rectangle {
            horizontal-stretch: 1;
            min-width: 0px;
            preferred-width: 0px;
            max-width: 100000px;
            background: root.shell-base-color;

            main-focus := FocusScope {
                width: 0px;
                height: 0px;
            }

            pane-row := Rectangle {
                width: parent.width;
                height: parent.height;
                clip: true;

                pane-shells := Rectangle {
                    width: parent.width;
                    height: parent.height;
                    clip: true;

                    left-pane-shell := Rectangle {
                        x: 0px;
                        width: root.active-pane-width;
                        height: parent.height;
                        background: root.shell-base-color;
                        clip: true;

                        FilePane {
                            pane-side: 0;
                            width: parent.width;
                            height: parent.height;
                            dark: root.dark_mode;
                            shell-base-color: root.shell-base-color;
                            path-bar-height: root.path-bar-height;
                            status-bar-height: root.status-bar-height;
                            current-path: root.left_pane_path;
                            can-go-back: root.left_pane_can_go_back;
                            can-go-forward: root.left_pane_can_go_forward;
                            path-text <=> root.left_pane_path_input_text;
                            path-focused <=> root.left_pane_path_focused;
                            search-panel-visible: root.search-panel-visible;
                            search-panel-height: root.search-panel-height;
                            search-loading: root.search_loading;
                            search-filters-active: root.search-filters-active;
                            search-kind-label: root.search-kind-filter-label;
                            search-modified-label: root.search-modified-filter-label;
                            search-size-label: root.search-size-filter-label;
                            search-query <=> root.search_query;
                            recursive-search <=> root.recursive_search;
                            search-kind-filter <=> root.search_kind_filter;
                            search-modified-filter <=> root.search_modified_filter;
                            search-size-filter <=> root.search_size_filter;
                            content-interactive: !root.directory_loading;
                            drop-ready: !root.directory_loading;
                            drop-trace-prefix: "";
                            entry-count: root.entry_count;
                            entries: root.virtual_entries;
                            virtual-start-index: root.virtual_start_index;
                            virtual-start-column: root.virtual_start_column;
                            viewport-x <=> root.main_viewport_x;
                            viewport-offset <=> root.main_viewport_offset;
                            zoom-level: root.icon_zoom_level;
                            selection-revision: root.selection_revision;
                            show-location: root.left_pane_in_trash || (root.recursive_search && root.search_query != "");
                            drag-active <=> root.main_drag_active;
                            drag-rejected <=> root.main_drag_rejected;
                            drag-target-path <=> root.place_drag_target_path;
                            empty-message-visible: !root.directory_loading;
                            empty-title: root.search_loading ? "Searching..." : (root.search_query == "" ? "This folder is empty" : "No matching items");
                            empty-subtitle: root.search_loading ? "Scanning subfolders." : (root.search_query == "" ? "This directory has no visible files." : "Try another search term.");
                            status: root.left_pane_status;
                            selected-count: root.left_pane_selected_count;
                            selected-status: root.left_pane_selected_status;
                            external-edit-active: root.focused_pane == 0 && root.external_edit_active;
                            external-edit-status: root.external_edit_status;
                            undo-available: root.focused_pane == 0 && root.undo_available;
                            undo-label: root.undo_label;
                            chooser-mode: root.focused_pane == 0 && root.chooser_mode;
                            chooser-select-directories: root.chooser_select_directories;
                            chooser-save-mode: root.chooser_save_mode;
                            chooser-accept-label: root.chooser_accept_label;
                            selected-path: root.focused_pane == 0 ? root.selected_path : "";
                            chooser-filter-count: root.chooser_filter_count;
                            chooser-filter-label: root.chooser_filter_label;
                            chooser-choices: root.chooser_choices;
                            chooser-save-name <=> root.chooser_save_name;
                            focus_requested(side) => { root.pane-focus(side); }
                            path_submitted(side, path) => { root.pane-path-submitted(side, path); }
                            go_back(side) => { root.pane-go-back(side); }
                            go_forward(side) => { root.pane-go-forward(side); }
                            search_submitted(query) => { root.search_submitted(query); }
                            cancel_search => { root.cancel_search(); }
                            search_filters_changed(kind, modified, size) => {
                                root.search_filters_changed(kind, modified, size);
                            }
                            search_close_requested => { root.search_bar_open = false; }
                            view_changed(side) => { root.pane-view-changed(side); }
                            activated(side, path) => { root.pane-activated(side, path); }
                            request_select(side, path, toggle, range) => { root.pane-request-select(side, path, toggle, range); }
                            select_rect(side, x1, y1, x2, y2, rows-per-column, cell-width, row-height, padding, toggle) => {
                                root.pane-select-rect(side, x1, y1, x2, y2, rows-per-column, cell-width, row-height, padding, toggle);
                            }
                            clear_selection(side) => { root.pane-clear-selection(side); }
                            request_context_menu(side, path, name, size, modified, is-dir, x, y) => { root.pane-request-context-menu(side, path, name, size, modified, is-dir, x, y); }
                            request_blank_context_menu(side, x, y) => { root.pane-request-blank-context-menu(side, x, y); }
                            zoom_in(side) => { root.pane-zoom-in(side); }
                            zoom_out(side) => { root.pane-zoom-out(side); }
                            drop_target_path(side, x, y, source) => {
                                root.pane-drop-target-path(side, x, y, source)
                            }
                            drop_allowed(side, x, y, source) => {
                                root.pane-drop-allowed(side, x, y, source)
                            }
                            prepare_transfer(side, source, x, y) => {
                                root.pane-prepare-transfer(side, source, x, y)
                            }
                            transfer_menu_requested(side) => { root.pane-transfer-menu-requested(side); }
                            trace_drop(action, kind, path, x, y, rejected, target) => {
                                root.trace_main_drop(action, kind, path, x, y, rejected, target);
                            }
                            save_focus_changed(side, focused) => { root.pane-save-focus-changed(side, focused); }
                            commit_external_edit => { root.commit_external_edit(); }
                            discard_external_edit => { root.discard_external_edit(); }
                            undo_last_operation => { root.undo_last_operation(); }
                            chooser_accept(value) => { root.chooser_accept(value); }
                            chooser_filter_requested(side, x, y) => { root.pane-chooser-filter-requested(side, x, y); }
                            chooser_choice_requested(side, index, x, y) => { root.pane-chooser-choice-requested(side, index, x, y); }
                            is_selected(side, path) => {
                                side == 1 ? root.is_inactive_selected(path) : root.is_selected(path)
                            }
                            make_drag_data(side, path, is-dir) => {
                                is-dir ? DndApi.make-drag-folder(path) : DndApi.make-drag-file(path)
                            }
                        }
                    }

                    if (root.split_view_open) : split-divider := Rectangle {
                        x: root.active-pane-width;
                        width: root.split-divider-width;
                        height: parent.height;
                        background: root.split-resize-active ? (root.dark_mode ? #58b4d8 : #2f8dbc) : root.shell-separator-color;
                    }

                    if (root.split_view_open) : right-pane-shell := Rectangle {
                        x: root.inactive-pane-x;
                        width: root.inactive-pane-width;
                        height: parent.height;
                        background: root.shell-base-color;
                        clip: true;

                        FilePane {
                            pane-side: 1;
                            width: parent.width;
                            height: parent.height;
                            dark: root.dark_mode;
                            shell-base-color: root.shell-base-color;
                            path-bar-height: root.path-bar-height;
                            status-bar-height: root.status-bar-height;
                            current-path: root.inactive_pane_path;
                            can-go-back: root.inactive_pane_can_go_back;
                            can-go-forward: root.inactive_pane_can_go_forward;
                            path-text <=> root.inactive_pane_path_input_text;
                            path-focused <=> root.inactive_pane_path_focused;
                            search-panel-visible: false;
                            content-interactive: true;
                            drop-ready: true;
                            drop-trace-prefix: "inactive-";
                            entry-count: root.inactive_pane_entry_count;
                            entries: root.inactive_pane_entries;
                            virtual-start-index: root.inactive_pane_virtual_start_index;
                            virtual-start-column: root.inactive_pane_virtual_start_column;
                            viewport-x <=> root.inactive_pane_viewport_x;
                            viewport-offset <=> root.inactive_pane_viewport_offset;
                            zoom-level: root.icon_zoom_level;
                            selection-revision: root.selection_revision;
                            show-location: root.inactive_pane_in_trash;
                            drag-active <=> root.inactive-pane-drag-active;
                            drag-rejected <=> root.inactive-pane-drag-rejected;
                            drag-target-path <=> root.inactive-pane-drag-target-path;
                            status: root.inactive_pane_status;
                            selected-count: root.inactive_pane_selected_count;
                            selected-status: root.inactive_pane_selected_status;
                            external-edit-active: root.focused_pane == 1 && root.external_edit_active;
                            external-edit-status: root.external_edit_status;
                            undo-available: root.focused_pane == 1 && root.undo_available;
                            undo-label: root.undo_label;
                            chooser-mode: root.focused_pane == 1 && root.chooser_mode;
                            chooser-select-directories: root.chooser_select_directories;
                            chooser-save-mode: root.chooser_save_mode;
                            chooser-accept-label: root.chooser_accept_label;
                            selected-path: root.focused_pane == 1 ? root.selected_path : "";
                            chooser-filter-count: root.chooser_filter_count;
                            chooser-filter-label: root.chooser_filter_label;
                            chooser-choices: root.chooser_choices;
                            chooser-save-name <=> root.chooser_save_name;
                            focus_requested(side) => { root.pane-focus(side); }
                            path_submitted(side, path) => { root.pane-path-submitted(side, path); }
                            go_back(side) => { root.pane-go-back(side); }
                            go_forward(side) => { root.pane-go-forward(side); }
                            search_submitted(query) => { root.search_submitted(query); }
                            cancel_search => { root.cancel_search(); }
                            search_filters_changed(kind, modified, size) => {
                                root.search_filters_changed(kind, modified, size);
                            }
                            search_close_requested => { root.search_bar_open = false; }
                            view_changed(side) => { root.pane-view-changed(side); }
                            activated(side, path) => { root.pane-activated(side, path); }
                            request_select(side, path, toggle, range) => { root.pane-request-select(side, path, toggle, range); }
                            select_rect(side, x1, y1, x2, y2, rows-per-column, cell-width, row-height, padding, toggle) => {
                                root.pane-select-rect(side, x1, y1, x2, y2, rows-per-column, cell-width, row-height, padding, toggle);
                            }
                            clear_selection(side) => { root.pane-clear-selection(side); }
                            request_context_menu(side, path, name, size, modified, is-dir, x, y) => { root.pane-request-context-menu(side, path, name, size, modified, is-dir, x, y); }
                            request_blank_context_menu(side, x, y) => { root.pane-request-blank-context-menu(side, x, y); }
                            zoom_in(side) => { root.pane-zoom-in(side); }
                            zoom_out(side) => { root.pane-zoom-out(side); }
                            drop_target_path(side, x, y, source) => {
                                root.pane-drop-target-path(side, x, y, source)
                            }
                            drop_allowed(side, x, y, source) => {
                                root.pane-drop-allowed(side, x, y, source)
                            }
                            prepare_transfer(side, source, x, y) => {
                                root.pane-prepare-transfer(side, source, x, y)
                            }
                            transfer_menu_requested(side) => { root.pane-transfer-menu-requested(side); }
                            trace_drop(action, kind, path, x, y, rejected, target) => {
                                root.trace_main_drop(action, kind, path, x, y, rejected, target);
                            }
                            save_focus_changed(side, focused) => { root.pane-save-focus-changed(side, focused); }
                            commit_external_edit => { root.commit_external_edit(); }
                            discard_external_edit => { root.discard_external_edit(); }
                            undo_last_operation => { root.undo_last_operation(); }
                            chooser_accept(value) => { root.chooser_accept(value); }
                            chooser_filter_requested(side, x, y) => { root.pane-chooser-filter-requested(side, x, y); }
                            chooser_choice_requested(side, index, x, y) => { root.pane-chooser-choice-requested(side, index, x, y); }
                            is_selected(side, path) => {
                                side == 1 ? root.is_inactive_selected(path) : root.is_selected(path)
                            }
                            make_drag_data(side, path, is-dir) => {
                                is-dir ? DndApi.make-drag-folder(path) : DndApi.make-drag-file(path)
                            }
                        }
                    }

                    if (root.split_view_open) : split-divider-touch := TouchArea {
                        x: max(0px, root.active-pane-width - root.split-resize-hit-width / 2);
                        width: root.split-resize-hit-width;
                        height: parent.height;
                        mouse-cursor: ew-resize;

                        pointer-event(event) => {
                            if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                                root.split-resize-start-ratio = root.split_pane_ratio;
                                root.split-resize-press-x = self.absolute-position.x + self.mouse-x;
                                root.split-resize-active = true;
                            } else if (event.button == PointerEventButton.left && event.kind == PointerEventKind.up) {
                                root.split-resize-active = false;
                                root.persist_ui_state();
                            }
                        }

                        moved => {
                            if (self.pressed) {
                                root.split_pane_ratio = max(0.1, min(0.9, root.split-resize-start-ratio + ((self.absolute-position.x + self.mouse-x - root.split-resize-press-x) / 1px) / max(1, root.split-content-width / 1px)));
                            }
                        }
                    }
                }
        }
            }
        }
    }
    }

    DragOverlayLayer {
        width: parent.width;
        height: parent.height;
        dark: root.dark_mode;
        sidebar-width-px: root.sidebar_width_px;
        places-count: root.places.length;
        place-list-y: root.place_list_y;
        folder-drag-active: root.folder_drag_active;
        folder-drag-x: root.folder_drag_x;
        folder-drag-y: root.folder_drag_y;
        folder-drag-slot: root.folder_drag_slot;
        folder-drag-place-target: root.folder_drag_place_target;
        folder-drag-label: root.folder_drag_label;
        folder-drag-over-place-gap: root.folder_drag_over_place_gap;
        place-drag-active: root.place_drag_active;
        place-drag-x: root.place_drag_x;
        place-drag-y: root.place_drag_y;
        place-drag-slot: root.place_drag_slot;
        place-drag-label: root.place_drag_label;
        place-drag-marker: root.place_drag_marker;
        place-drag-rejected: root.place_drag_rejected;
        main-drag-active: root.main_drag_active;
        main-drag-rejected: root.main_drag_rejected;
    }

    if (root.transient-popup-open): MenuDismissLayer {
        width: parent.width;
        height: parent.height;
        dismissed => {
            root.dismiss-transient-popups();
        }
    }

    root-context-menu := RootContextMenuLayer {
        width: parent.width;
        height: parent.height;
        menu-open: root.context-menu-open;
        menu-kind: root.context-menu-kind;
        menu-x: root.context-menu-x;
        menu-y: root.context-menu-y;
        window-width: root.width;
        window-height: root.height;
        screen-margin: root.menu-screen-margin;
        pointer-gap: root.menu-pointer-gap;
        file-menu-width: root.context-file-menu-width;
        place-menu-width: root.context-place-menu-width;
        blank-menu-width: root.context-blank-menu-width;
        item-height: root.menu-item-height;
        separator-height: root.menu-separator-height;
        title-height: root.menu-title-height;
        dark: root.dark_mode;
        selected-count: root.selected_count;
        selected-status: root.selected_status;
        is-dir: root.context-menu-is-dir;
        default-open-visible: root.context-default-open-visible;
        default-open-app-name: root.default_open_app_name;
        clipboard-has-paths: root.clipboard_has_paths;
        clipboard-cut: root.clipboard_cut;
        add-to-places-visible: root.context-add-place-visible;
        in-trash: root.current_in_trash;
        place-title: root.rename-place-label;
        place-builtin: root.context-menu-place-builtin;
        device-title: root.rename-place-label;
        device-mounted: root.context-menu-device-mounted;
        device-can-mount: root.context-menu-device-can-mount;
        device-can-unmount: root.context-menu-device-can-unmount;
        device-can-eject: root.context-menu-device-can-eject;
        device-pending-action: root.context-menu-device-pending-action;
        file_open_folder_with_hover(row-y, is-hovered) => {
            root.open-with-submenu-hover(root.context-menu-path, row-y, is-hovered);
        }
        file_open_folder_with_clicked(row-y) => {
            root.show-open-with-submenu(root.context-menu-path, row-y);
        }
        file_default_open_requested => {
            root.open_path(root.context-menu-path);
            root.close-context-popups();
        }
        file_open_with_hover(row-y, is-hovered) => {
            root.open-with-submenu-hover(root.context-menu-path, row-y, is-hovered);
        }
        file_open_with_clicked(row-y) => {
            root.show-open-with-submenu(root.context-menu-path, row-y);
        }
        file_paste_into_folder => {
            root.paste_into(root.context-menu-path);
            root.close-context-popups();
        }
        file_add_to_places => {
            root.add_place(root.context-menu-path);
            root.close-context-popups();
        }
        file_open_terminal_here => {
            root.open_terminal_here(root.context-menu-path);
            root.close-context-popups();
        }
        file_rename_requested => {
            root.rename-entry-path = root.context-menu-path;
            root.rename-entry-name = root.context-menu-name;
            root.rename-entry-open = true;
            root.close-context-popups();
        }
        file_duplicate_requested => {
            root.duplicate_path(root.context-menu-path);
            root.close-context-popups();
        }
        file_cut_requested => {
            root.copy_paths(root.context-menu-path, true);
            root.close-context-popups();
        }
        file_copy_requested => {
            root.copy_paths(root.context-menu-path, false);
            root.close-context-popups();
        }
        file_copy_location_requested => {
            root.copy_location(root.context-menu-path);
            root.close-context-popups();
        }
        file_properties_requested => {
            root.properties-name = root.context-menu-name;
            root.properties-path = root.context-menu-path;
            root.properties-kind = root.context-menu-is-dir ? "Folder" : "File";
            root.properties-size = root.context-menu-properties-size;
            root.properties-modified-label = root.current_in_trash ? "Deleted" : "Modified";
            root.properties-modified = root.context-menu-properties-modified;
            root.properties-open = true;
            root.close-context-popups();
        }
        file_trash_requested => {
            if (root.selected_count > 1) {
                root.trash_selected();
            } else {
                root.trash_path(root.context-menu-path);
            }
            root.close-context-popups();
        }
        file_restore_trash_requested => {
            if (root.selected_count > 1) {
                root.restore_trash_selected();
            } else {
                root.restore_trash_path(root.context-menu-path);
            }
            root.close-context-popups();
        }
        file_delete_permanently_requested => {
            if (root.selected_count > 1) {
                root.confirm-permanent-delete("", true);
            } else {
                root.confirm-permanent-delete(root.context-menu-path, false);
            }
        }
        place_open_new_window => {
            root.open_place_new_window(root.context-menu-place-index);
            root.close-context-popups();
        }
        place_rename_requested => {
            root.rename-place-index = root.context-menu-place-index;
            root.rename-place-open = true;
            root.close-context-popups();
        }
        place_remove_requested => {
            root.remove_place(root.context-menu-place-index);
            root.close-context-popups();
        }
        device_open_requested => {
            root.open_device(root.context-menu-device-open-path, true);
            root.close-context-popups();
        }
        device_mount_requested => {
            root.open_device(root.context-menu-device-path, false);
            root.close-context-popups();
        }
        device_unmount_requested => {
            root.unmount_device(root.context-menu-device-path, root.context-menu-device-open-path);
            root.close-context-popups();
        }
        device_eject_requested => {
            root.eject_device(root.context-menu-device-path, root.context-menu-device-open-path);
            root.close-context-popups();
        }
        places_blank_add_current_folder => {
            root.add_place(root.current_path);
            root.close-context-popups();
        }
        places_blank_restore_defaults => {
            root.restore_default_places();
            root.close-context-popups();
        }
        viewport_create_new_hover(row-y, is-hovered) => {
            root.create-new-submenu-hover(row-y, is-hovered);
        }
        viewport_create_new_clicked(row-y) => {
            root.show-create-new-submenu(row-y);
        }
        viewport_select_all_requested => {
            root.select_all_visible();
            root.close-context-popups();
        }
        viewport_paste_requested => {
            root.paste_into(root.current_path);
            root.close-context-popups();
        }
        viewport_empty_trash_requested => {
            root.confirm-empty-trash();
        }
        viewport_open_folder_with_hover(row-y, is-hovered) => {
            root.open-with-submenu-hover(root.current_path, row-y, is-hovered);
        }
        viewport_open_folder_with_clicked(row-y) => {
            root.show-open-with-submenu(root.current_path, row-y);
        }
        viewport_open_terminal_here => {
            root.open_terminal_here(root.current_path);
            root.close-context-popups();
        }
    }

    ChildSubmenuLayer {
        width: parent.width;
        height: parent.height;
        context-menu-open: root.context-menu-open;
        context-menu-left: root-context-menu.active-menu-left;
        context-menu-width: root-context-menu.active-menu-width;
        window-width: root.width;
        window-height: root.height;
        screen-margin: root.menu-screen-margin;
        pointer-gap: root.menu-pointer-gap;
        child-gap: root.child-menu-gap;
        item-height: root.menu-item-height;
        title-height: root.menu-title-height;
        separator-height: root.menu-separator-height;
        create-new-open: MenuLifecycle.create-new-open;
        create-new-row-y: MenuLifecycle.create-new-row-y;
        open-with-open: MenuLifecycle.open-with-open;
        open-with-row-y: MenuLifecycle.open-with-row-y;
        open-with-apps: root.open_with_apps;
        dark: root.dark_mode;
        child_hovered(kind, is-hovered) => {
            root.set-child-submenu-hover(kind, is-hovered);
        }
        create_folder_selected => {
            root.new-folder-name = "New Folder";
            root.new-folder-open = true;
            root.close-context-popups();
        }
        create_file_selected => {
            root.new-file-name = "New File.txt";
            root.new-file-open = true;
            root.close-context-popups();
        }
        open_with_app_selected(app-id) => {
            root.open_with_app(root.open_with_path, app-id);
            root.close-context-popups();
        }
        other_applications => {
            root.prepare_other_applications(root.open_with_path);
            root.custom_open_command = "";
            root.other_application_filter = "";
            root.other_application_set_default = false;
            root.custom-open-with-open = true;
            root.close-context-popups();
        }
    }

    if (root.rename-entry-open): TextInputPopup {
        width: parent.width;
        height: parent.height;
        dialog-width: 380px;
        dark: root.dark_mode;
        title: "Rename";
        accept-label: "Rename";
        value <=> root.rename-entry-name;
        accepted(value) => {
            root.rename_path(root.rename-entry-path, value);
            root.rename-entry-open = false;
        }
        cancelled => { root.rename-entry-open = false; }
    }

    if (root.properties-open): PropertiesPopup {
        width: parent.width;
        height: parent.height;
        dark: root.dark_mode;
        name: root.properties-name;
        kind: root.properties-kind;
        size: root.properties-size;
        modified-label: root.properties-modified-label;
        modified: root.properties-modified;
        path: root.properties-path;
        closed => { root.properties-open = false; }
    }

    if (root.privileged_prompt_open): PrivilegedPromptPopup {
        width: parent.width;
        height: parent.height;
        dark: root.dark_mode;
        title: root.privileged_prompt_title;
        message: root.privileged_prompt_message;
        detail: root.privileged_prompt_detail;
        cancelled => { root.privileged_prompt_dismiss(); }
        accepted => { root.privileged_prompt_accept(); }
    }

    if (root.trash-confirm-open): ConfirmationPopup {
        width: parent.width;
        height: parent.height;
        dark: root.dark_mode;
        title: root.trash-confirm-title;
        message: root.trash-confirm-message;
        detail: root.trash-confirm-detail;
        accept-label: root.trash-confirm-accept-label;
        cancelled => { root.trash-confirm-open = false; }
        accepted => { root.accept-trash-confirmation(); }
    }

    if (root.transfer_conflict_open): TransferConflictPopup {
        width: parent.width;
        height: parent.height;
        dark: root.dark_mode;
        source: root.transfer_conflict_source;
        target: root.transfer_conflict_target;
        rename-name <=> root.transfer_conflict_rename_name;
        apply-all <=> root.transfer-conflict-apply-all;
        choice(decision) => { root.transfer_conflict_choice(decision); }
    }

    TransferMenuLayer {
        width: parent.width;
        height: parent.height;
        menu-open: root.transfer-menu-open;
        menu-x: root.transfer_menu_x;
        menu-y: root.transfer_menu_y;
        window-width: root.width;
        window-height: root.height;
        screen-margin: root.menu-screen-margin;
        pointer-gap: root.menu-pointer-gap;
        item-height: root.menu-item-height;
        separator-height: root.menu-separator-height;
        title-height: root.menu-title-height;
        title: root.transfer_source_label + " -> " + root.transfer_target_label;
        dark: root.dark_mode;
        operation_selected(operation) => {
            root.transfer_operation(operation, root.transfer_source_path, root.transfer_target_path);
            root.transfer-menu-open = false;
        }
        cancelled => {
            root.transfer-menu-open = false;
        }
    }

    if (root.rename-place-open): TextInputPopup {
        width: parent.width;
        height: parent.height;
        dark: root.dark_mode;
        title: "Rename Place";
        accept-label: "Rename";
        value <=> root.rename-place-label;
        accepted(value) => {
            root.rename_place(root.rename-place-index, value);
            root.rename-place-open = false;
        }
        cancelled => { root.rename-place-open = false; }
    }

    if (root.new-folder-open): TextInputPopup {
        width: parent.width;
        height: parent.height;
        dark: root.dark_mode;
        title: "New Folder";
        accept-label: "Create";
        value <=> root.new-folder-name;
        accepted(value) => {
            root.create_folder(value);
            root.new-folder-open = false;
        }
        cancelled => { root.new-folder-open = false; }
    }

    if (root.new-file-open): TextInputPopup {
        width: parent.width;
        height: parent.height;
        dark: root.dark_mode;
        title: "New File";
        accept-label: "Create";
        value <=> root.new-file-name;
        accepted(value) => {
            root.create_file(value);
            root.new-file-open = false;
        }
        cancelled => { root.new-file-open = false; }
    }

    ChooserChoicePopupLayer {
        width: parent.width;
        height: parent.height;
        menu-open: root.chooser-choice-menu-open;
        menu-index: root.chooser-choice-menu-index;
        menu-x: root.chooser-choice-menu-x;
        menu-y: root.chooser-choice-menu-y;
        menu-width: root.chooser-choice-menu-width;
        window-width: root.width;
        window-height: root.height;
        screen-margin: root.menu-screen-margin;
        pointer-gap: root.menu-pointer-gap;
        child-gap: root.child-menu-gap;
        dark: root.dark_mode;
        choices: root.chooser_choices;
        title-height: root.menu-title-height;
        item-height: root.menu-item-height;
        option_selected(choice-index, option-index) => {
            root.chooser_select_choice(choice-index, option-index);
            root.chooser-choice-menu-open = false;
        }
    }

    ChooserOptionPopupLayer {
        width: parent.width;
        height: parent.height;
        menu-open: root.chooser-filter-menu-open;
        menu-x: root.chooser-filter-menu-x;
        menu-y: root.chooser-filter-menu-y;
        menu-width: root.chooser-filter-menu-width;
        window-width: root.width;
        window-height: root.height;
        screen-margin: root.menu-screen-margin;
        pointer-gap: root.menu-pointer-gap;
        child-gap: root.child-menu-gap;
        dark: root.dark_mode;
        title: "Filter";
        options: root.chooser_filter_options;
        selected-index: root.chooser_filter_index;
        title-height: root.menu-title-height;
        item-height: root.menu-item-height;
        option_selected(option-index) => {
            root.chooser_select_filter(option-index);
            root.chooser-filter-menu-open = false;
        }
    }

    if (root.custom-open-with-open): OtherApplicationsPopup {
        width: parent.width;
        height: parent.height;
        dark: root.dark_mode;
        apps: root.other_application_apps;
        filter <=> root.other_application_filter;
        custom-command <=> root.custom_open_command;
        set-default <=> root.other_application_set_default;
        filter_changed(query) => { root.filter_other_applications(query); }
        app_selected(app-id, set-default) => {
            if (set-default) {
                root.set_default_app(root.open_with_path, app-id);
            }
            root.open_with_app(root.open_with_path, app-id);
            root.custom-open-with-open = false;
        }
        custom_open(command) => {
            root.open_with_custom_command(root.open_with_path, command);
            root.custom-open-with-open = false;
        }
        cancelled => { root.custom-open-with-open = false; }
    }
}
