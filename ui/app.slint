    private property <length> active-child-bridge-top: root.child_bridge_top(root.width / 1px, root.height / 1px, root.context-menu-left / 1px, root.active-context-menu-width / 1px, root.active-child-menu-left / 1px, root.active-child-menu-width / 1px, root.active-child-menu-y / 1px, root.active-child-menu-top / 1px, root.menu-item-height / 1px, root.active-child-menu-title-height / 1px, root.menu-screen-margin / 1px, root.menu-pointer-gap / 1px, root.child-menu-gap / 1px) * 1px;
