// Globals must be exported from app.slint (the root file) so that
// `include_modules!()` generates Rust types for `ui.global::<...>()`.
export { MenuGeometry } from "menu_geometry.slint";
export { MenuLifecycle } from "menu_lifecycle.slint";

export global DndApi {
    pure callback make-drag-place(path: string) -> data-transfer;
    pure callback make-drag-folder(path: string) -> data-transfer;
    pure callback make-drag-file(path: string) -> data-transfer;
    pure callback event-kind(event: DropEvent) -> DragKind;
    pure callback event-path(event: DropEvent) -> string;
}

export global PaneRouting {
    callback focus(int);
    callback path-submitted(int, string);
    callback go-back(int);
    callback go-forward(int);
    callback search-submitted(string);
    callback cancel-search();
    callback search-filters-changed(int, int, int);
    callback search-close-requested();
    callback view-changed(int);
    callback activated(int, string);
    callback request-select(int, string, bool, bool);
    callback select-rect(int, float, float, float, float, int, float, float, float, bool);
    callback clear-selection(int);
    callback request-context-menu(int, string, string, string, string, bool, length, length);
    callback request-blank-context-menu(int, length, length);
    callback zoom-in(int);
    callback zoom-out(int);
    callback drop-target-path(int, float, float, string) -> string;
    callback drop-allowed(int, float, float, string) -> bool;
    callback prepare-transfer(int, string, float, float) -> bool;
    callback transfer-menu-requested(int);
    callback trace-drop(string, string, string, float, float, bool, string);
    callback save-focus-changed(int, bool);
    callback commit-external-edit(int);
    callback discard-external-edit(int);
    callback undo-last-operation();
    callback chooser-accept(string);
    callback chooser-filter-requested(int, length, length);
    callback chooser-choice-requested(int, int, length, length);
}

import { DragKind } from "dnd_bridge.slint";
import { MenuLifecycle, MenuLifecycleController } from "menu_lifecycle.slint";
import { ScrollView } from "std-widgets.slint";
import {
    MenuDismissLayer,
    PlaceButton,
    SidebarAction,
    SidebarSection,
} from "widgets.slint";
import { ChooserChoice, ChooserChoiceOption, ContextServiceAction, ContextServicePolicyAction, DesktopApp, DeviceEntry, FileEntry, PaneSlotData, PlaceEntry } from "models.slint";
import { DragOverlayLayer } from "dnd_overlay.slint";
import { SearchPanel } from "search_panel.slint";
import { SplitPaneView } from "split_pane.slint";
import { StatusBar } from "status_bar.slint";
import { PathBar, TopBar } from "top_bar.slint";
import { ChildSubmenuLayer, ChooserChoicePopupLayer, ChooserOptionPopupLayer, RootContextMenuLayer, TransferMenuLayer } from "menus.slint";
import { ConfirmationPopup, OtherApplicationsPopup, PrivilegedPromptPopup, PropertiesPopup, ServiceMenuPolicyPopup, TextInputPopup, TransferConflictPopup } from "dialogs.slint";

component FilePane inherits Rectangle {
    in property <int> pane-slot: 0;
    in property <bool> dark;
    in property <color> shell-base-color;
    in property <length> path-bar-height;
    in property <length> status-bar-height;
    in property <string> current-path;
    in property <bool> can-go-back;
    in property <bool> can-go-forward;
    in-out property <string> path-text;
    in-out property <bool> path-focused;
    in property <bool> search-panel-visible: false;
    in property <length> search-panel-height: 0px;
    in property <bool> search-loading: false;
    in property <bool> search-filters-active: false;
    in property <string> search-kind-label;
    in property <string> search-modified-label;
    in property <string> search-size-label;
    in-out property <string> search-query;
    in-out property <bool> recursive-search;
    in-out property <int> search-kind-filter;
    in-out property <int> search-modified-filter;
    in-out property <int> search-size-filter;
    in property <bool> content-interactive: true;
    in property <bool> drop-ready: true;
    in property <string> drop-trace-prefix;
    in property <int> entry-count;
    in property <[FileEntry]> entries;
    in property <int> virtual-start-index;
    in property <int> virtual-start-column;
    in-out property <float> viewport-x;
    in property <int> zoom-level;
    in property <int> selection-revision;
    in property <bool> show-location: false;
    in-out property <bool> drag-active;
    in-out property <bool> drag-rejected;
    in-out property <string> drag-target-path;
    in property <bool> empty-message-visible: true;
    in property <string> empty-title: "This folder is empty";
    in property <string> empty-subtitle: "";
    in property <string> status;
    in property <int> selected-count;
    in property <string> selected-status;
    in property <bool> external-edit-active;
    in property <string> external-edit-status;
    in property <bool> undo-available;
    in property <string> undo-label;
    in property <bool> chooser-mode;
    in property <bool> chooser-select-directories;
    in property <bool> chooser-save-mode;
    in property <string> chooser-accept-label;
    in property <string> selected-path;
    in property <int> chooser-filter-count;
    in property <string> chooser-filter-label;
    in property <[ChooserChoice]> chooser-choices;
    in-out property <string> chooser-save-name;

    callback focus_requested(int);
    callback path_submitted(int, string);
    callback path_text_changed(int, string);
    callback path_focus_changed(int, bool);
    callback go_back(int);
    callback go_forward(int);
    callback search_submitted(string);
    callback cancel_search();
    callback search_filters_changed(int, int, int);
    callback search_close_requested();
    callback viewport_changed(int, float);
    callback view_changed(int);
    callback activated(int, string);
    callback request_select(int, string, bool, bool);
    callback select_rect(int, float, float, float, float, int, float, float, float, bool);
    callback clear_selection(int);
    callback request_context_menu(int, string, string, string, string, bool, length, length);
    callback request_blank_context_menu(int, length, length);
    callback zoom_in(int);
    callback zoom_out(int);
    callback drop_target_path(int, float, float, string) -> string;
    callback drop_allowed(int, float, float, string) -> bool;
    callback prepare_transfer(int, string, float, float) -> bool;
    callback transfer_menu_requested(int);
    callback trace_drop(string, string, string, float, float, bool, string);
    callback save_focus_changed(int, bool);
    callback commit_external_edit(int);
    callback discard_external_edit(int);
    callback undo_last_operation();
    callback chooser_accept(string);
    callback chooser_filter_requested(int, length, length);
    callback chooser_choice_requested(int, int, length, length);
    pure callback make_drag_data(int, string, bool) -> data-transfer;

    background: root.shell-base-color;
    clip: true;

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        padding: 0px;
        spacing: 0px;

        PathBar {
            horizontal-stretch: 1;
            height: root.path-bar-height;
            dark: root.dark;
            current-path: root.current-path;
            can-go-back: root.can-go-back;
            can-go-forward: root.can-go-forward;
            path-text: root.path-text;
            path-focused: root.path-focused;
            focus_requested => { root.focus_requested(root.pane-slot); }
            go_back => { root.go_back(root.pane-slot); }
            go_forward => { root.go_forward(root.pane-slot); }
            path_submitted(path) => { root.path_submitted(root.pane-slot, path); }
            path_text_changed(text) => {
                root.path-text = text;
                root.path_text_changed(root.pane-slot, text);
            }
            path_focus_changed(focused) => {
                root.path-focused = focused;
                root.path_focus_changed(root.pane-slot, focused);
            }
        }

        if (root.search-panel-visible) : SearchPanel {
            horizontal-stretch: 1;
            height: root.search-panel-height;
            dark: root.dark;
            loading: root.search-loading;
            filters-active: root.search-filters-active;
            kind-label: root.search-kind-label;
            modified-label: root.search-modified-label;
            size-label: root.search-size-label;
            query <=> root.search-query;
            recursive <=> root.recursive-search;
            kind-filter <=> root.search-kind-filter;
            modified-filter <=> root.search-modified-filter;
            size-filter <=> root.search-size-filter;
            submitted(query) => { root.search_submitted(query); }
            cancel_requested => { root.cancel_search(); }
            filters_changed(kind, modified, size) => {
                root.search_filters_changed(kind, modified, size);
            }
            close_requested => { root.search_close_requested(); }
        }

        pane-content := Rectangle {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            width: parent.width;
            height: max(1px, parent.height - root.path-bar-height - root.status-bar-height - (root.search-panel-visible ? root.search-panel-height : 0px));
            background: root.shell-base-color;
            clip: true;

            DropArea {
                width: parent.width;
                height: parent.height;
                enabled: true;
                changed contains-drag => {
                    if (!self.contains-drag) {
                        root.drag-active = false;
                        root.drag-rejected = false;
                        root.drag-target-path = "";
                    }
                }
                can-drop(event) => {
                    root.focus_requested(root.pane-slot);
                    if (!root.drop-ready) {
                        root.drag-active = false;
                        root.drag-rejected = true;
                        root.drag-target-path = "";
                        return DragAction.none;
                    }
                    if (DndApi.event-kind(event) == DragKind.folder || DndApi.event-kind(event) == DragKind.file || DndApi.event-kind(event) == DragKind.place) {
                        root.drag-active = true;
                        root.drag-target-path = root.drop_target_path(root.pane-slot, (self.absolute-position.x + event.position.x) / 1px, (self.absolute-position.y + event.position.y) / 1px, DndApi.event-path(event));
                        root.drag-rejected = !root.drop_allowed(root.pane-slot, (self.absolute-position.x + event.position.x) / 1px, (self.absolute-position.y + event.position.y) / 1px, DndApi.event-path(event));
                        root.trace_drop(root.drop-trace-prefix + (root.drag-rejected ? "can-drop-rejected" : "can-drop-accepted"), DndApi.event-kind(event) == DragKind.place ? "place" : (DndApi.event-kind(event) == DragKind.folder ? "folder" : "file"), DndApi.event-path(event), (self.absolute-position.x + event.position.x) / 1px, (self.absolute-position.y + event.position.y) / 1px, root.drag-rejected, root.drag-target-path);
                        return DragAction.copy;
                    } else {
                        root.drag-active = false;
                        root.drag-rejected = false;
                        root.drag-target-path = "";
                        root.trace_drop(root.drop-trace-prefix + "can-drop-rejected:unsupported-dnd-payload", "unsupported", DndApi.event-path(event), (self.absolute-position.x + event.position.x) / 1px, (self.absolute-position.y + event.position.y) / 1px, true, "");
                        return DragAction.none;
                    }
                }
                dropped(event) => {
                    root.focus_requested(root.pane-slot);
                    root.trace_drop(root.drop-trace-prefix + "dropped", DndApi.event-kind(event) == DragKind.place ? "place" : (DndApi.event-kind(event) == DragKind.folder ? "folder" : (DndApi.event-kind(event) == DragKind.file ? "file" : "unsupported")), DndApi.event-path(event), (self.absolute-position.x + event.position.x) / 1px, (self.absolute-position.y + event.position.y) / 1px, root.drag-rejected, root.drag-target-path);
                    if (!root.drag-rejected && root.drop-ready && (DndApi.event-kind(event) == DragKind.folder || DndApi.event-kind(event) == DragKind.file || DndApi.event-kind(event) == DragKind.place) && root.prepare_transfer(root.pane-slot, DndApi.event-path(event), (self.absolute-position.x + event.position.x) / 1px, (self.absolute-position.y + event.position.y) / 1px)) {
                        root.transfer_menu_requested(root.pane-slot);
                    }
                    root.drag-active = false;
                    root.drag-rejected = false;
                    root.drag-target-path = "";
                    return DragAction.copy;
                }
            }

            SplitPaneView {
                width: parent.width;
                height: parent.height;
                dark: root.dark;
                entry-count: root.entry-count;
                entries: root.entries;
                virtual-start-index: root.virtual-start-index;
                virtual-start-column: root.virtual-start-column;
                viewport-x <=> root.viewport-x;
                zoom-level: root.zoom-level;
                selection-revision: root.selection-revision;
                interactive: root.content-interactive;
                empty-message-visible: root.empty-message-visible;
                empty-title: root.empty-title;
                empty-subtitle: root.empty-subtitle;
                show-location: root.show-location;
                drag-active: root.drag-active;
                drag-rejected: root.drag-rejected;
                drag-target-path: root.drag-target-path;
                make_drag_data(path, is-dir) => {
                    root.make_drag_data(root.pane-slot, path, is-dir)
                }
                focus_requested => { root.focus_requested(root.pane-slot); }
                view_changed => {
                    root.viewport_changed(root.pane-slot, root.viewport-x);
                    root.view_changed(root.pane-slot);
                }
                zoom_in => { root.zoom_in(root.pane-slot); }
                zoom_out => { root.zoom_out(root.pane-slot); }
                activated(path) => { root.activated(root.pane-slot, path); }
                request_select(path, toggle, range) => {
                    root.request_select(root.pane-slot, path, toggle, range);
                }
                select_rect(x1, y1, x2, y2, rows-per-column, cell-width, row-height, padding, toggle) => {
                    root.select_rect(root.pane-slot, x1, y1, x2, y2, rows-per-column, cell-width, row-height, padding, toggle);
                }
                clear_selection => { root.clear_selection(root.pane-slot); }
                request_context_menu(path, name, size, modified, is-dir, x, y) => {
                    root.request_context_menu(root.pane-slot, path, name, size, modified, is-dir, x, y);
                }
                request_blank_context_menu(x, y) => {
                    root.request_blank_context_menu(root.pane-slot, x, y);
                }
                navigate_back => { root.go_back(root.pane-slot); }
                navigate_forward => { root.go_forward(root.pane-slot); }
            }
        }

        StatusBar {
            horizontal-stretch: 1;
            height: root.status-bar-height;
            dark: root.dark;
            status: root.status;
            selected-count: root.selected-count;
            selected-status: root.selected-status;
            external-edit-active: root.external-edit-active;
            external-edit-status: root.external-edit-status;
            undo-available: root.undo-available;
            undo-label: root.undo-label;
            chooser-mode: root.chooser-mode;
            chooser-select-directories: root.chooser-select-directories;
            chooser-save-mode: root.chooser-save-mode;
            chooser-accept-label: root.chooser-accept-label;
            selected-path: root.selected-path;
            chooser-filter-count: root.chooser-filter-count;
            chooser-filter-label: root.chooser-filter-label;
            chooser-choices: root.chooser-choices;
            chooser-save-name <=> root.chooser-save-name;
            save_focus_changed(focused) => { root.save_focus_changed(root.pane-slot, focused); }
            commit_external_edit => { root.commit_external_edit(root.pane-slot); }
            discard_external_edit => { root.discard_external_edit(root.pane-slot); }
            undo_last_operation => { root.undo_last_operation(); }
            chooser_accept(value) => { root.chooser_accept(value); }
            chooser_filter_requested(x, y) => { root.chooser_filter_requested(root.pane-slot, x, y); }
            chooser_choice_requested(index, x, y) => {
                root.chooser_choice_requested(root.pane-slot, index, x, y);
            }
        }
    }
}

component PaneSlot inherits FilePane {
    focus_requested(slot) => { PaneRouting.focus(slot); }
    path_submitted(slot, path) => { PaneRouting.path-submitted(slot, path); }
    go_back(slot) => { PaneRouting.go-back(slot); }
    go_forward(slot) => { PaneRouting.go-forward(slot); }
    search_submitted(query) => { PaneRouting.search-submitted(query); }
    cancel_search => { PaneRouting.cancel-search(); }
    search_filters_changed(kind, modified, size) => {
        PaneRouting.search-filters-changed(kind, modified, size);
    }
    search_close_requested => { PaneRouting.search-close-requested(); }
    view_changed(slot) => { PaneRouting.view-changed(slot); }
    activated(slot, path) => { PaneRouting.activated(slot, path); }
    request_select(slot, path, toggle, range) => {
        PaneRouting.request-select(slot, path, toggle, range);
    }
    select_rect(slot, x1, y1, x2, y2, rows-per-column, cell-width, row-height, padding, toggle) => {
        PaneRouting.select-rect(slot, x1, y1, x2, y2, rows-per-column, cell-width, row-height, padding, toggle);
    }
    clear_selection(slot) => { PaneRouting.clear-selection(slot); }
    request_context_menu(slot, path, name, size, modified, is-dir, x, y) => {
        PaneRouting.request-context-menu(slot, path, name, size, modified, is-dir, x, y);
    }
    request_blank_context_menu(slot, x, y) => {
        PaneRouting.request-blank-context-menu(slot, x, y);
    }
    zoom_in(slot) => { PaneRouting.zoom-in(slot); }
    zoom_out(slot) => { PaneRouting.zoom-out(slot); }
    drop_target_path(slot, x, y, source) => {
        PaneRouting.drop-target-path(slot, x, y, source)
    }
    drop_allowed(slot, x, y, source) => {
        PaneRouting.drop-allowed(slot, x, y, source)
    }
    prepare_transfer(slot, source, x, y) => {
        PaneRouting.prepare-transfer(slot, source, x, y)
    }
    transfer_menu_requested(slot) => { PaneRouting.transfer-menu-requested(slot); }
    trace_drop(action, kind, path, x, y, rejected, target) => {
        PaneRouting.trace-drop(action, kind, path, x, y, rejected, target);
    }
    save_focus_changed(slot, focused) => { PaneRouting.save-focus-changed(slot, focused); }
    commit_external_edit(slot) => { PaneRouting.commit-external-edit(slot); }
    discard_external_edit(slot) => { PaneRouting.discard-external-edit(slot); }
    undo_last_operation => { PaneRouting.undo-last-operation(); }
    chooser_accept(value) => { PaneRouting.chooser-accept(value); }
    chooser_filter_requested(slot, x, y) => { PaneRouting.chooser-filter-requested(slot, x, y); }
    chooser_choice_requested(slot, index, x, y) => {
        PaneRouting.chooser-choice-requested(slot, index, x, y);
    }
    make_drag_data(slot, path, is-dir) => {
        is-dir ? DndApi.make-drag-folder(path) : DndApi.make-drag-file(path)
    }
}

component PaneSlotSurface inherits Rectangle {
    in property <PaneSlotData> pane;
    in property <bool> focused: false;
    in property <bool> dark-mode;
    in property <color> pane-shell-base-color;
    in property <length> pane-path-bar-height;
    in property <length> pane-status-bar-height;
    in-out property <string> pane-search-query;
    in-out property <bool> pane-recursive-search;
    in-out property <int> pane-search-kind-filter;
    in-out property <int> pane-search-modified-filter;
    in-out property <int> pane-search-size-filter;
    in-out property <string> pane-chooser-save-name;

    callback path_text_changed(int, string);
    callback path_focus_changed(int, bool);
    callback viewport_changed(int, float);

    private property <string> live-path-text: root.pane.path_text;
    private property <bool> live-path-focused: root.pane.path_focused;
    private property <int> live-slot: root.pane.slot;
    private property <string> live-current-path: root.pane.current_path;
    private property <float> live-viewport-x: root.pane.viewport_x;
    private property <bool> live-drag-active: false;
    private property <bool> live-drag-rejected: false;
    private property <string> live-drag-target-path;

    background: root.pane-shell-base-color;
    clip: true;

    changed pane => {
        if (!root.live-path-focused) {
            root.live-path-text = root.pane.path_text;
        }
        root.live-path-focused = root.pane.path_focused;
        if (root.live-slot != root.pane.slot || root.live-current-path != root.pane.current_path || root.live-viewport-x != root.pane.viewport_x) {
            root.live-viewport-x = root.pane.viewport_x;
        }
        root.live-slot = root.pane.slot;
        root.live-current-path = root.pane.current_path;
    }

    PaneSlot {
        pane-slot: root.pane.slot;
        width: parent.width;
        height: parent.height;
        dark: root.dark-mode;
        shell-base-color: root.pane-shell-base-color;
        path-bar-height: root.pane-path-bar-height;
        status-bar-height: root.pane-status-bar-height;
        current-path: root.pane.current_path;
        can-go-back: root.pane.can_go_back;
        can-go-forward: root.pane.can_go_forward;
        path-text <=> root.live-path-text;
        path-focused <=> root.live-path-focused;
        search-panel-visible: root.pane.search_panel_visible;
        search-panel-height: root.pane.search_panel_visible ? (root.width < 760px ? 78px : 44px) : 0px;
        search-loading: root.pane.search_loading;
        search-filters-active: root.pane.search_filters_active;
        search-kind-label: root.pane.search_kind_label;
        search-modified-label: root.pane.search_modified_label;
        search-size-label: root.pane.search_size_label;
        search-query <=> root.pane-search-query;
        recursive-search <=> root.pane-recursive-search;
        search-kind-filter <=> root.pane-search-kind-filter;
        search-modified-filter <=> root.pane-search-modified-filter;
        search-size-filter <=> root.pane-search-size-filter;
        content-interactive: root.pane.content_interactive;
        drop-ready: root.pane.drop_ready;
        drop-trace-prefix: root.pane.drop_trace_prefix;
        entry-count: root.pane.entry_count;
        entries: root.pane.entries;
        virtual-start-index: root.pane.virtual_start_index;
        virtual-start-column: root.pane.virtual_start_column;
        viewport-x <=> root.live-viewport-x;
        zoom-level: root.pane.zoom_level;
        selection-revision: root.pane.selection_revision;
        show-location: root.pane.show_location;
        drag-active <=> root.live-drag-active;
        drag-rejected <=> root.live-drag-rejected;
        drag-target-path <=> root.live-drag-target-path;
        empty-message-visible: root.pane.empty_message_visible;
        empty-title: root.pane.empty_title;
        empty-subtitle: root.pane.empty_subtitle;
        status: root.pane.status;
        selected-count: root.pane.selected_count;
        selected-status: root.pane.selected_status;
        external-edit-active: root.pane.external_edit_active;
        external-edit-status: root.pane.external_edit_status;
        undo-available: root.focused && root.pane.undo_available;
        undo-label: root.pane.undo_label;
        chooser-mode: root.focused && root.pane.chooser_mode;
        chooser-select-directories: root.pane.chooser_select_directories;
        chooser-save-mode: root.pane.chooser_save_mode;
        chooser-accept-label: root.pane.chooser_accept_label;
        selected-path: root.focused ? root.pane.focused_selected_path : "";
        chooser-filter-count: root.pane.chooser_filter_count;
        chooser-filter-label: root.pane.chooser_filter_label;
        chooser-choices: root.pane.chooser_choices;
        chooser-save-name <=> root.pane-chooser-save-name;
        path_text_changed(slot, text) => { root.path_text_changed(slot, text); }
        path_focus_changed(slot, focused) => { root.path_focus_changed(slot, focused); }
        viewport_changed(slot, viewport-x) => {
            root.viewport_changed(slot, viewport-x);
        }
    }
}

export component AppWindow inherits Window {
    in-out property <string> current_path;
    in-out property <string> items_path;
    in property <string> current_name;
    in property <string> status;
    in property <bool> chooser_mode;
