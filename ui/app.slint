    in-out property <string> transfer_target_path;
    in-out property <string> transfer_target_label;
    in-out property <float> transfer_menu_x: 0;
    in-out property <float> transfer_menu_y: 0;
    private property <bool> place_drag_active: false;
    private property <int> place_drag_from: -1;
    private property <int> place_drag_slot: 0;
    private property <string> place_drag_label;
    private property <string> place_drag_marker;
    private property <string> place_drag_target_path;
    private property <string> place_drag_target_label;
    private property <bool> place_drag_rejected: false;
    private property <length> place_drag_x: 0px;
    private property <length> place_drag_y: 0px;
    private property <length> place_list_y: 0px;
    private property <bool> search-input-focused: false;
    private property <bool> chooser-save-input-focused: false;
    private property <bool> transient-popup-open: root.context-menu-open || root.rename-place-open || root.transfer-menu-open || root.transfer_conflict_open || MenuLifecycle.open-with-open || MenuLifecycle.create-new-open || MenuLifecycle.service-menu-open || root.chooser-choice-menu-open || root.chooser-filter-menu-open || root.custom-open-with-open || root.service-policy-open || root.new-folder-open || root.new-file-open || root.rename-entry-open || root.properties-open || root.privileged_prompt_open || root.trash-confirm-open;
    private property <bool> file-operation-shortcuts-blocked: root.search-input-focused || root.chooser-save-input-focused || root.transient-popup-open;

    callback go_home();
    callback go_back();
    callback go_forward();
    callback go_parent();
