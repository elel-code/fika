    private property <length> context-blank-menu-width: 220px;
    private property <bool> context-default-open-visible: root.default_open_app_name != "" && root.open_with_path == root.context-menu-path;
    private property <bool> context-add-place-visible: root.context-menu-kind == 4 ? (root.current_path != "" && !root.is_place(root.current_path)) : (root.context-menu-is-dir && !root.is_place(root.context-menu-path));
    private property <length> child-menu-gap: 3px;
    private property <bool> rename-place-open: false;
    private property <int> rename-place-index: -1;
    private property <string> rename-place-label;
    in-out property <bool> privileged_prompt_open: false;
    in-out property <string> privileged_prompt_title;
    in-out property <string> privileged_prompt_message;
    in-out property <string> privileged_prompt_detail;
    private property <bool> trash-confirm-open: false;
    private property <string> trash-confirm-action;
    private property <string> trash-confirm-path;
    private property <string> trash-confirm-title;
    private property <string> trash-confirm-message;
    private property <string> trash-confirm-detail;
    private property <string> trash-confirm-accept-label;
