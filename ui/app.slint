    private property <bool> chooser-save-input-focused: false;
    private property <bool> transient-popup-open: root.context-menu-open || root.rename-place-open || root.transfer-menu-open || root.transfer_conflict_open || MenuLifecycle.open-with-open || MenuLifecycle.create-new-open || root.chooser-choice-menu-open || root.chooser-filter-menu-open || root.custom-open-with-open || root.new-folder-open || root.new-file-open || root.rename-entry-open || root.properties-open || root.privileged_prompt_open || root.trash-confirm-open;
    private property <bool> file-operation-shortcuts-blocked: root.left_pane_path_focused || root.inactive_pane_path_focused || root.search-input-focused || root.chooser-save-input-focused || root.context-menu-open || MenuLifecycle.open-with-open || MenuLifecycle.create-new-open || root.transfer-menu-open || root.transfer_conflict_open || root.rename-place-open || root.new-folder-open || root.new-file-open || root.rename-entry-open || root.properties-open || root.privileged_prompt_open || root.trash-confirm-open || root.chooser-choice-menu-open || root.chooser-filter-menu-open || root.custom-open-with-open;

