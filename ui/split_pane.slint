import { ItemViewEntry } from "models.slint";

export component SplitPaneView inherits Rectangle {
    in property <bool> dark;
    in property <int> entry-count;
    in property <[ItemViewEntry]> entries;
    in property <int> virtual-start-column;
    in-out property <float> viewport-x;
    in property <int> item-view-rows-per-column: 1;
    in property <float> item-view-cell-width: 1;
    in property <float> item-view-row-height: 1;
    in property <float> item-view-padding: 14;
    in property <float> item-view-content-width: 1;
    in property <float> item-view-virtual-slice-width: 1;
    in property <float> item-view-scroll-max-x: 0;
    in property <int> selection-revision;
    in property <bool> interactive: true;
    in property <bool> empty-message-visible: true;
    in property <string> empty-title: "This folder is empty";
    in property <string> empty-subtitle: "";
    in property <bool> show-location: false;
    in property <bool> drag-active: false;
    in property <bool> drag-rejected: false;
    in property <string> drag-target-path;
    callback view_changed();
    callback focus_requested();
    callback item_pressed(float, float, bool, bool) -> bool;
    callback item_activated(float, float);
    callback item_context_menu(float, float, length, length) -> bool;
    callback blank_pressed(float, float, int, float, float, float, bool);
    callback blank_moved(float, float) -> bool;
    callback blank_released(float, float);
    callback blank_cancelled();
    callback request_blank_context_menu(length, length);
    callback navigate_back();
    callback navigate_forward();
    callback zoom_in();
    callback zoom_out();
    pure callback make_drag_data_at(float, float) -> data-transfer;

    clip: true;

    private property <length> preview-padding: max(0, root.item-view-padding) * 1px;
    private property <length> cell-width: max(1, root.item-view-cell-width) * 1px;
    private property <length> row-height: max(1, root.item-view-row-height) * 1px;
    private property <color> selection-border-color: root.dark ? #51a9d4 : #2b86b7;
    private property <color> drop-border-color: root.dark ? #f59e0b : #d97706;
    private property <color> drop-background-color: root.dark ? #3a2a12 : #fff7dd;
    private property <color> selected-background-color: root.dark ? #223f4f : #e4f0f8;
    private property <color> metadata-group-color: root.dark ? #9bc7ec : #2b6f9f;
    private property <color> metadata-location-color: root.dark ? #9aa5af : #697684;
    private property <color> title-color: root.dark ? #edf2f7 : #1f2933;
    private property <int> rows-per-column: max(1, root.item-view-rows-per-column);
    private property <length> viewport-content-width: max(1px, root.item-view-content-width * 1px);
    private property <length> virtual-slice-width: max(1px, root.item-view-virtual-slice-width * 1px);
    private property <float> scroll-max-x: max(0, root.item-view-scroll-max-x);
    private property <float> pan-target-viewport-x: 0;
    private property <bool> scrollbar-visible: root.entry-count > 0 && root.scroll-max-x > 0;
    private property <length> scrollbar-height: 10px;
    private property <length> scrollbar-track-margin: 8px;
    private property <length> scrollbar-track-width: max(1px, root.width - 2 * root.scrollbar-track-margin);
    private property <length> scrollbar-thumb-width: root.scrollbar-visible ? max(34px, min(root.scrollbar-track-width, root.scrollbar-track-width * root.width / max(root.width, root.viewport-content-width))) : 0px;
    private property <length> scrollbar-thumb-travel: max(1px, root.scrollbar-track-width - root.scrollbar-thumb-width);
    private property <length> scrollbar-thumb-track-x: root.scroll-max-x <= 0 ? 0px : root.scrollbar-thumb-travel * root.viewport-x / root.scroll-max-x;
    private property <float> scrollbar-drag-start-viewport-x: 0;
    private property <length> scrollbar-drag-press-x: 0px;
    private property <bool> scrollbar-drag-active: false;
    private property <bool> selection-rect-active: false;
    private property <bool> selection-rect-pending: false;
    private property <bool> selection-rect-toggle: false;
    private property <length> selection-rect-start-x: 0px;
    private property <length> selection-rect-start-y: 0px;
    private property <length> selection-rect-current-x: 0px;
    private property <length> selection-rect-current-y: 0px;
    private property <length> item-pointer-abs-x: -1px;
    private property <length> item-pointer-abs-y: -1px;

    function set-viewport-x(raw: float) {
        root.pan-target-viewport-x = root.entry-count == 0 ? 0 : root.stable-viewport-x(raw);
        if (root.pan-target-viewport-x != root.viewport-x) {
            root.viewport-x = root.pan-target-viewport-x;
            root.view_changed();
        }
    }

    function pan-horizontal(delta: length) {
        root.set-viewport-x(root.viewport-x + delta / 1px);
    }

    function stable-viewport-x(raw: float) -> float {
        return floor(max(0, min(root.scroll-max-x, raw)) + 0.5);
    }

    function viewport-x-from-scrollbar-thumb(raw-thumb-x: length) -> float {
        return root.scroll-max-x <= 0 ? 0 : root.stable-viewport-x(max(0, min(root.scrollbar-thumb-travel / 1px, raw-thumb-x / 1px)) / max(1, root.scrollbar-thumb-travel / 1px) * root.scroll-max-x);
    }

    function scroll-pan-delta(delta-x: length, delta-y: length) -> length {
        return (delta-x < 0px ? -delta-x : delta-x) > (delta-y < 0px ? -delta-y : delta-y) ? -delta-x : -delta-y;
    }

    function handle-scroll(delta-x: length, delta-y: length, control: bool) {
        if (control && delta-y < 0px) {
            root.focus_requested();
            root.zoom_out();
        } else if (control && delta-y > 0px) {
            root.focus_requested();
            root.zoom_in();
        } else {
            root.pan-horizontal(root.scroll-pan-delta(delta-x, delta-y));
        }
    }

    function set-item-pointer-abs(x: length, y: length) {
        root.item-pointer-abs-x = x;
        root.item-pointer-abs-y = y;
    }

    function clear-item-pointer-abs() {
        root.item-pointer-abs-x = -1px;
        root.item-pointer-abs-y = -1px;
    }

    function begin-blank-press(mouse-x: length, mouse-y: length, toggle: bool) {
        root.selection-rect-pending = true;
        root.selection-rect-active = false;
        root.selection-rect-toggle = toggle;
        root.selection-rect-start-x = mouse-x + root.viewport-x * 1px;
        root.selection-rect-start-y = mouse-y;
        root.selection-rect-current-x = mouse-x + root.viewport-x * 1px;
        root.selection-rect-current-y = mouse-y;
        root.blank_pressed(
            root.selection-rect-start-x / 1px,
            root.selection-rect-start-y / 1px,
            root.rows-per-column,
            root.cell-width / 1px,
            root.row-height / 1px,
            root.preview-padding / 1px,
            root.selection-rect-toggle
        );
    }

    function relayout-visible-slice() {
        root.pan-target-viewport-x = root.entry-count == 0 ? 0 : root.stable-viewport-x(root.viewport-x);
        if (root.viewport-x != root.pan-target-viewport-x) {
            root.viewport-x = root.pan-target-viewport-x;
        }
        root.view_changed();
    }

    changed width => {
        root.relayout-visible-slice();
    }

    changed rows-per-column => {
        root.relayout-visible-slice();
    }

    background: root.dark ? #101418 : #f8fafc;

    if (root.entry-count == 0): Rectangle {
        width: parent.width;
        height: parent.height;
        background: transparent;

        TouchArea {
            width: parent.width;
            height: parent.height;
            pointer-event(event) => {
                if (event.button == PointerEventButton.back && event.kind == PointerEventKind.down) {
                    root.focus_requested();
                    root.navigate_back();
                } else if (event.button == PointerEventButton.forward && event.kind == PointerEventKind.down) {
                    root.focus_requested();
                    root.navigate_forward();
                } else if (root.interactive && event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                    root.focus_requested();
                    root.selection-rect-start-x = self.mouse-x;
                    root.selection-rect-start-y = self.mouse-y;
                    root.selection-rect-current-x = self.mouse-x;
                    root.selection-rect-current-y = self.mouse-y;
                    root.blank_pressed(self.mouse-x / 1px, self.mouse-y / 1px, 1, 1, 1, 0, false);
                } else if (root.interactive && event.button == PointerEventButton.left && event.kind == PointerEventKind.up) {
                    root.blank_released(self.mouse-x / 1px, self.mouse-y / 1px);
                } else if (root.interactive && event.kind == PointerEventKind.cancel) {
                    root.blank_cancelled();
                } else if (root.interactive && event.button == PointerEventButton.right && event.kind == PointerEventKind.down) {
                    root.focus_requested();
                    root.request_blank_context_menu(self.absolute-position.x + self.mouse-x, self.absolute-position.y + self.mouse-y);
                }
            }
        }

        if (root.empty-message-visible): VerticalLayout {
            alignment: center;

            Text {
                text: root.empty-title;
                color: root.dark ? #e8edf2 : #334155;
                font-size: 15px;
                font-weight: 600;
                horizontal-alignment: center;
            }

            if (root.empty-subtitle != ""): Text {
                text: root.empty-subtitle;
                color: root.dark ? #9aa5af : #94a3b8;
                font-size: 13px;
                horizontal-alignment: center;
            }
        }
    }

    if (root.entry-count > 0): preview := Rectangle {
        width: parent.width;
        height: parent.height;
        clip: true;

        item-drag-area := DragArea {
            width: parent.width;
            height: parent.height;
            enabled: root.interactive;
            data: root.make_drag_data_at(root.item-pointer-abs-x / 1px, root.item-pointer-abs-y / 1px);

            input-touch := TouchArea {
                width: parent.width;
                height: parent.height;

                changed has-hover => {
                    if (!self.has-hover) {
                        root.clear-item-pointer-abs();
                    }
                }

                pointer-event(event) => {
                    root.set-item-pointer-abs(self.absolute-position.x + self.mouse-x, self.absolute-position.y + self.mouse-y);
                    if (event.button == PointerEventButton.back && event.kind == PointerEventKind.down) {
                        root.focus_requested();
                        root.navigate_back();
                    } else if (event.button == PointerEventButton.forward && event.kind == PointerEventKind.down) {
                        root.focus_requested();
                        root.navigate_forward();
                    } else if (root.interactive && event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                        root.focus_requested();
                        if (root.item_pressed(root.item-pointer-abs-x / 1px, root.item-pointer-abs-y / 1px, event.modifiers.control, event.modifiers.shift)) {
                            root.selection-rect-active = false;
                            root.selection-rect-pending = false;
                        } else {
                            root.begin-blank-press(self.mouse-x, self.mouse-y, event.modifiers.control);
                        }
                    } else if (root.interactive && event.button == PointerEventButton.left && event.kind == PointerEventKind.up) {
                        if (root.selection-rect-pending) {
                            root.selection-rect-current-x = self.mouse-x + root.viewport-x * 1px;
                            root.selection-rect-current-y = self.mouse-y;
                            root.blank_released(root.selection-rect-current-x / 1px, root.selection-rect-current-y / 1px);
                        }
                        root.selection-rect-active = false;
                        root.selection-rect-pending = false;
                    } else if (root.interactive && event.kind == PointerEventKind.cancel) {
                        if (root.selection-rect-pending) {
                            root.blank_cancelled();
                        }
                        root.selection-rect-active = false;
                        root.selection-rect-pending = false;
                    } else if (root.interactive && event.button == PointerEventButton.right && event.kind == PointerEventKind.down) {
                        root.focus_requested();
                        if (!root.item_context_menu(root.item-pointer-abs-x / 1px, root.item-pointer-abs-y / 1px, root.item-pointer-abs-x, root.item-pointer-abs-y)) {
                            root.request_blank_context_menu(root.item-pointer-abs-x, root.item-pointer-abs-y);
                        }
                    }
                }

                double-clicked => {
                    if (root.interactive) {
                        root.focus_requested();
                        root.item_activated(root.item-pointer-abs-x / 1px, root.item-pointer-abs-y / 1px);
                    }
                }

                moved => {
                    root.set-item-pointer-abs(self.absolute-position.x + self.mouse-x, self.absolute-position.y + self.mouse-y);
                    if (root.interactive && self.pressed && root.selection-rect-pending) {
                        root.selection-rect-current-x = self.mouse-x + root.viewport-x * 1px;
                        root.selection-rect-current-y = self.mouse-y;
                        root.selection-rect-active = root.blank_moved(root.selection-rect-current-x / 1px, root.selection-rect-current-y / 1px);
                    }
                }

                scroll-event(event) => {
                    if (root.interactive) {
                        root.handle-scroll(event.delta-x, event.delta-y, event.modifiers.control);
                    }
                    return accept;
                }
            }

            slice-layer := Rectangle {
                x: root.preview-padding + root.virtual-start-column * root.cell-width - root.viewport-x * 1px;
                y: 0px;
                width: root.virtual-slice-width;
                height: parent.height;

                for item[index] in root.entries: Rectangle {
                    private property <int> tile-row: index.mod(root.rows-per-column);
                    private property <int> tile-column: (index - self.tile-row) / root.rows-per-column;

                    x: self.tile-column * root.cell-width;
                    y: root.preview-padding + self.tile-row * root.row-height;
                    width: item.tile_width * 1px;
                    height: item.tile_height * 1px;
                    border-radius: 7px;
                    border-width: item.selected || (root.drag-active && !root.drag-rejected && root.drag-target-path == item.path) ? 1px : 0px;
                    border-color: root.drag-active && !root.drag-rejected && root.drag-target-path == item.path ? root.drop-border-color : root.selection-border-color;
                    background: root.drag-active && !root.drag-rejected && root.drag-target-path == item.path ? root.drop-background-color : (item.selected ? root.selected-background-color : transparent);

                    Image {
                        x: item.media_x * 1px;
                        y: item.media_y * 1px;
                        width: item.media_width * 1px;
                        height: item.media_height * 1px;
                        source: item.media;
                        image-fit: contain;
                    }

                    if (root.show-location && item.group != ""): Text {
                        x: item.text_x * 1px;
                        y: item.group_y * 1px;
                        width: item.text_width * 1px;
                        height: item.metadata_line_height * 1px;
                        text: item.group;
                        color: root.metadata-group-color;
                        font-size: item.metadata_font_size * 1px;
                        font-weight: 700;
                        overflow: elide;
                        vertical-alignment: center;
                    }

                    Text {
                        x: item.text_x * 1px;
                        y: item.title_y * 1px;
                        width: item.text_width * 1px;
                        height: item.title_line_height * 1px;
                        text: item.name;
                        color: root.title-color;
                        font-size: item.title_font_size * 1px;
                        overflow: elide;
                        horizontal-alignment: root.show-location && (item.group != "" || item.location != "") ? left : center;
                        vertical-alignment: center;
                    }

                    if (root.show-location && item.location != ""): Text {
                        x: item.text_x * 1px;
                        y: item.location_y * 1px;
                        width: item.text_width * 1px;
                        height: item.metadata_line_height * 1px;
                        text: item.location;
                        color: root.metadata-location-color;
                        font-size: item.metadata_font_size * 1px;
                        overflow: elide;
                        vertical-alignment: center;
                    }
                }
            }

            if (root.selection-rect-active): Rectangle {
                x: min(root.selection-rect-start-x, root.selection-rect-current-x) - root.viewport-x * 1px;
                y: min(root.selection-rect-start-y, root.selection-rect-current-y);
                width: max(1px, max(root.selection-rect-start-x, root.selection-rect-current-x) - min(root.selection-rect-start-x, root.selection-rect-current-x));
                height: max(1px, max(root.selection-rect-start-y, root.selection-rect-current-y) - min(root.selection-rect-start-y, root.selection-rect-current-y));
                background: root.dark ? #51a9d433 : #2b86b733;
                border-width: 1px;
                border-color: root.dark ? #51a9d4 : #2b86b7;
            }
        }

        if (root.scrollbar-visible): scrollbar-track := Rectangle {
            x: root.scrollbar-track-margin;
            y: parent.height - root.scrollbar-height - 3px;
            width: root.scrollbar-track-width;
            height: root.scrollbar-height;
            border-radius: 5px;
            background: root.dark ? #222a31 : #e2e8f0;

            scrollbar-thumb := Rectangle {
                x: root.scrollbar-thumb-track-x;
                y: 2px;
                width: root.scrollbar-thumb-width;
                height: parent.height - 4px;
                border-radius: 4px;
                background: root.dark ? #6b7c8c : #94a3b8;
            }

            scrollbar-touch := TouchArea {
                width: parent.width;
                height: parent.height;
                mouse-cursor: pointer;

                pointer-event(event) => {
                    if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                        if (self.mouse-x < root.scrollbar-thumb-track-x || self.mouse-x > root.scrollbar-thumb-track-x + root.scrollbar-thumb-width) {
                            root.set-viewport-x(root.viewport-x-from-scrollbar-thumb(self.mouse-x - root.scrollbar-thumb-width / 2));
                        }
                        root.scrollbar-drag-start-viewport-x = root.viewport-x;
                        root.scrollbar-drag-press-x = self.mouse-x;
                        root.scrollbar-drag-active = true;
                    } else if (event.button == PointerEventButton.left && (event.kind == PointerEventKind.up || event.kind == PointerEventKind.cancel)) {
                        root.scrollbar-drag-active = false;
                    }
                }

                moved => {
                    if (self.pressed && root.scrollbar-drag-active) {
                        root.set-viewport-x(root.scrollbar-drag-start-viewport-x + ((self.mouse-x - root.scrollbar-drag-press-x) / 1px) / max(1, root.scrollbar-thumb-travel / 1px) * root.scroll-max-x);
                    }
                }
            }
        }
    }
}
