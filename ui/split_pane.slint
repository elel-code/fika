import { ScrollView } from "std-widgets.slint";
import { FileEntry } from "models.slint";
import { FolderGlyph } from "widgets.slint";

component SplitPreviewTile inherits Rectangle {
    in property <FileEntry> entry;
    in property <bool> dark;
    in property <int> zoom-level;
    callback focus_requested();
    callback activated(string);
    callback scrolled(length, length, bool);

    height: root.zoom-level == 0 ? 72px : (root.zoom-level == 1 ? 84px : (root.zoom-level == 2 ? 98px : (root.zoom-level == 3 ? 116px : 136px)));
    border-radius: 7px;
    background: touch-area.has-hover ? (root.dark ? #171b1f : #f0f4f8) : transparent;

    touch-area := TouchArea {
        clicked => { root.focus_requested(); }
        double-clicked => { root.activated(root.entry.path); }
        scroll-event(event) => {
            root.scrolled(event.delta-x, event.delta-y, event.modifiers.control);
            return accept;
        }
    }

    HorizontalLayout {
        padding-left: root.zoom-level < 2 ? 12px : 16px;
        padding-right: root.zoom-level < 2 ? 12px : 16px;
        spacing: root.zoom-level < 2 ? 10px : 12px;

        FolderGlyph {
            dir: root.entry.is_dir;
            dark: root.dark;
            zoom-level: root.zoom-level;
        }

        Text {
            text: root.entry.name;
            color: root.dark ? #edf2f7 : #1f2933;
            font-size: root.zoom-level == 0 ? 12px : (root.zoom-level == 1 ? 13px : (root.zoom-level == 2 ? 15px : (root.zoom-level == 3 ? 16px : 18px)));
            overflow: elide;
            vertical-alignment: center;
        }
    }
}

export component SplitPaneView inherits Rectangle {
    in property <bool> dark;
    in property <string> path;
    in property <string> name;
    in property <int> entry-count;
    in property <[FileEntry]> entries;
    in property <int> virtual-start-index;
    in property <int> virtual-start-column;
    in-out property <float> viewport-x;
    in-out property <length> viewport-offset;
    in property <int> zoom-level;
    callback view_changed();
    callback focus_requested();
    callback activated(string);
    callback zoom_in();
    callback zoom_out();

    clip: true;

    private property <length> header-height: 56px;
    private property <length> preview-padding: 14px;
    private property <length> cell-width: root.zoom-level == 0 ? 172px : (root.zoom-level == 1 ? 208px : (root.zoom-level == 2 ? 248px : (root.zoom-level == 3 ? 292px : 340px)));
    private property <length> row-height: root.zoom-level == 0 ? 78px : (root.zoom-level == 1 ? 90px : (root.zoom-level == 2 ? 104px : (root.zoom-level == 3 ? 124px : 146px)));
    private property <int> rows-per-column: max(1, floor(max(1px, root.height - root.header-height - 2 * root.preview-padding) / root.row-height));
    private property <int> column-count: max(1, ceil(root.entry-count / root.rows-per-column));
    private property <length> viewport-content-width: 2 * root.preview-padding + root.column-count * root.cell-width;
    private property <float> scroll-max-x: max(0, (root.viewport-content-width - max(1px, root.width - 1px)) / 1px);

    function pan-horizontal(delta: length) {
        root.viewport-x = root.entry-count == 0 ? 0 : max(0, min(root.scroll-max-x, root.viewport-x + delta / 1px));
        root.viewport-offset = -root.viewport-x * 1px;
        root.view_changed();
    }

    function handle-scroll(delta-x: length, delta-y: length, control: bool) {
        if (control && delta-y < 0px) {
            root.zoom_out();
        } else if (control && delta-y > 0px) {
            root.zoom_in();
        } else {
            root.pan-horizontal(-(delta-y + delta-x));
        }
    }

    background: root.dark ? #101418 : #f8fafc;

    Rectangle {
        width: 1px;
        height: parent.height;
        background: root.dark ? #222832 : #dde4ec;
    }

    Rectangle {
        x: 1px;
        width: max(1px, parent.width - 1px);
        height: root.header-height;
        background: transparent;

        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => { root.focus_requested(); }
        }

        Text {
            x: 14px;
            y: 10px;
            width: max(1px, parent.width - 28px);
            height: 18px;
            text: root.name == "" ? "Split Pane" : root.name;
            color: root.dark ? #eef3f7 : #202832;
            font-size: 13px;
            font-weight: 700;
            overflow: elide;
            vertical-alignment: center;
        }

        Text {
            x: 14px;
            y: 31px;
            width: max(1px, parent.width - 28px);
            height: 16px;
            text: root.path;
            color: root.dark ? #8f9aa5 : #667586;
            font-size: 11px;
            overflow: elide;
            vertical-alignment: center;
        }
    }

    if (root.entry-count == 0): Rectangle {
        y: root.header-height;
        width: parent.width;
        height: max(1px, parent.height - root.header-height);
        background: transparent;

        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => { root.focus_requested(); }
        }

        VerticalLayout {
            alignment: center;
            spacing: 8px;

            Text {
                text: "This split pane is empty";
                color: root.dark ? #e8edf2 : #334155;
                font-size: 14px;
                font-weight: 600;
                horizontal-alignment: center;
            }

            Text {
                text: "Click to focus it.";
                color: root.dark ? #9aa5af : #94a3b8;
                font-size: 12px;
                horizontal-alignment: center;
            }
        }
    }

    if (root.entry-count > 0): preview := ScrollView {
        x: 1px;
        y: root.header-height;
        width: max(1px, parent.width - 1px);
        height: max(1px, parent.height - root.header-height);
        horizontal-scrollbar-policy: as-needed;
        vertical-scrollbar-policy: always-off;
        viewport-width: max(parent.width, root.viewport-content-width);
        viewport-height: max(1px, parent.height - root.header-height);
        viewport-x <=> root.viewport-offset;
        viewport-y: 0px;

        changed viewport-x => {
            if (root.viewport-x != max(0, -self.viewport-x / 1px)) {
                root.viewport-x = max(0, -self.viewport-x / 1px);
                root.view_changed();
            }
        }

        TouchArea {
            width: preview.viewport-width;
            height: preview.viewport-height;
            clicked => { root.focus_requested(); }
            scroll-event(event) => {
                root.handle-scroll(event.delta-x, event.delta-y, event.modifiers.control);
                return accept;
            }
        }

        virtual-layer := Rectangle {
            x: root.preview-padding + root.virtual-start-column * root.cell-width;
            y: 0px;
            width: max(1px, root.viewport-content-width - self.x);
            height: preview.viewport-height;

            for item[index] in root.entries: SplitPreviewTile {
                property <int> local-index: index + root.virtual-start-index - root.virtual-start-column * root.rows-per-column;
                x: floor(local-index / root.rows-per-column) * root.cell-width;
                y: root.preview-padding + mod(local-index, root.rows-per-column) * root.row-height;
                width: root.cell-width - 12px;
                entry: item;
                dark: root.dark;
                zoom-level: root.zoom-level;
                focus_requested => { root.focus_requested(); }
                activated(path) => { root.activated(path); }
                scrolled(delta-x, delta-y, control) => {
                    root.handle-scroll(delta-x, delta-y, control);
                }
            }
        }
    }
}
