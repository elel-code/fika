import { ScrollView } from "std-widgets.slint";
import { FileEntry } from "models.slint";
import { FileTile } from "file_tile.slint";

export component SplitPaneView inherits Rectangle {
    in property <bool> dark;
    in property <int> entry-count;
    in property <[FileEntry]> entries;
    in property <int> virtual-start-index;
    in property <int> virtual-start-column;
    in-out property <float> viewport-x;
    in-out property <length> viewport-offset;
    in property <int> zoom-level;
    in property <int> selection-revision;
    in property <bool> interactive: true;
    in property <bool> empty-message-visible: true;
    in property <string> empty-title: "This folder is empty";
    in property <string> empty-subtitle: "";
    in property <bool> show-location: false;
    in property <bool> drag-active: false;
    in property <bool> drag-rejected: false;
    in property <string> drag-target-path;
    callback view_changed();
    callback focus_requested();
    callback activated(string);
    callback request_select(string, bool, bool);
    callback select_rect(float, float, float, float, int, float, float, float, bool);
    callback clear_selection();
    callback request_context_menu(string, string, string, string, bool, length, length);
    callback request_blank_context_menu(length, length);
    callback navigate_back();
    callback navigate_forward();
    callback zoom_in();
    callback zoom_out();
    pure callback is_selected(string) -> bool;
    pure callback make_drag_data(string, bool) -> data-transfer;

    clip: true;

    private property <length> preview-padding: 14px;
    private property <length> cell-width: root.zoom-level == 0 ? 172px : (root.zoom-level == 1 ? 208px : (root.zoom-level == 2 ? 248px : (root.zoom-level == 3 ? 292px : 340px)));
    private property <length> row-height: root.zoom-level == 0 ? 78px : (root.zoom-level == 1 ? 90px : (root.zoom-level == 2 ? 104px : (root.zoom-level == 3 ? 124px : 146px)));
    private property <int> rows-per-column: max(1, floor(max(1px, root.height - 2 * root.preview-padding) / root.row-height));
    private property <int> column-count: max(1, ceil(root.entry-count / root.rows-per-column));
    private property <length> viewport-content-width: 2 * root.preview-padding + root.column-count * root.cell-width;
    private property <int> virtual-column-count: max(1, ceil(root.entries.length / root.rows-per-column));
    private property <length> virtual-layer-width: max(1px, root.virtual-column-count * root.cell-width);
    private property <float> scroll-max-x: max(0, (root.viewport-content-width - max(1px, root.width)) / 1px);
    private property <bool> selection-rect-active: false;
    private property <bool> selection-rect-pending: false;
    private property <bool> selection-rect-toggle: false;
    private property <length> selection-rect-start-x: 0px;
    private property <length> selection-rect-start-y: 0px;
    private property <length> selection-rect-current-x: 0px;
    private property <length> selection-rect-current-y: 0px;

    function pan-horizontal(delta: length) {
        root.focus_requested();
        root.viewport-x = root.entry-count == 0 ? 0 : max(0, min(root.scroll-max-x, root.viewport-x + delta / 1px));
        root.viewport-offset = -root.viewport-x * 1px;
        root.view_changed();
    }

    function handle-scroll(delta-x: length, delta-y: length, control: bool) {
        root.focus_requested();
        if (control && delta-y < 0px) {
            root.zoom_out();
        } else if (control && delta-y > 0px) {
            root.zoom_in();
        } else {
            root.pan-horizontal(-(delta-y + delta-x));
        }
    }

    background: root.dark ? #101418 : #f8fafc;

    if (root.entry-count == 0): Rectangle {
        width: parent.width;
        height: parent.height;
        background: transparent;

        TouchArea {
            width: parent.width;
            height: parent.height;
            pointer-event(event) => {
                if (event.button == PointerEventButton.back && event.kind == PointerEventKind.down) {
                    root.focus_requested();
                    root.navigate_back();
                } else if (event.button == PointerEventButton.forward && event.kind == PointerEventKind.down) {
                    root.focus_requested();
                    root.navigate_forward();
                } else if (root.interactive && event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                    root.focus_requested();
                    root.clear_selection();
                } else if (root.interactive && event.button == PointerEventButton.right && event.kind == PointerEventKind.down) {
                    root.focus_requested();
                    root.request_blank_context_menu(self.absolute-position.x + self.mouse-x, self.absolute-position.y + self.mouse-y);
                }
            }
        }

        if (root.empty-message-visible): VerticalLayout {
            alignment: center;

            Text {
                text: root.empty-title;
                color: root.dark ? #e8edf2 : #334155;
                font-size: 15px;
                font-weight: 600;
                horizontal-alignment: center;
            }

            if (root.empty-subtitle != ""): Text {
                text: root.empty-subtitle;
                color: root.dark ? #9aa5af : #94a3b8;
                font-size: 13px;
                horizontal-alignment: center;
            }
        }
    }

    if (root.entry-count > 0): preview := ScrollView {
        width: parent.width;
        height: parent.height;
        horizontal-scrollbar-policy: as-needed;
        vertical-scrollbar-policy: always-off;
        viewport-width: max(parent.width, root.viewport-content-width);
        viewport-height: parent.height;
        viewport-x <=> root.viewport-offset;
        viewport-y: 0px;

        changed viewport-x => {
            if (root.viewport-x != max(0, -self.viewport-x / 1px)) {
                root.focus_requested();
                root.viewport-x = max(0, -self.viewport-x / 1px);
                root.view_changed();
            }
        }

        TouchArea {
            width: preview.viewport-width;
            height: preview.viewport-height;
            pointer-event(event) => {
                if (event.button == PointerEventButton.back && event.kind == PointerEventKind.down) {
                    root.focus_requested();
                    root.navigate_back();
                } else if (event.button == PointerEventButton.forward && event.kind == PointerEventKind.down) {
                    root.focus_requested();
                    root.navigate_forward();
                } else if (root.interactive && event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                    root.focus_requested();
                    root.selection-rect-pending = true;
                    root.selection-rect-active = false;
                    root.selection-rect-toggle = event.modifiers.control;
                    root.selection-rect-start-x = self.mouse-x;
                    root.selection-rect-start-y = self.mouse-y;
                    root.selection-rect-current-x = self.mouse-x;
                    root.selection-rect-current-y = self.mouse-y;
                } else if (root.interactive && event.button == PointerEventButton.left && event.kind == PointerEventKind.up) {
                    if (root.selection-rect-active) {
                        root.select_rect(
                            min(root.selection-rect-start-x, root.selection-rect-current-x) / 1px,
                            min(root.selection-rect-start-y, root.selection-rect-current-y) / 1px,
                            max(root.selection-rect-start-x, root.selection-rect-current-x) / 1px,
                            max(root.selection-rect-start-y, root.selection-rect-current-y) / 1px,
                            root.rows-per-column,
                            root.cell-width / 1px,
                            root.row-height / 1px,
                            root.preview-padding / 1px,
                            root.selection-rect-toggle
                        );
                    } else if (root.selection-rect-pending) {
                        root.clear_selection();
                    }
                    root.selection-rect-active = false;
                    root.selection-rect-pending = false;
                } else if (root.interactive && event.button == PointerEventButton.right && event.kind == PointerEventKind.down) {
                    root.focus_requested();
                    root.request_blank_context_menu(self.absolute-position.x + self.mouse-x, self.absolute-position.y + self.mouse-y);
                }
            }
            moved => {
                if (root.interactive && self.pressed && root.selection-rect-pending) {
                    root.selection-rect-current-x = self.mouse-x;
                    root.selection-rect-current-y = self.mouse-y;
                    if (!root.selection-rect-active && (self.mouse-x > root.selection-rect-start-x + 5px || self.mouse-x + 5px < root.selection-rect-start-x || self.mouse-y > root.selection-rect-start-y + 5px || self.mouse-y + 5px < root.selection-rect-start-y)) {
                        root.selection-rect-active = true;
                    }
                }
            }
            scroll-event(event) => {
                if (root.interactive) {
                    root.handle-scroll(event.delta-x, event.delta-y, event.modifiers.control);
                }
                return accept;
            }
        }

        virtual-layer := Rectangle {
            x: root.preview-padding + root.virtual-start-column * root.cell-width;
            y: 0px;
            width: root.virtual-layer-width;
            height: preview.viewport-height;

            for item[index] in root.entries: FileTile {
                drag-data-source: root.make_drag_data(item.path, item.is_dir);
                property <int> local-index: index + root.virtual-start-index - root.virtual-start-column * root.rows-per-column;
                x: floor(local-index / root.rows-per-column) * root.cell-width;
                y: root.preview-padding + mod(local-index, root.rows-per-column) * root.row-height;
                width: root.cell-width - 12px;
                entry: item;
                selected: root.selection-revision >= 0 && root.is_selected(item.path);
                dark: root.dark;
                zoom-level: root.zoom-level;
                show-location: root.show-location;
                interactive: root.interactive;
                drop-target: root.drag-active && !root.drag-rejected && root.drag-target-path == item.path;
                request_select(path, toggle, range) => {
                    root.focus_requested();
                    root.request_select(path, toggle, range);
                }
                request_context_menu(path, name, x, y) => {
                    root.focus_requested();
                    root.request_context_menu(path, name, item.size, item.modified, item.is_dir, x, y);
                }
                activated(path) => {
                    root.focus_requested();
                    root.activated(path);
                }
                navigate_back => {
                    root.focus_requested();
                    root.navigate_back();
                }
                navigate_forward => {
                    root.focus_requested();
                    root.navigate_forward();
                }
                zoom_in => {
                    root.focus_requested();
                    root.zoom_in();
                }
                zoom_out => {
                    root.focus_requested();
                    root.zoom_out();
                }
                pan_horizontal(delta) => {
                    root.pan-horizontal(delta);
                }
            }
        }

        if (root.selection-rect-active): Rectangle {
            x: min(root.selection-rect-start-x, root.selection-rect-current-x);
            y: min(root.selection-rect-start-y, root.selection-rect-current-y);
            width: max(1px, max(root.selection-rect-start-x, root.selection-rect-current-x) - min(root.selection-rect-start-x, root.selection-rect-current-x));
            height: max(1px, max(root.selection-rect-start-y, root.selection-rect-current-y) - min(root.selection-rect-start-y, root.selection-rect-current-y));
            background: root.dark ? #51a9d433 : #2b86b733;
            border-width: 1px;
            border-color: root.dark ? #51a9d4 : #2b86b7;
        }
    }
}
