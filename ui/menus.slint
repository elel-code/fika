        }
    }
}

export component TransferMenu inherits PopupSurface {
    in property <string> title;
    callback operation_selected(string);
    callback cancelled();

    VerticalLayout {
        spacing: 0px;

        MenuTitle {
            label: root.title;
            dark: root.dark;
        }

        ActionMenuRow {
            label: "Move Here";
            dark: root.dark;
            clicked => { root.operation_selected("move"); }
        }

        ActionMenuRow {
            label: "Copy Here";
            dark: root.dark;
            clicked => { root.operation_selected("copy"); }
        }

        ActionMenuRow {
            label: "Link Here";
            dark: root.dark;
            clicked => { root.operation_selected("link"); }
        }

        MenuSeparator {
            dark: root.dark;
        }

        ActionMenuRow {
            label: "Cancel";
            dark: root.dark;
            clicked => { root.cancelled(); }
        }
    }
}

export component TransferMenuLayer inherits Rectangle {
    in property <bool> menu-open;
    in property <float> menu-x;
    in property <float> menu-y;
    in property <length> window-width;
    in property <length> window-height;
    in property <length> screen-margin;
    in property <length> pointer-gap;
    in property <length> item-height: 38px;
    in property <length> separator-height: 8px;
    in property <length> title-height: 30px;
    in property <string> title;
    in property <bool> dark;
    private property <length> menu-width: 240px;
    private property <length> menu-height: root.title-height + 4 * root.item-height + root.separator-height;
    private property <length> menu-left: MenuGeometry.root_menu_left(root.window-width / 1px, root.window-height / 1px, root.menu-x, root.menu-y, root.menu-width / 1px, root.menu-height / 1px, root.screen-margin / 1px, root.pointer-gap / 1px) * 1px;
    private property <length> menu-top: MenuGeometry.root_menu_top(root.window-width / 1px, root.window-height / 1px, root.menu-x, root.menu-y, root.menu-width / 1px, root.menu-height / 1px, root.screen-margin / 1px, root.pointer-gap / 1px) * 1px;
    callback operation_selected(string);
    callback cancelled();

    background: transparent;

    if (root.menu-open): TransferMenu {
        x: root.menu-left;
        y: root.menu-top;
        width: root.menu-width;
        height: root.menu-height;
        title: root.title;
        dark: root.dark;
        operation_selected(operation) => { root.operation_selected(operation); }
        cancelled => { root.cancelled(); }
    }
}

export component PlaceContextMenu inherits PopupSurface {
    in property <string> title;
    in property <bool> builtin;
    callback open_new_window();
    callback rename_requested();
    callback remove_requested();

    VerticalLayout {
        spacing: 0px;

        MenuTitle {
            label: root.title;
            dark: root.dark;
        }

        ActionMenuRow {
            label: "Open in New Window";
            dark: root.dark;
            clicked => { root.open_new_window(); }
        }

        if (!root.builtin): MenuSeparator {
            dark: root.dark;
        }

        if (!root.builtin): ActionMenuRow {
            label: "Rename";
            dark: root.dark;
            clicked => { root.rename_requested(); }
        }

        if (!root.builtin): ActionMenuRow {
            label: "Remove";
            dark: root.dark;
            clicked => { root.remove_requested(); }
        }
    }
}

export component DeviceContextMenu inherits PopupSurface {
    in property <string> title;
    in property <bool> mounted;
    in property <bool> can-mount;
    in property <bool> can-unmount;
    in property <bool> can-eject;
    in property <string> pending-action: "";
    callback open_requested();
    callback mount_requested();
    callback unmount_requested();
    callback eject_requested();

    VerticalLayout {
        spacing: 0px;

        MenuTitle {
            label: root.title;
            dark: root.dark;
        }

        if (root.pending-action != ""): ActionMenuRow {
            label: root.pending-action == "mount" ? "Mounting..." : (root.pending-action == "unmount" ? "Unmounting..." : (root.pending-action == "eject" ? "Ejecting..." : "Working..."));
            dark: root.dark;
            enabled: false;
            clicked => { }
        }

        if (root.pending-action == "" && root.mounted): ActionMenuRow {
            label: "Open";
            dark: root.dark;
            clicked => { root.open_requested(); }
        }

        if (root.pending-action == "" && !root.mounted && root.can-mount): ActionMenuRow {
            label: "Mount";
            dark: root.dark;
            clicked => { root.mount_requested(); }
        }

        if (root.pending-action == "" && (root.can-unmount || root.can-eject)): MenuSeparator {
            dark: root.dark;
        }

        if (root.pending-action == "" && root.can-unmount): ActionMenuRow {
            label: "Unmount";
            dark: root.dark;
            clicked => { root.unmount_requested(); }
        }

        if (root.pending-action == "" && root.can-eject): ActionMenuRow {
            label: "Eject";
            dark: root.dark;
            clicked => { root.eject_requested(); }
        }

        if (root.pending-action == "" && !root.mounted && !root.can-mount && !root.can-unmount && !root.can-eject): ActionMenuRow {
            label: "No actions available";
            dark: root.dark;
            enabled: false;
            clicked => { }
        }
    }
}

export component PlacesBlankMenu inherits PopupSurface {
    in property <bool> add-current-enabled;
    callback add_current_folder();
    callback restore_defaults();

    VerticalLayout {
        spacing: 0px;

        MenuTitle {
            label: "Places";
            dark: root.dark;
        }

        ActionMenuRow {
            label: "Add Current Folder";
            dark: root.dark;
            enabled: root.add-current-enabled;
            clicked => { root.add_current_folder(); }
        }

        MenuSeparator {
            dark: root.dark;
        }

        ActionMenuRow {
            label: "Restore Defaults";
            dark: root.dark;
            clicked => { root.restore_defaults(); }
        }
    }
}

export component FileContextMenu inherits PopupSurface {
    in property <int> selected-count;
    in property <string> selected-status;
    in property <bool> is-dir;
    in property <bool> default-open-visible;
    in property <string> default-open-app-name;
    in property <bool> clipboard-has-paths;
    in property <bool> add-to-places-visible;
    in property <bool> in-trash;
    in property <[ContextServiceAction]> service-actions;
    in property <bool> service-config-visible;
    callback open_folder_with_hover(bool);
    callback open_folder_with_clicked();
    callback default_open_requested();
    callback open_with_hover(bool);
    callback open_with_clicked();
    callback paste_into_folder();
    callback add_to_places();
    callback open_terminal_here();
    callback rename_requested();
    callback duplicate_requested();
    callback cut_requested();
    callback copy_requested();
    callback copy_location_requested();
    callback properties_requested();
    callback trash_requested();
    callback restore_trash_requested();
    callback delete_permanently_requested();
    callback service_action_requested(int);
    callback service_submenu_hovered(string, length, bool);
    callback service_submenu_clicked(string, length);
    callback configure_service_actions();

    VerticalLayout {
        spacing: 0px;

        if (root.selected-count > 1): MenuTitle {
            label: root.selected-status;
            dark: root.dark;
        }

        if (root.selected-count <= 1 && root.is-dir): SubmenuMenuRow {
            label: "Open Folder With";
            dark: root.dark;
            hovered(is-hovered) => { root.open_folder_with_hover(is-hovered); }
            clicked => { root.open_folder_with_clicked(); }
        }

        if (root.selected-count <= 1 && !root.is-dir && root.default-open-visible): ActionMenuRow {
            label: "Open With " + root.default-open-app-name;
            dark: root.dark;
            clicked => { root.default_open_requested(); }
        }

        if (root.selected-count <= 1 && !root.is-dir): SubmenuMenuRow {
            label: "Open With";
            dark: root.dark;
            hovered(is-hovered) => { root.open_with_hover(is-hovered); }
            clicked => { root.open_with_clicked(); }
        }

        for action in root.service-actions: ServiceActionMenuRow {
            action: action;
            dark: root.dark;
            action_requested(index) => { root.service_action_requested(index); }
            submenu_hovered(group, row-y, is-hovered) => {
                root.service_submenu_hovered(group, row-y, is-hovered);
            }
            submenu_clicked(group, row-y) => {
                root.service_submenu_clicked(group, row-y);
            }
        }

        if (root.service-config-visible): ActionMenuRow {
            label: "Configure Service Actions...";
            dark: root.dark;
            clicked => { root.configure_service_actions(); }
        }

        if (root.selected-count <= 1): MenuSeparator {
            dark: root.dark;
        }

        if (root.selected-count <= 1 && root.is-dir): PasteMenuRow {
            label: "Paste Into Folder";
            dark: root.dark;
            enabled: root.clipboard-has-paths;
            paste_requested => { root.paste_into_folder(); }
        }

        if (root.selected-count <= 1 && root.is-dir && root.add-to-places-visible): ActionMenuRow {
            label: "Add to Places";
            dark: root.dark;
            clicked => { root.add_to_places(); }
        }

        if (root.selected-count <= 1 && root.is-dir && !root.in-trash): ActionMenuRow {
            label: "Open Terminal Here";
            dark: root.dark;
            clicked => { root.open_terminal_here(); }
        }

        if (root.selected-count <= 1): ActionMenuRow {
            label: "Rename";
            dark: root.dark;
            clicked => { root.rename_requested(); }
        }

        if (root.selected-count <= 1): ActionMenuRow {
            label: "Duplicate Here";
            dark: root.dark;
            clicked => { root.duplicate_requested(); }
        }

        if (root.selected-count <= 1): CutCopyMenuRows {
            dark: root.dark;
            cut_requested => { root.cut_requested(); }
            copy_requested => { root.copy_requested(); }
        }

        if (root.selected-count <= 1): ActionMenuRow {
            label: "Copy Location";
            dark: root.dark;
            clicked => { root.copy_location_requested(); }
        }

        if (root.selected-count <= 1): ActionMenuRow {
            label: "Properties";
            dark: root.dark;
            clicked => { root.properties_requested(); }
        }

        if (root.selected-count <= 1): MenuSeparator {
            dark: root.dark;
        }

        if (root.selected-count > 1): CutCopyMenuRows {
            dark: root.dark;
            cut_requested => { root.cut_requested(); }
            copy_requested => { root.copy_requested(); }
        }

        if (root.selected-count > 1): MenuSeparator {
            dark: root.dark;
        }

        if (!root.in-trash): ActionMenuRow {
            label: root.selected-count > 1 ? "Move Selected to Trash" : "Move to Trash";
            shortcut: "Delete";
            dark: root.dark;
            clicked => { root.trash_requested(); }
        }

        if (root.in-trash): ActionMenuRow {
            label: root.selected-count > 1 ? "Restore Selected From Trash" : "Restore From Trash";
            dark: root.dark;
            clicked => { root.restore_trash_requested(); }
        }

        if (root.in-trash): ActionMenuRow {
            label: root.selected-count > 1 ? "Delete Selected Permanently" : "Delete Permanently";
            dark: root.dark;
            clicked => { root.delete_permanently_requested(); }
        }
    }
}

export component ViewportContextMenu inherits PopupSurface {
    in property <bool> clipboard-has-paths;
    in property <bool> clipboard-cut;
    in property <bool> in-trash;
    in property <[ContextServiceAction]> service-actions;
    in property <bool> service-config-visible;
    callback create_new_hover(bool);
    callback create_new_clicked();
    callback select_all_requested();
    callback paste_requested();
    callback empty_trash_requested();
    callback open_folder_with_hover(bool);
    callback open_folder_with_clicked();
    callback open_terminal_here();
    callback service_action_requested(int);
    callback service_submenu_hovered(string, length, bool);
    callback service_submenu_clicked(string, length);
    callback configure_service_actions();

    VerticalLayout {
        spacing: 0px;

        if (root.in-trash): ActionMenuRow {
            label: "Empty Trash";
            dark: root.dark;
            clicked => { root.empty_trash_requested(); }
        }

        if (!root.in-trash): SubmenuMenuRow {
            label: "Create New";
            dark: root.dark;
            hovered(is-hovered) => { root.create_new_hover(is-hovered); }
            clicked => { root.create_new_clicked(); }
        }

        MenuSeparator {
            dark: root.dark;
        }

        ActionMenuRow {
            label: "Select All";
            shortcut: "Ctrl+A";
            dark: root.dark;
            clicked => { root.select_all_requested(); }
        }

        if (!root.in-trash): PasteMenuRow {
            label: root.clipboard-cut ? "Paste Moved Items" : "Paste";
            dark: root.dark;
            enabled: root.clipboard-has-paths;
            paste_requested => { root.paste_requested(); }
        }

        if (!root.in-trash): SubmenuMenuRow {
            label: "Open Folder With";
            dark: root.dark;
            hovered(is-hovered) => { root.open_folder_with_hover(is-hovered); }
            clicked => { root.open_folder_with_clicked(); }
        }

        if (!root.in-trash): ActionMenuRow {
            label: "Open Terminal Here";
            dark: root.dark;
            clicked => { root.open_terminal_here(); }
        }

        for action in root.service-actions: ServiceActionMenuRow {
            action: action;
            dark: root.dark;
            action_requested(index) => { root.service_action_requested(index); }
            submenu_hovered(group, row-y, is-hovered) => {
                root.service_submenu_hovered(group, row-y, is-hovered);
            }
            submenu_clicked(group, row-y) => {
                root.service_submenu_clicked(group, row-y);
            }
        }

        if (root.service-config-visible): ActionMenuRow {
            label: "Configure Service Actions...";
            dark: root.dark;
            clicked => { root.configure_service_actions(); }
        }
    }
}

export component RootContextMenuLayer inherits Rectangle {
    in property <bool> menu-open;
    in property <int> menu-kind;
    in property <length> menu-x;
    in property <length> menu-y;
    in property <length> window-width;
    in property <length> window-height;
    in property <length> screen-margin;
    in property <length> pointer-gap;
    in property <length> file-menu-width;
    in property <length> place-menu-width;
    in property <length> blank-menu-width;
    in property <length> item-height: 38px;
    in property <length> separator-height: 8px;
    in property <length> title-height: 30px;
    in property <bool> dark;
    in property <int> selected-count;
    in property <string> selected-status;
    in property <bool> is-dir;
    in property <bool> default-open-visible;
    in property <string> default-open-app-name;
    in property <bool> clipboard-has-paths;
    in property <bool> clipboard-cut;
    in property <bool> add-to-places-visible;
    in property <bool> in-trash;
    in property <string> place-title;
    in property <bool> place-builtin;
    in property <string> device-title;
    in property <bool> device-mounted;
    in property <bool> device-can-mount;
    in property <bool> device-can-unmount;
    in property <bool> device-can-eject;
    in property <string> device-pending-action: "";
    in property <[ContextServiceAction]> service-actions;
    in property <int> service-action-rows;
    in property <int> service-submenu-rows;
    in property <bool> service-config-visible;
    out property <length> active-menu-left: MenuGeometry.root_menu_left(root.window-width / 1px, root.window-height / 1px, root.menu-x / 1px, root.menu-y / 1px, root.active-menu-width / 1px, root.active-menu-height / 1px, root.screen-margin / 1px, root.pointer-gap / 1px) * 1px;
    out property <length> active-menu-top: MenuGeometry.root_menu_top(root.window-width / 1px, root.window-height / 1px, root.menu-x / 1px, root.menu-y / 1px, root.active-menu-width / 1px, root.active-menu-height / 1px, root.screen-margin / 1px, root.pointer-gap / 1px) * 1px;
    out property <length> active-menu-width: (root.menu-kind == 2 || root.menu-kind == 5) ? root.place-menu-width : ((root.menu-kind == 3 || root.menu-kind == 4) ? root.blank-menu-width : root.file-menu-width);
    out property <length> active-menu-height: MenuGeometry.context_menu_height(root.menu-kind, root.selected-count, root.is-dir, root.default-open-visible, root.add-to-places-visible, root.clipboard-has-paths, root.in-trash, root.place-builtin, root.device-mounted, root.metrics-device-pending, root.device-can-mount, root.device-can-unmount, root.device-can-eject, root.service-action-rows, root.service-submenu-rows, root.item-height / 1px, root.separator-height / 1px, root.title-height / 1px) * 1px;
    private property <bool> metrics-device-pending: root.menu-kind == 5 && root.device-pending-action != "";
    private property <length> open-with-row-y: root.active-menu-top + MenuGeometry.context_menu_open_with_row_offset(root.menu-kind, root.selected-count, root.is-dir, root.default-open-visible, root.add-to-places-visible, root.clipboard-has-paths, root.in-trash, root.place-builtin, root.device-mounted, root.metrics-device-pending, root.device-can-mount, root.device-can-unmount, root.device-can-eject, root.service-action-rows, root.service-submenu-rows, root.item-height / 1px, root.separator-height / 1px, root.title-height / 1px) * 1px;
    private property <length> create-new-row-y: root.active-menu-top + MenuGeometry.context_menu_create_new_row_offset(root.menu-kind, root.selected-count, root.is-dir, root.default-open-visible, root.add-to-places-visible, root.clipboard-has-paths, root.in-trash, root.place-builtin, root.device-mounted, root.metrics-device-pending, root.device-can-mount, root.device-can-unmount, root.device-can-eject, root.service-action-rows, root.service-submenu-rows, root.item-height / 1px, root.separator-height / 1px, root.title-height / 1px) * 1px;
    callback file_open_folder_with_hover(length, bool);
    callback file_open_folder_with_clicked(length);
    callback file_default_open_requested();
    callback file_open_with_hover(length, bool);
    callback file_open_with_clicked(length);
    callback file_paste_into_folder();
    callback file_add_to_places();
    callback file_open_terminal_here();
    callback file_rename_requested();
    callback file_duplicate_requested();
    callback file_cut_requested();
    callback file_copy_requested();
    callback file_copy_location_requested();
    callback file_properties_requested();
    callback file_trash_requested();
    callback file_restore_trash_requested();
    callback file_delete_permanently_requested();
    callback file_service_action_requested(int);
    callback file_service_submenu_hovered(string, length, bool);
    callback file_service_submenu_clicked(string, length);
    callback file_configure_service_actions();
    callback place_open_new_window();
    callback place_rename_requested();
    callback place_remove_requested();
    callback device_open_requested();
    callback device_mount_requested();
    callback device_unmount_requested();
    callback device_eject_requested();
    callback places_blank_add_current_folder();
    callback places_blank_restore_defaults();
    callback viewport_create_new_hover(length, bool);
    callback viewport_create_new_clicked(length);
    callback viewport_select_all_requested();
    callback viewport_paste_requested();
    callback viewport_empty_trash_requested();
    callback viewport_open_folder_with_hover(length, bool);
    callback viewport_open_folder_with_clicked(length);
    callback viewport_open_terminal_here();
    callback viewport_service_action_requested(int);
    callback viewport_service_submenu_hovered(string, length, bool);
    callback viewport_service_submenu_clicked(string, length);
    callback viewport_configure_service_actions();

    background: transparent;

    if (root.menu-open && root.menu-kind == 1): FileContextMenu {
        x: root.active-menu-left;
        y: root.active-menu-top;
        width: root.file-menu-width;
        height: root.active-menu-height;
        dark: root.dark;
        selected-count: root.selected-count;
        selected-status: root.selected-status;
        is-dir: root.is-dir;
        default-open-visible: root.default-open-visible;
        default-open-app-name: root.default-open-app-name;
        clipboard-has-paths: root.clipboard-has-paths;
        add-to-places-visible: root.add-to-places-visible;
        in-trash: root.in-trash;
        service-actions: root.service-actions;
        service-config-visible: root.service-config-visible;
        open_folder_with_hover(is-hovered) => { root.file_open_folder_with_hover(root.active-menu-top, is-hovered); }
        open_folder_with_clicked => { root.file_open_folder_with_clicked(root.active-menu-top); }
        default_open_requested => { root.file_default_open_requested(); }
        open_with_hover(is-hovered) => { root.file_open_with_hover(root.open-with-row-y, is-hovered); }
        open_with_clicked => { root.file_open_with_clicked(root.open-with-row-y); }
        paste_into_folder => { root.file_paste_into_folder(); }
        add_to_places => { root.file_add_to_places(); }
        open_terminal_here => { root.file_open_terminal_here(); }
        rename_requested => { root.file_rename_requested(); }
        duplicate_requested => { root.file_duplicate_requested(); }
        cut_requested => { root.file_cut_requested(); }
        copy_requested => { root.file_copy_requested(); }
        copy_location_requested => { root.file_copy_location_requested(); }
        properties_requested => { root.file_properties_requested(); }
        trash_requested => { root.file_trash_requested(); }
        restore_trash_requested => { root.file_restore_trash_requested(); }
        delete_permanently_requested => { root.file_delete_permanently_requested(); }
        service_action_requested(index) => { root.file_service_action_requested(index); }
        service_submenu_hovered(group, row-y, is-hovered) => {
            root.file_service_submenu_hovered(group, row-y, is-hovered);
        }
        service_submenu_clicked(group, row-y) => {
            root.file_service_submenu_clicked(group, row-y);
        }
        configure_service_actions => { root.file_configure_service_actions(); }
    }

    if (root.menu-open && root.menu-kind == 2): PlaceContextMenu {
        x: root.active-menu-left;
        y: root.active-menu-top;
        width: root.place-menu-width;
        height: root.active-menu-height;
        title: root.place-title;
        dark: root.dark;
        builtin: root.place-builtin;
        open_new_window => { root.place_open_new_window(); }
        rename_requested => { root.place_rename_requested(); }
        remove_requested => { root.place_remove_requested(); }
    }

    if (root.menu-open && root.menu-kind == 5): DeviceContextMenu {
        x: root.active-menu-left;
        y: root.active-menu-top;
        width: root.place-menu-width;
        height: root.active-menu-height;
        title: root.device-title;
        dark: root.dark;
        mounted: root.device-mounted;
        can-mount: root.device-can-mount;
        can-unmount: root.device-can-unmount;
        can-eject: root.device-can-eject;
        pending-action: root.device-pending-action;
        open_requested => { root.device_open_requested(); }
        mount_requested => { root.device_mount_requested(); }
        unmount_requested => { root.device_unmount_requested(); }
        eject_requested => { root.device_eject_requested(); }
    }

    if (root.menu-open && root.menu-kind == 4): PlacesBlankMenu {
        x: root.active-menu-left;
        y: root.active-menu-top;
        width: root.blank-menu-width;
        height: root.active-menu-height;
        dark: root.dark;
        add-current-enabled: root.add-to-places-visible;
        add_current_folder => { root.places_blank_add_current_folder(); }
        restore_defaults => { root.places_blank_restore_defaults(); }
    }

    if (root.menu-open && root.menu-kind == 3): ViewportContextMenu {
        x: root.active-menu-left;
        y: root.active-menu-top;
        width: root.blank-menu-width;
        height: root.active-menu-height;
        dark: root.dark;
        clipboard-has-paths: root.clipboard-has-paths;
        clipboard-cut: root.clipboard-cut;
        in-trash: root.in-trash;
        service-actions: root.service-actions;
        service-config-visible: root.service-config-visible;
        create_new_hover(is-hovered) => { root.viewport_create_new_hover(root.create-new-row-y, is-hovered); }
        create_new_clicked => { root.viewport_create_new_clicked(root.create-new-row-y); }
        select_all_requested => { root.viewport_select_all_requested(); }
        paste_requested => { root.viewport_paste_requested(); }
        empty_trash_requested => { root.viewport_empty_trash_requested(); }
        open_folder_with_hover(is-hovered) => { root.viewport_open_folder_with_hover(root.open-with-row-y, is-hovered); }
        open_folder_with_clicked => { root.viewport_open_folder_with_clicked(root.open-with-row-y); }
        open_terminal_here => { root.viewport_open_terminal_here(); }
        service_action_requested(index) => { root.viewport_service_action_requested(index); }
        service_submenu_hovered(group, row-y, is-hovered) => {
            root.viewport_service_submenu_hovered(group, row-y, is-hovered);
        }
        service_submenu_clicked(group, row-y) => {
            root.viewport_service_submenu_clicked(group, row-y);
        }
        configure_service_actions => { root.viewport_configure_service_actions(); }
    }
}
