import { ScrollView } from "std-widgets.slint";
import { MenuGeometry } from "menu_geometry.slint";
import { ChooserChoice, ChooserChoiceOption, ContextServiceAction, DesktopApp } from "models.slint";
import { MenuHoverBridge, MenuHoverRegion, MenuItem, MenuSeparator, MenuTitle, PopupSurface } from "widgets.slint";

component SubmenuMenuRow inherits Rectangle {
    in property <string> label;
    in property <bool> dark;
    callback hovered(bool);
    callback clicked();

    horizontal-stretch: 1;
    height: 38px;

    MenuItem {
        width: parent.width;
        height: parent.height;
        label: root.label;
        dark: root.dark;
        submenu: true;
        hovered(is-hovered) => { root.hovered(is-hovered); }
        clicked => { root.clicked(); }
    }
}

component ActionMenuRow inherits Rectangle {
    in property <string> label;
    in property <string> shortcut: "";
    in property <bool> dark;
    in property <bool> enabled: true;
    callback clicked();

    horizontal-stretch: 1;
    height: 38px;

    MenuItem {
        width: parent.width;
        height: parent.height;
        label: root.label;
        shortcut: root.shortcut;
        dark: root.dark;
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }
}

component ServiceActionMenuRow inherits Rectangle {
    in property <ContextServiceAction> action;
    in property <bool> dark;
    callback action_requested(int);
    callback submenu_hovered(string, length, bool);
    callback submenu_clicked(string, length);

    horizontal-stretch: 1;
    height: 38px;

    if (root.action.row_kind == 0): ActionMenuRow {
        width: parent.width;
        label: root.action.name;
        dark: root.dark;
        clicked => { root.action_requested(root.action.action_index); }
    }

    if (root.action.row_kind == 1): SubmenuMenuRow {
        width: parent.width;
        label: root.action.name;
        dark: root.dark;
        hovered(is-hovered) => {
            root.submenu_hovered(root.action.group, self.absolute-position.y, is-hovered);
        }
        clicked => {
            root.submenu_clicked(root.action.group, self.absolute-position.y);
        }
    }
}

component HoverActionMenuRow inherits Rectangle {
    in property <string> label;
    in property <string> shortcut: "";
    in property <bool> dark;
    in property <bool> enabled: true;
    callback hovered(bool);
    callback clicked();

    horizontal-stretch: 1;
    height: 38px;

    MenuItem {
        width: parent.width;
        height: parent.height;
        label: root.label;
        shortcut: root.shortcut;
        dark: root.dark;
        enabled: root.enabled;
        hovered(is-hovered) => { root.hovered(is-hovered); }
        clicked => { root.clicked(); }
    }
}

component PasteMenuRow inherits Rectangle {
    in property <string> label;
    in property <bool> dark;
    in property <bool> enabled;
    callback paste_requested();

    horizontal-stretch: 1;
    height: 38px;

    ActionMenuRow {
        width: parent.width;
        height: parent.height;
        label: root.label;
        shortcut: "Ctrl+V";
        dark: root.dark;
        enabled: root.enabled;
        clicked => { root.paste_requested(); }
    }
}

component CutCopyMenuRows inherits Rectangle {
    in property <bool> dark;
    callback cut_requested();
    callback copy_requested();

    horizontal-stretch: 1;
    height: 76px;

    VerticalLayout {
        spacing: 0px;

        ActionMenuRow {
            label: "Cut";
            shortcut: "Ctrl+X";
            dark: root.dark;
            clicked => { root.cut_requested(); }
        }

        ActionMenuRow {
            label: "Copy";
            shortcut: "Ctrl+C";
            dark: root.dark;
            clicked => { root.copy_requested(); }
        }
    }
}

export component OpenWithMenu inherits PopupSurface {
    in property <[DesktopApp]> apps;
    in property <length> item-height: 38px;
    in property <length> separator-height: 8px;
    private property <length> list-height: max(root.item-height, root.height - root.separator-height - root.item-height);
    callback keep_alive(bool);
    callback app_selected(string);
    callback other_applications();

    MenuHoverRegion {
        width: parent.width;
        height: parent.height;
        hovered(is-hovered) => { root.keep_alive(is-hovered); }
    }

    VerticalLayout {
        spacing: 0px;

        ScrollView {
            width: parent.width;
            height: root.list-height;
            horizontal-scrollbar-policy: always-off;
            vertical-scrollbar-policy: as-needed;
            viewport-width: root.width;
            viewport-height: max(root.item-height, root.apps.length * root.item-height);

            if (root.apps.length == 0): HoverActionMenuRow {
                width: root.width;
                label: "Loading applications...";
                dark: root.dark;
                hovered(is-hovered) => { root.keep_alive(is-hovered); }
                clicked => { }
            }

            for app[index] in root.apps: HoverActionMenuRow {
                y: index * root.item-height;
                width: root.width;
                label: (app.is_default ? "Default: " : "") + app.name;
                dark: root.dark;
                hovered(is-hovered) => { root.keep_alive(is-hovered); }
                clicked => { root.app_selected(app.id); }
            }
        }

        MenuSeparator {
            dark: root.dark;
        }

        HoverActionMenuRow {
            label: "Other Applications...";
            dark: root.dark;
            hovered(is-hovered) => { root.keep_alive(is-hovered); }
            clicked => { root.other_applications(); }
        }
    }
}

export component CreateNewMenu inherits PopupSurface {
    callback keep_alive(bool);
    callback folder_selected();
    callback file_selected();

    MenuHoverRegion {
        width: parent.width;
        height: parent.height;
        hovered(is-hovered) => { root.keep_alive(is-hovered); }
    }

    VerticalLayout {
        spacing: 0px;

        HoverActionMenuRow {
            label: "Folder";
            dark: root.dark;
            hovered(is-hovered) => { root.keep_alive(is-hovered); }
            clicked => { root.folder_selected(); }
        }

        HoverActionMenuRow {
            label: "File";
            dark: root.dark;
            hovered(is-hovered) => { root.keep_alive(is-hovered); }
            clicked => { root.file_selected(); }
        }
    }
}

export component ServiceMenuGroupMenu inherits PopupSurface {
    in property <[ContextServiceAction]> actions;
    callback keep_alive(bool);
    callback action_selected(int);

    MenuHoverRegion {
        width: parent.width;
        height: parent.height;
        hovered(is-hovered) => { root.keep_alive(is-hovered); }
    }

    VerticalLayout {
        spacing: 0px;

        for action in root.actions: HoverActionMenuRow {
            label: action.name;
            dark: root.dark;
            hovered(is-hovered) => { root.keep_alive(is-hovered); }
            clicked => { root.action_selected(action.action_index); }
        }
    }
}

export component ChildSubmenuLayer inherits Rectangle {
    in property <bool> context-menu-open;
    in property <length> context-menu-left;
    in property <length> context-menu-width;
    in property <length> window-width;
    in property <length> window-height;
    in property <length> screen-margin;
    in property <length> pointer-gap;
    in property <length> child-gap;
    in property <length> item-height: 38px;
    in property <length> title-height: 30px;
    in property <length> separator-height: 8px;
    in property <bool> create-new-open;
    in property <length> create-new-row-y;
    in property <bool> open-with-open;
    in property <length> open-with-row-y;
    in property <[DesktopApp]> open-with-apps;
    in property <bool> service-menu-open;
    in property <length> service-menu-row-y;
    in property <[ContextServiceAction]> service-menu-actions;
    in property <bool> dark;
    private property <length> open-with-width: 260px;
    private property <length> open-with-list-height: max(root.item-height, min(7 * root.item-height, max(1, root.open-with-apps.length) * root.item-height));
    private property <length> open-with-height: root.open-with-list-height + root.separator-height + root.item-height;
    private property <length> create-new-width: 180px;
    private property <length> create-new-height: 2 * root.item-height;
    private property <length> service-menu-width: 240px;
    private property <length> service-menu-height: max(root.item-height, root.service-menu-actions.length * root.item-height);
    private property <int> active-kind: root.open-with-open ? 1 : (root.create-new-open ? 2 : (root.service-menu-open ? 3 : 0));
    private property <length> active-row-y: root.open-with-open ? root.open-with-row-y : (root.create-new-open ? root.create-new-row-y : root.service-menu-row-y);
    private property <length> active-width: root.open-with-open ? root.open-with-width : (root.create-new-open ? root.create-new-width : root.service-menu-width);
    private property <length> active-height: root.open-with-open ? root.open-with-height : (root.create-new-open ? root.create-new-height : root.service-menu-height);
    private property <length> active-left: MenuGeometry.child_menu_left(root.window-width / 1px, root.window-height / 1px, root.context-menu-left / 1px, root.context-menu-width / 1px, root.active-row-y / 1px, root.active-width / 1px, root.active-height / 1px, root.screen-margin / 1px, root.pointer-gap / 1px, root.child-gap / 1px) * 1px;
    private property <length> active-top: MenuGeometry.child_menu_top(root.window-width / 1px, root.window-height / 1px, root.context-menu-left / 1px, root.context-menu-width / 1px, root.active-row-y / 1px, root.active-width / 1px, root.active-height / 1px, root.screen-margin / 1px, root.pointer-gap / 1px, root.child-gap / 1px) * 1px;
    private property <length> bridge-left: MenuGeometry.child_bridge_left(root.window-width / 1px, root.window-height / 1px, root.context-menu-left / 1px, root.context-menu-width / 1px, root.active-left / 1px, root.active-width / 1px, root.active-row-y / 1px, root.active-top / 1px, root.item-height / 1px, 0, root.screen-margin / 1px, root.pointer-gap / 1px, root.child-gap / 1px) * 1px;
    private property <length> bridge-top: MenuGeometry.child_bridge_top(root.window-width / 1px, root.window-height / 1px, root.context-menu-left / 1px, root.context-menu-width / 1px, root.active-left / 1px, root.active-width / 1px, root.active-row-y / 1px, root.active-top / 1px, root.item-height / 1px, 0, root.screen-margin / 1px, root.pointer-gap / 1px, root.child-gap / 1px) * 1px;
    private property <length> bridge-width: MenuGeometry.child_bridge_width(root.window-width / 1px, root.window-height / 1px, root.context-menu-left / 1px, root.context-menu-width / 1px, root.active-left / 1px, root.active-width / 1px, root.active-row-y / 1px, root.active-top / 1px, root.item-height / 1px, 0, root.screen-margin / 1px, root.pointer-gap / 1px, root.child-gap / 1px) * 1px;
    private property <length> bridge-height: MenuGeometry.child_bridge_height(root.window-width / 1px, root.window-height / 1px, root.context-menu-left / 1px, root.context-menu-width / 1px, root.active-left / 1px, root.active-width / 1px, root.active-row-y / 1px, root.active-top / 1px, root.item-height / 1px, 0, root.screen-margin / 1px, root.pointer-gap / 1px, root.child-gap / 1px) * 1px;
    callback child_hovered(int, bool);
    callback create_folder_selected();
    callback create_file_selected();
    callback open_with_app_selected(string);
    callback other_applications();
    callback service_action_selected(int);

    background: transparent;

    if (root.active-kind != 0 && root.context-menu-open): MenuHoverBridge {
        x: root.bridge-left;
        y: root.bridge-top;
        width: root.bridge-width;
        height: root.bridge-height;
        hovered(is-hovered) => {
            root.child_hovered(root.active-kind, is-hovered);
        }
    }

    if (root.create-new-open): CreateNewMenu {
        x: root.active-left;
        y: root.active-top;
        width: root.create-new-width;
        height: root.create-new-height;
        dark: root.dark;
        keep_alive(is-hovered) => {
            root.child_hovered(2, is-hovered);
        }
        folder_selected => {
            root.create_folder_selected();
        }
        file_selected => {
            root.create_file_selected();
        }
    }

    if (root.open-with-open): OpenWithMenu {
        x: root.active-left;
        y: root.active-top;
        width: root.open-with-width;
        height: root.open-with-height;
        dark: root.dark;
        apps: root.open-with-apps;
        item-height: root.item-height;
        separator-height: root.separator-height;
        keep_alive(is-hovered) => {
            root.child_hovered(1, is-hovered);
        }
        app_selected(app-id) => {
            root.open_with_app_selected(app-id);
        }
        other_applications => {
            root.other_applications();
        }
    }

    if (root.service-menu-open): ServiceMenuGroupMenu {
        x: root.active-left;
        y: root.active-top;
        width: root.service-menu-width;
        height: root.service-menu-height;
        dark: root.dark;
        actions: root.service-menu-actions;
        keep_alive(is-hovered) => {
            root.child_hovered(3, is-hovered);
        }
        action_selected(index) => {
            root.service_action_selected(index);
        }
    }
}

export component ChooserChoiceMenu inherits Rectangle {
    in property <string> title;
    in property <bool> dark;
    in property <[ChooserChoiceOption]> options;
    in property <int> selected-index;
    callback option_selected(int);

    background: transparent;

    VerticalLayout {
        spacing: 0px;

        MenuTitle {
            label: root.title;
            dark: root.dark;
        }

        for option[index] in root.options: ActionMenuRow {
            label: (index == root.selected-index ? "✓ " : "  ") + option.label;
            dark: root.dark;
            clicked => { root.option_selected(index); }
        }
    }
}

export component ChooserChoicePopup inherits PopupSurface {
    in property <string> title;
    in property <[ChooserChoiceOption]> options;
    in property <int> selected-index;
    in property <length> title-height: 30px;
    in property <length> item-height: 38px;
    callback option_selected(int);

    height: root.title-height + max(1, root.options.length) * root.item-height;

    ChooserChoiceMenu {
        width: parent.width;
        height: parent.height;
        title: root.title;
        dark: root.dark;
        options: root.options;
        selected-index: root.selected-index;
        option_selected(index) => { root.option_selected(index); }
    }
}

component AnchoredChooserPopup inherits Rectangle {
    in property <bool> open;
    in property <length> menu-x;
    in property <length> menu-y;
    in property <length> menu-width;
    in property <length> window-width;
    in property <length> window-height;
    in property <length> screen-margin;
    in property <length> pointer-gap;
    in property <length> child-gap;
    in property <bool> dark;
    in property <string> title;
    in property <[ChooserChoiceOption]> options;
    in property <int> selected-index;
    in property <length> title-height: 30px;
    in property <length> item-height: 38px;
    private property <length> popup-height: root.title-height + max(1, root.options.length) * root.item-height;
    callback option_selected(int);

    background: transparent;

    if (root.open): ChooserChoicePopup {
        x: MenuGeometry.anchored_menu_left(root.window-width / 1px, root.window-height / 1px, root.menu-x / 1px, root.menu-y / 1px, root.menu-width / 1px, root.popup-height / 1px, root.screen-margin / 1px, root.pointer-gap / 1px, root.child-gap / 1px) * 1px;
        y: MenuGeometry.anchored_menu_top(root.window-width / 1px, root.window-height / 1px, root.menu-x / 1px, root.menu-y / 1px, root.menu-width / 1px, root.popup-height / 1px, root.screen-margin / 1px, root.pointer-gap / 1px, root.child-gap / 1px) * 1px;
        width: root.menu-width;
        dark: root.dark;
        title: root.title;
        options: root.options;
        selected-index: root.selected-index;
        title-height: root.title-height;
        item-height: root.item-height;
        option_selected(option-index) => { root.option_selected(option-index); }
    }
}

export component ChooserChoicePopupLayer inherits Rectangle {
    in property <bool> menu-open;
    in property <int> menu-index;
    in property <length> menu-x;
    in property <length> menu-y;
    in property <length> menu-width;
    in property <length> window-width;
    in property <length> window-height;
    in property <length> screen-margin;
    in property <length> pointer-gap;
    in property <length> child-gap;
    in property <bool> dark;
    in property <[ChooserChoice]> choices;
    in property <length> title-height: 30px;
    in property <length> item-height: 38px;
    callback option_selected(int, int);

    background: transparent;

    for choice[index] in root.choices: AnchoredChooserPopup {
        width: parent.width;
        height: parent.height;
        open: root.menu-open && root.menu-index == index;
        menu-x: root.menu-x;
        menu-y: root.menu-y;
        menu-width: root.menu-width;
        window-width: root.window-width;
        window-height: root.window-height;
        screen-margin: root.screen-margin;
        pointer-gap: root.pointer-gap;
        child-gap: root.child-gap;
        dark: root.dark;
        title: choice.label;
        options: choice.options;
        selected-index: choice.selected_index;
        title-height: root.title-height;
        item-height: root.item-height;
        option_selected(option-index) => {
            root.option_selected(index, option-index);
        }
    }
}

