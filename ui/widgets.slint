export component PopupSurface inherits Rectangle {
    in property <bool> dark;
    in property <length> radius: 8px;

    border-radius: root.radius;
    background: root.dark ? #24282c : #fcfdfe;
    border-width: 1px;
    border-color: root.dark ? #3f474f : #d9e1e8;
}

export component MenuDismissLayer inherits TouchArea {
    callback dismissed();

    clicked => { root.dismissed(); }
}

export component MenuHoverBridge inherits Rectangle {
    callback hovered(bool);

    background: transparent;

    TouchArea {
        width: parent.width;
        height: parent.height;

        changed has-hover => { root.hovered(self.has-hover); }
    }
}

export component MenuHoverRegion inherits Rectangle {
    callback hovered(bool);

    background: transparent;

    TouchArea {
        width: parent.width;
        height: parent.height;

        changed has-hover => { root.hovered(self.has-hover); }
    }
}

export component FolderGlyph inherits Rectangle {
    in property <bool> dir;
    in property <bool> dark;
    in property <int> zoom-level;

    width: root.zoom-level == 0 ? 52px : (root.zoom-level == 1 ? 64px : (root.zoom-level == 2 ? 80px : (root.zoom-level == 3 ? 96px : 112px)));
    height: root.zoom-level == 0 ? 46px : (root.zoom-level == 1 ? 58px : (root.zoom-level == 2 ? 70px : (root.zoom-level == 3 ? 84px : 98px)));
    background: transparent;

    Rectangle {
        x: 0px;
        y: root.height * 0.14;
        width: root.width * 0.475;
        height: root.height * 0.257;
        border-radius: 5px;
        background: root.dir ? (root.dark ? #3b668b : #72aee6) : (root.dark ? #858b90 : #a8afb6);
    }

    Rectangle {
        x: 0px;
        y: root.height * 0.286;
        width: root.width;
        height: root.height * 0.686;
        border-radius: 4px;
        background: root.dir ? (root.dark ? #3f6f98 : #609fe0) : (root.dark ? #8b9197 : #aeb4ba);
    }

    Rectangle {
        visible: root.dir;
        x: root.width * 0.075;
        y: root.height * 0.357;
        width: root.width * 0.825;
        height: max(5px, root.height * 0.1);
        border-radius: 2px;
        background: root.dark ? #a9b8c4 : #edf4fa;
    }

    Text {
        visible: !root.dir;
        text: "doc";
        x: root.width * 0.1875;
        y: root.height * 0.543;
        width: root.width * 0.625;
        color: root.dark ? #303030 : #555555;
        font-size: root.zoom-level < 2 ? 10px : (root.zoom-level == 2 ? 12px : 13px);
        font-weight: 700;
        horizontal-alignment: center;
    }
}
