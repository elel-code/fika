export component ToolButton inherits Rectangle {
    in property <string> label;
    in property <bool> dark;
    in property <bool> enabled: true;
    in property <bool> selected: false;
    callback clicked();

    width: 32px;
    height: 32px;
    border-radius: 8px;
    border-width: root.selected ? 1px : 0px;
    border-color: root.selected ? (root.dark ? #3b5a68 : #c8d7e3) : transparent;
    background: root.selected ? (root.dark ? #1b2a32 : #e8eef4) : (root.enabled && touch-area.has-hover ? (dark ? #1e252b : #e9edf2) : transparent);
    opacity: root.enabled ? 1 : 0.45;

    touch-area := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }

    Text {
        text: root.label;
        horizontal-alignment: center;
        vertical-alignment: center;
        color: root.enabled ? (root.selected ? (root.dark ? #e8f6fb : #17445a) : (root.dark ? #dce4eb : #24303b)) : (root.dark ? #68727c : #9aa3ad);
        font-size: 13px;
        font-weight: 700;
    }
}

export component ActionButton inherits Rectangle {
    in property <string> label;
    in property <bool> dark;
    in property <bool> enabled: true;
    callback clicked();

    width: 92px;
    height: 28px;
    border-radius: 8px;
    border-width: 1px;
    border-color: root.enabled ? (root.dark ? #36414a : #d8e1ea) : (root.dark ? #2a3239 : #e2e7ed);
    background: !root.enabled ? (root.dark ? #171d22 : #f2f4f6) : (touch-area.has-hover ? (root.dark ? #20272e : #edf1f4) : (root.dark ? #151b20 : #ffffff));

    touch-area := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }

    Text {
        text: root.label;
        horizontal-alignment: center;
        vertical-alignment: center;
        color: root.enabled ? (root.dark ? #e9eff4 : #24303b) : (root.dark ? #6b7280 : #94a3b8);
        font-size: 12px;
        font-weight: 700;
        overflow: elide;
    }
}

export component PlaceButton inherits Rectangle {
    in property <string> label;
    in property <string> path;
    in property <string> marker;
    in property <bool> selected;
    in property <bool> dark;
    in property <int> index;
    in property <length> list_y;
    in property <bool> reorderable;
    in property <bool> dragged;
    in property <int> place_count;
    in property <data-transfer> drag-data-source;
    in property <bool> builtin;
    in property <bool> drop-target;
    in property <bool> available: true;
    in property <string> pending-action: "";
    in property <string> error: "";
    callback clicked();
    callback context_requested(int, string, bool, string, length, length);
    callback drag_cancelled();

    height: 34px;
    border-radius: 8px;
    border-width: dragged || drop-target || error != "" || pending-action != "" ? 1px : 0px;
    border-color: error != "" ? (dark ? #ef4444 : #dc2626) : (pending-action != "" ? (dark ? #51a9d4 : #2b86b7) : (drop-target ? (dark ? #f59e0b : #d97706) : (dark ? #3f4953 : #cfd8e3)));
    background: error != "" ? (dark ? #351b1f : #fff1f2) : (pending-action != "" ? (dark ? #102c38 : #e4f3fa) : (drop-target ? (dark ? #3a2a12 : #fff7dd) : (dragged ? (dark ? #20262c : #e2e7ec) : (selected ? (dark ? #202a33 : #eef2f6) : (touch-area.has-hover ? (dark ? #1f262d : #f2f5f8) : transparent)))));
    opacity: dragged ? 0.45 : (available ? 1 : 0.68);

    drag-area := DragArea {
        enabled: root.reorderable && root.path != "";
        data: root.drag-data-source;

        touch-area := TouchArea {
            clicked => { root.clicked(); }
            pointer-event(event) => {
                if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                    root.drag_cancelled();
                } else if (event.button == PointerEventButton.right && event.kind == PointerEventKind.down) {
                    root.context_requested(root.index, root.label, root.builtin, root.path, self.absolute-position.x + self.mouse-x, self.absolute-position.y + self.mouse-y);
                }
            }
        }

        HorizontalLayout {
            padding-left: 11px;
            padding-right: 10px;
            spacing: 10px;

            Rectangle {
                width: 24px;
                height: root.height;
                background: transparent;

                Rectangle {
                    y: (parent.height - self.height) / 2;
                    width: 24px;
                    height: 22px;
                    border-radius: 6px;
                    background: root.error != "" ? (root.dark ? #ef4444 : #dc2626) : (root.pending-action != "" ? (root.dark ? #51a9d4 : #2b86b7) : (root.available ? (root.dark ? #527b9e : #7aa3c7) : (root.dark ? #3f464d : #cbd5e1)));

                    Text {
                        text: root.error != "" ? "!" : (root.pending-action != "" ? "..." : root.marker);
                        color: root.error != "" || root.pending-action != "" ? #ffffff : #102033;
                        font-size: 11px;
                        font-weight: 800;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }

            Text {
                text: root.label;
                color: root.error != "" ? (root.dark ? #fecaca : #991b1b) : (root.pending-action != "" ? (root.dark ? #bce7f7 : #075985) : (root.available ? (root.dark ? #dfe7ee : #24303b) : (root.dark ? #89939d : #64748b)));
                font-size: 14px;
                overflow: elide;
                vertical-alignment: center;
            }
        }
    }
}

export component SidebarAction inherits Rectangle {
    in property <string> label;
    in property <bool> dark;
    callback clicked();

    height: 30px;
    border-radius: 8px;
    background: touch-area.has-hover ? (dark ? #1f262d : #f2f5f8) : transparent;

    touch-area := TouchArea {
        clicked => { root.clicked(); }
    }

    Text {
        text: root.label;
        x: 13px;
        width: parent.width - 26px;
        color: root.dark ? #cbd3dc : #526071;
        font-size: 13px;
        overflow: elide;
        vertical-alignment: center;
    }
}

export component SidebarSection inherits Rectangle {
    in property <string> label;
    in property <bool> dark;

    height: 30px;
    background: transparent;

    Text {
        x: 12px;
        text: root.label;
        color: root.dark ? #8f9aa5 : #667586;
        font-size: 12px;
        font-weight: 700;
        vertical-alignment: center;
    }
}

export component CheckOption inherits Rectangle {
    in property <string> label;
    in property <image> icon;
    in property <bool> has-icon: false;
    in property <bool> dark;
    in-out property <bool> checked;
    callback toggled(bool);

    height: 30px;
    border-radius: 8px;
    background: touch-area.has-hover ? (dark ? #1f262d : #f2f5f8) : transparent;

    touch-area := TouchArea {
        clicked => {
            root.checked = !root.checked;
            root.toggled(root.checked);
        }
    }

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 9px;

        Rectangle {
            y: (parent.height - self.height) / 2;
            width: 18px;
            height: 18px;
            border-radius: 4px;
            border-width: 1px;
            border-color: root.dark ? #65727f : #a1adba;
            background: root.checked ? (root.dark ? #51a9d4 : #2b86b7) : transparent;

            Text {
                text: root.checked ? "X" : "";
                color: root.dark ? #0f172a : #ffffff;
                font-size: 11px;
                font-weight: 800;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        if (root.has-icon): Image {
            y: (parent.height - self.height) / 2;
            width: 18px;
            height: 18px;
            source: root.icon;
            image-fit: contain;
        }

        Text {
            text: root.label;
            color: root.dark ? #dfe7ee : #24303b;
            font-size: 13px;
            overflow: elide;
            vertical-alignment: center;
        }
    }
}

export component FilterButton inherits Rectangle {
    in property <string> label;
    in property <bool> dark;
    callback clicked();

    height: 30px;
    border-radius: 8px;
    border-width: 1px;
    border-color: root.dark ? #303a43 : #dce3ea;
    background: touch-area.has-hover ? (root.dark ? #1f262d : #f2f5f8) : (root.dark ? #151b20 : #ffffff);

    touch-area := TouchArea {
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 8px;
        spacing: 6px;

        Text {
            text: root.label;
            color: root.dark ? #dfe7ee : #24303b;
            font-size: 12px;
            overflow: elide;
            vertical-alignment: center;
        }

        Text {
            text: "v";
            color: root.dark ? #a6b0ba : #64748b;
            font-size: 11px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}

export component MenuItem inherits Rectangle {
    in property <string> label;
    in property <string> shortcut: "";
    in property <image> icon;
    in property <bool> has-icon: false;
    in property <bool> dark;
    in property <bool> submenu: false;
    in property <bool> enabled: true;
    callback clicked();
    callback hovered(bool);

    height: 38px;
    background: transparent;

    touch-area := TouchArea {
        enabled: root.enabled;
        changed has-hover => { root.hovered(self.has-hover && root.enabled); }
        clicked => { root.clicked(); }
    }

    Rectangle {
        x: 4px;
        y: 3px;
        width: parent.width - 8px;
        height: parent.height - 6px;
        border-radius: 6px;
        background: root.enabled && touch-area.has-hover ? (root.dark ? #30363c : #eef3f7) : transparent;
    }

    if (root.has-icon): Image {
        x: 12px;
        y: (parent.height - self.height) / 2;
        width: 18px;
        height: 18px;
        source: root.icon;
        image-fit: contain;
        opacity: root.enabled ? 1 : 0.45;
    }

    Text {
        text: root.label;
        x: root.has-icon ? 38px : 12px;
        width: parent.width - self.x - (root.submenu ? 22px : (root.shortcut != "" ? 84px : 12px));
        color: root.enabled ? (root.dark ? #edf2f7 : #1f2933) : (root.dark ? #717b84 : #94a3b8);
        font-size: 13px;
        overflow: elide;
        vertical-alignment: center;
    }

    if (root.shortcut != "" && !root.submenu): Text {
        text: root.shortcut;
        x: parent.width - 82px;
        width: 70px;
        color: root.enabled ? (root.dark ? #aeb8c2 : #64748b) : (root.dark ? #5f6871 : #cbd5e1);
        font-size: 12px;
        horizontal-alignment: right;
        vertical-alignment: center;
    }

    if (root.submenu): Text {
        text: ">";
        x: parent.width - 24px;
        width: 12px;
        color: root.enabled ? (root.dark ? #b6c0ca : #64748b) : (root.dark ? #5f6871 : #cbd5e1);
        font-size: 13px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

export component MenuSeparator inherits Rectangle {
    in property <bool> dark;

    height: 8px;
    background: transparent;

    Rectangle {
        x: 8px;
        y: 4px;
        width: parent.width - 16px;
        height: 1px;
        background: root.dark ? #343b42 : #e5ebf0;
    }
}

export component MenuTitle inherits Rectangle {
    in property <string> label;
    in property <bool> dark;

    height: 30px;
    background: transparent;

    Text {
        text: root.label;
        x: 12px;
        width: parent.width - 24px;
        color: root.dark ? #9aa5af : #697684;
        font-size: 12px;
        font-weight: 700;
        overflow: elide;
        vertical-alignment: center;
    }
}

export component MenuHoverTitle inherits Rectangle {
    in property <string> label;
    in property <bool> dark;
    callback hovered(bool);

    height: 30px;
    background: transparent;

    touch-area := TouchArea {
        changed has-hover => { root.hovered(self.has-hover); }
    }

    Text {
        text: root.label;
        x: 12px;
        width: parent.width - 24px;
        color: root.dark ? #9aa5af : #697684;
        font-size: 12px;
        font-weight: 700;
        overflow: elide;
        vertical-alignment: center;
    }
}

export component PopupSurface inherits Rectangle {
    in property <bool> dark;
    in property <length> radius: 8px;

    border-radius: root.radius;
    background: root.dark ? #24282c : #fcfdfe;
    border-width: 1px;
    border-color: root.dark ? #3f474f : #d9e1e8;
}

export component MenuDismissLayer inherits TouchArea {
    callback dismissed();

    clicked => { root.dismissed(); }
}

export component MenuHoverBridge inherits Rectangle {
    callback hovered(bool);

    background: transparent;

    TouchArea {
        width: parent.width;
        height: parent.height;

        changed has-hover => { root.hovered(self.has-hover); }
    }
}

export component MenuHoverRegion inherits Rectangle {
    callback hovered(bool);

    background: transparent;

    TouchArea {
        width: parent.width;
        height: parent.height;

        changed has-hover => { root.hovered(self.has-hover); }
    }
}
