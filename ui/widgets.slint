export component ToolButton inherits Rectangle {
    in property <string> label;
    in property <bool> dark;
    in property <bool> enabled: true;
    in property <bool> selected: false;
    callback clicked();

    width: 32px;
    height: 32px;
    border-radius: 8px;
    border-width: 1px;
    border-color: root.selected ? (root.dark ? #3d7892 : #b6d8e7) : transparent;
    background: root.selected ? (root.dark ? #183140 : #e8f5fb) : (root.enabled && touch-area.has-hover ? (dark ? #232a31 : #eef1f5) : transparent);
    opacity: root.enabled ? 1 : 0.45;

    touch-area := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }

    Text {
        text: root.label;
        horizontal-alignment: center;
        vertical-alignment: center;
        color: root.enabled ? (root.selected ? (root.dark ? #e8f8ff : #15526a) : (root.dark ? #e8eef4 : #202832)) : (root.dark ? #68727c : #9aa3ad);
        font-size: 14px;
        font-weight: 700;
    }
}

export component ActionButton inherits Rectangle {
    in property <string> label;
    in property <bool> dark;
    in property <bool> enabled: true;
    callback clicked();

    width: 92px;
    height: 28px;
    border-radius: 7px;
    border-width: 1px;
    border-color: root.enabled ? (root.dark ? #414b55 : #d9e1e8) : (root.dark ? #303840 : #e1e7ee);
    background: !root.enabled ? (root.dark ? #1a1f24 : #f4f6f8) : (touch-area.has-hover ? (root.dark ? #242b32 : #eef1f5) : (root.dark ? #1b2026 : #ffffff));

    touch-area := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }

    Text {
        text: root.label;
        horizontal-alignment: center;
        vertical-alignment: center;
        color: root.enabled ? (root.dark ? #eef3f7 : #202832) : (root.dark ? #6b7280 : #94a3b8);
        font-size: 12px;
        font-weight: 700;
        overflow: elide;
    }
}

export component PlaceButton inherits Rectangle {
    in property <string> label;
    in property <string> path;
    in property <string> marker;
    in property <bool> selected;
    in property <bool> dark;
    in property <int> index;
    in property <length> list_y;
    in property <bool> reorderable;
    in property <bool> dragged;
    in property <int> place_count;
    in property <data-transfer> drag-data-source;
    in property <bool> builtin;
    in property <bool> drop-target;
    in property <bool> available: true;
    in property <string> pending-action: "";
    in property <string> error: "";
    callback clicked();
    callback context_requested(int, string, bool, string, length, length);
    callback drag_cancelled();

    height: 34px;
    border-radius: 8px;
    border-width: dragged || drop-target || error != "" || pending-action != "" ? 1px : 0px;
    border-color: error != "" ? (dark ? #ef4444 : #dc2626) : (pending-action != "" ? (dark ? #51a9d4 : #2b86b7) : (drop-target ? (dark ? #f59e0b : #d97706) : (dark ? #45505a : #c9d3dd)));
    background: error != "" ? (dark ? #351b1f : #fff1f2) : (pending-action != "" ? (dark ? #102c38 : #e4f3fa) : (drop-target ? (dark ? #3a2a12 : #fff7dd) : (dragged ? (dark ? #20262c : #e2e7ec) : (selected ? (dark ? #232f39 : #edf3f8) : (touch-area.has-hover ? (dark ? #222930 : #f1f4f7) : transparent)))));
    opacity: dragged ? 0.45 : (available ? 1 : 0.68);

    drag-area := DragArea {
        enabled: root.reorderable && root.path != "";
        data: root.drag-data-source;

        touch-area := TouchArea {
            clicked => { root.clicked(); }
            pointer-event(event) => {
                if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                    root.drag_cancelled();
                } else if (event.button == PointerEventButton.right && event.kind == PointerEventKind.down) {
                    root.context_requested(root.index, root.label, root.builtin, root.path, self.absolute-position.x + self.mouse-x, self.absolute-position.y + self.mouse-y);
                }
            }
        }

        HorizontalLayout {
            padding-left: 10px;
            padding-right: 10px;
            spacing: 9px;

            Rectangle {
                width: 24px;
                height: root.height;
                background: transparent;

                Rectangle {
                    y: (parent.height - self.height) / 2;
                    width: 24px;
                    height: 22px;
                    border-radius: 3px;
                    background: root.error != "" ? (root.dark ? #ef4444 : #dc2626) : (root.pending-action != "" ? (root.dark ? #51a9d4 : #2b86b7) : (root.available ? (root.dark ? #5d8db8 : #6b9fd0) : (root.dark ? #3f464d : #cbd5e1)));

                    Text {
                        text: root.error != "" ? "!" : (root.pending-action != "" ? "..." : root.marker);
                        color: root.error != "" || root.pending-action != "" ? #ffffff : #102033;
                        font-size: 11px;
                        font-weight: 800;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }

            Text {
                text: root.label;
                color: root.error != "" ? (root.dark ? #fecaca : #991b1b) : (root.pending-action != "" ? (root.dark ? #bce7f7 : #075985) : (root.available ? (root.dark ? #e8eef4 : #202832) : (root.dark ? #89939d : #64748b)));
                font-size: 14px;
                overflow: elide;
                vertical-alignment: center;
            }
        }
    }
}

export component SidebarAction inherits Rectangle {
    in property <string> label;
    in property <bool> dark;
    callback clicked();

    height: 30px;
    border-radius: 8px;
    background: touch-area.has-hover ? (dark ? #222930 : #f1f4f7) : transparent;

    touch-area := TouchArea {
        clicked => { root.clicked(); }
    }

    Text {
        text: root.label;
        x: 12px;
        width: parent.width - 24px;
        color: root.dark ? #cbd3dc : #526071;
        font-size: 13px;
        overflow: elide;
        vertical-alignment: center;
    }
}

export component SidebarSection inherits Rectangle {
    in property <string> label;
    in property <bool> dark;

    height: 28px;
    background: transparent;

    Text {
        x: 10px;
        text: root.label;
        color: root.dark ? #9aa5af : #667586;
        font-size: 12px;
        font-weight: 700;
        vertical-alignment: center;
    }
}

export component CheckOption inherits Rectangle {
    in property <string> label;
    in property <bool> dark;
    in-out property <bool> checked;
    callback toggled(bool);

    height: 30px;
    border-radius: 7px;
    background: touch-area.has-hover ? (dark ? #222930 : #f1f4f7) : transparent;

    touch-area := TouchArea {
        clicked => {
            root.checked = !root.checked;
            root.toggled(root.checked);
        }
    }

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 9px;

        Rectangle {
            y: (parent.height - self.height) / 2;
            width: 18px;
            height: 18px;
            border-radius: 4px;
            border-width: 1px;
            border-color: root.dark ? #65727f : #a1adba;
            background: root.checked ? (root.dark ? #51a9d4 : #2b86b7) : transparent;

            Text {
                text: root.checked ? "X" : "";
                color: root.dark ? #0f172a : #ffffff;
                font-size: 11px;
                font-weight: 800;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        Text {
            text: root.label;
            color: root.dark ? #e8eef4 : #202832;
            font-size: 13px;
            overflow: elide;
            vertical-alignment: center;
        }
    }
}

export component FilterButton inherits Rectangle {
    in property <string> label;
    in property <bool> dark;
    callback clicked();

    height: 30px;
    border-radius: 7px;
    border-width: 1px;
    border-color: root.dark ? #37414b : #dfe5eb;
    background: touch-area.has-hover ? (root.dark ? #222930 : #f1f4f7) : (root.dark ? #161b20 : #ffffff);

    touch-area := TouchArea {
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 8px;
        spacing: 6px;

        Text {
            text: root.label;
            color: root.dark ? #e8eef4 : #202832;
            font-size: 12px;
            overflow: elide;
            vertical-alignment: center;
        }

        Text {
            text: "v";
            color: root.dark ? #a6b0ba : #64748b;
            font-size: 11px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}

export component MenuItem inherits Rectangle {
    in property <string> label;
    in property <string> shortcut: "";
    in property <bool> dark;
    in property <bool> submenu: false;
    in property <bool> enabled: true;
    callback clicked();
    callback hovered(bool);

    height: 38px;
    background: transparent;

    touch-area := TouchArea {
        enabled: root.enabled;
        changed has-hover => { root.hovered(self.has-hover && root.enabled); }
        clicked => { root.clicked(); }
    }

    Rectangle {
        x: 4px;
        y: 3px;
        width: parent.width - 8px;
        height: parent.height - 6px;
        border-radius: 6px;
        background: root.enabled && touch-area.has-hover ? (root.dark ? #30363c : #eef3f7) : transparent;
    }

    Text {
        text: root.label;
        x: 12px;
        width: parent.width - (root.submenu ? 34px : (root.shortcut != "" ? 96px : 24px));
        color: root.enabled ? (root.dark ? #edf2f7 : #1f2933) : (root.dark ? #717b84 : #94a3b8);
        font-size: 13px;
        overflow: elide;
        vertical-alignment: center;
    }

    if (root.shortcut != "" && !root.submenu): Text {
        text: root.shortcut;
        x: parent.width - 82px;
        width: 70px;
        color: root.enabled ? (root.dark ? #aeb8c2 : #64748b) : (root.dark ? #5f6871 : #cbd5e1);
        font-size: 12px;
        horizontal-alignment: right;
        vertical-alignment: center;
    }

    if (root.submenu): Text {
        text: ">";
        x: parent.width - 24px;
        width: 12px;
        color: root.enabled ? (root.dark ? #b6c0ca : #64748b) : (root.dark ? #5f6871 : #cbd5e1);
        font-size: 13px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

export component MenuSeparator inherits Rectangle {
    in property <bool> dark;

    height: 8px;
    background: transparent;

    Rectangle {
        x: 8px;
        y: 4px;
        width: parent.width - 16px;
        height: 1px;
        background: root.dark ? #343b42 : #e5ebf0;
    }
}

export component MenuTitle inherits Rectangle {
    in property <string> label;
    in property <bool> dark;

    height: 30px;
    background: transparent;

    Text {
        text: root.label;
        x: 12px;
        width: parent.width - 24px;
        color: root.dark ? #9aa5af : #697684;
