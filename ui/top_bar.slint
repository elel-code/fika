import { ToolButton } from "widgets.slint";

export component TopBar inherits Rectangle {
    in property <bool> dark;
    in property <string> current-path;
    in property <float> sidebar-width-px;
    in property <length> divider-offset: 3px;
    in-out property <string> path-text;
    in-out property <bool> path-focused;
    callback go_parent();
    callback go_home();
    callback path_submitted(string);
    callback search_requested();
    callback dark_toggled();

    height: 64px;
    background: root.dark ? #0f1214 : #fbfcfd;
    border-width: 0px;

    HorizontalLayout {
        padding-right: 18px;
        padding-top: 12px;
        padding-bottom: 12px;
        spacing: 0px;

        HorizontalLayout {
            width: root.sidebar-width-px * 1px + root.divider-offset;
            padding-left: 18px;
            padding-right: 18px;
            spacing: 6px;

            ToolButton {
                label: "<";
                dark: root.dark;
                clicked => { root.go_parent(); }
            }

            ToolButton {
                label: "H";
                dark: root.dark;
                clicked => { root.go_home(); }
            }
        }

        Rectangle {
            horizontal-stretch: 1;
            min-width: 260px;
            height: 40px;
            border-radius: 8px;
            border-width: 1px;
            border-color: root.path-focused ? (root.dark ? #58b6dd : #2b86b7) : (root.dark ? #30363c : #d8e0e8);
            background: root.path-focused ? (root.dark ? #15191c : #ffffff) : (root.dark ? #15191c : #f5f7fa);

            Text {
                visible: root.path-text == "";
                x: 12px;
                width: parent.width - 24px;
                height: parent.height;
                text: "/path/to/folder";
                color: root.dark ? #74808a : #697684;
                font-size: 14px;
                overflow: elide;
                vertical-alignment: center;
            }

            TextInput {
                x: 12px;
                width: parent.width - 24px;
                height: parent.height;
                text <=> root.path-text;
                single-line: true;
                font-size: 14px;
                vertical-alignment: center;
                color: root.dark ? #f4f7fa : #1f2933;
                selection-background-color: root.dark ? #51a9d4 : #2b86b7;
                selection-foreground-color: root.dark ? #0f172a : #ffffff;
                accepted => { root.path_submitted(self.text); }
                changed has-focus => {
                    root.path-focused = self.has-focus;
                    if (!self.has-focus) {
                        self.text = root.current-path;
                    } else if (self.text == "") {
                        self.text = root.current-path;
                    }
                }
            }
        }

        HorizontalLayout {
            padding-left: 14px;
            spacing: 16px;

            Text {
                text: "Split";
                color: root.dark ? #dce3ea : #526071;
                font-size: 14px;
                font-weight: 500;
                height: 40px;
                min-width: 34px;
                vertical-alignment: center;
            }

            ToolButton {
                label: "S";
                dark: root.dark;
                clicked => { root.search_requested(); }
            }

            ToolButton {
                label: root.dark ? "L" : "D";
                dark: root.dark;
                clicked => { root.dark_toggled(); }
            }
        }
    }

    Rectangle {
        y: parent.height - 1px;
        width: parent.width;
        height: 1px;
        background: root.dark ? #252b31 : #e7edf3;
    }
}
