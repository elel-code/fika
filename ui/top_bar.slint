import { ToolButton } from "widgets.slint";

export component TopBar inherits Rectangle {
    in property <bool> dark;
    in property <string> current-path;
    in property <length> main-start-x;
    in property <bool> can-go-back;
    in property <bool> can-go-forward;
    in property <bool> search-active;
    in property <bool> split-view-open;
    in-out property <string> path-text;
    in-out property <bool> path-focused;
    in-out property <string> search-query;
    in-out property <bool> search-focused;
    callback go_back();
    callback go_forward();
    callback go_parent();
    callback path_submitted(string);
    callback search_requested();
    callback search_submitted(string);
    callback search_close_requested();
    callback toggle_split_view();
    callback dark_toggled();

    height: 56px;
    background: transparent;
    border-width: 0px;

    private property <color> separator-color: root.dark ? #242b33 : #e5eaf0;
    private property <color> field-background: root.dark ? #151b20 : #ffffff;
    private property <color> field-focus-background: root.dark ? #12181d : #ffffff;
    private property <color> field-border: root.dark ? #303943 : #d9e1e8;
    private property <color> field-focus-border: root.dark ? #58b4d8 : #2f8dbc;
    private property <color> field-text-color: root.dark ? #eef3f7 : #26303a;
    private property <color> muted-text-color: root.dark ? #87929d : #697684;
    private property <color> close-hover-color: root.dark ? #222a31 : #edf1f4;
    private property <length> path-min-width: root.search-active ? 48px : 160px;

    HorizontalLayout {
        padding-right: 12px;
        padding-top: 9px;
        padding-bottom: 9px;
        spacing: 0px;

        Rectangle {
            width: root.main-start-x;
            background: transparent;
        }

        HorizontalLayout {
            padding-left: 0px;
            padding-right: 14px;
            spacing: 4px;

            ToolButton {
                label: "<";
                dark: root.dark;
                enabled: root.can-go-back;
                clicked => { root.go_back(); }
            }

            ToolButton {
                label: ">";
                dark: root.dark;
                enabled: root.can-go-forward;
                clicked => { root.go_forward(); }
            }

            ToolButton {
                label: "^";
                dark: root.dark;
                clicked => { root.go_parent(); }
            }
        }

        Rectangle {
            horizontal-stretch: 1;
            min-width: root.path-min-width;
            height: 32px;
            border-radius: 9px;
            border-width: 1px;
            border-color: root.path-focused ? root.field-focus-border : root.field-border;
            background: root.path-focused ? root.field-focus-background : root.field-background;

            Text {
                visible: root.path-text == "";
                x: 13px;
                width: max(1px, parent.width - 26px);
                height: parent.height;
                text: "/path/to/folder";
                color: root.muted-text-color;
                font-size: 14px;
                overflow: elide;
                vertical-alignment: center;
            }

            TextInput {
                x: 13px;
                width: max(1px, parent.width - 26px);
                height: parent.height;
                text <=> root.path-text;
                single-line: true;
                font-size: 14px;
                vertical-alignment: center;
                color: root.field-text-color;
                selection-background-color: root.dark ? #58b4d8 : #2f8dbc;
                selection-foreground-color: root.dark ? #0f172a : #ffffff;
                accepted => { root.path_submitted(self.text); }
                changed has-focus => {
                    root.path-focused = self.has-focus;
                    if (!self.has-focus) {
                        self.text = root.current-path;
                    } else if (self.text == "") {
                        self.text = root.current-path;
                    }
                }
            }
        }

        HorizontalLayout {
            padding-left: 14px;
            spacing: 4px;

            if (!root.search-active): ToolButton {
                label: "||";
                dark: root.dark;
                selected: root.split-view-open;
                clicked => { root.toggle_split_view(); }
            }

            if (!root.search-active): ToolButton {
                label: "S";
                dark: root.dark;
                clicked => { root.search_requested(); }
            }

            if (root.search-active): Rectangle {
                min-width: 136px;
                preferred-width: 240px;
                max-width: 240px;
                height: 32px;
                border-radius: 9px;
                border-width: 1px;
                border-color: root.search-focused ? root.field-focus-border : root.field-border;
                background: root.search-focused ? root.field-focus-background : root.field-background;

                Text {
                    x: 11px;
                    width: 18px;
                    height: parent.height;
                    text: "S";
                    color: root.muted-text-color;
                    font-size: 13px;
                    font-weight: 800;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                Text {
                    visible: root.search-query == "";
                    x: 36px;
                    width: max(1px, parent.width - 70px);
                    height: parent.height;
                    text: "Search";
                    color: root.muted-text-color;
                    font-size: 14px;
                    overflow: elide;
                    vertical-alignment: center;
                }

                TextInput {
                    x: 36px;
                    width: max(1px, parent.width - 70px);
                    height: parent.height;
                    text <=> root.search-query;
                    single-line: true;
                    font-size: 14px;
                    vertical-alignment: center;
                    color: root.field-text-color;
                    selection-background-color: root.dark ? #58b4d8 : #2f8dbc;
                    selection-foreground-color: root.dark ? #0f172a : #ffffff;
                    accepted => { root.search_submitted(self.text); }
                    changed has-focus => {
                        root.search-focused = self.has-focus;
                    }
                }

                close-search-touch := TouchArea {
                    x: parent.width - 28px;
                    width: 28px;
                    height: parent.height;
                    clicked => { root.search_close_requested(); }
                }

                Rectangle {
                    x: parent.width - 25px;
                    y: (parent.height - self.height) / 2;
                    width: 21px;
                    height: 21px;
                    border-radius: 6px;
                    background: close-search-touch.has-hover ? root.close-hover-color : transparent;

                    Text {
                        text: "X";
                        color: root.dark ? #dce3ea : #526071;
                        font-size: 12px;
                        font-weight: 800;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }

            ToolButton {
                label: root.dark ? "L" : "D";
                dark: root.dark;
                clicked => { root.dark_toggled(); }
            }
        }
    }

    Rectangle {
        x: root.main-start-x;
        y: parent.height - 1px;
        width: max(1px, parent.width - self.x);
        height: 1px;
        background: root.separator-color;
    }
}
