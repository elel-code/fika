import { ToolButton } from "widgets.slint";

export component TopBar inherits Rectangle {
    in property <bool> dark;
    in property <string> current-path;
    in property <float> sidebar-width-px;
    in property <length> divider-offset: 3px;
    in property <bool> can-go-back;
    in property <bool> can-go-forward;
    in property <bool> search-active;
    in property <bool> split-view-open;
    in-out property <string> path-text;
    in-out property <bool> path-focused;
    in-out property <string> search-query;
    in-out property <bool> search-focused;
    callback go_back();
    callback go_forward();
    callback go_parent();
    callback path_submitted(string);
    callback search_requested();
    callback search_submitted(string);
    callback search_close_requested();
    callback toggle_split_view();
    callback dark_toggled();

    height: 64px;
    background: root.dark ? #0f1214 : #fbfcfd;
    border-width: 0px;

    HorizontalLayout {
        padding-right: 16px;
        padding-top: 14px;
        padding-bottom: 14px;
        spacing: 0px;

        Rectangle {
            width: root.sidebar-width-px * 1px + root.divider-offset;
            background: transparent;
        }

        HorizontalLayout {
            padding-left: 4px;
            padding-right: 12px;
            spacing: 6px;

            ToolButton {
                label: "<";
                dark: root.dark;
                enabled: root.can-go-back;
                clicked => { root.go_back(); }
            }

            ToolButton {
                label: ">";
                dark: root.dark;
                enabled: root.can-go-forward;
                clicked => { root.go_forward(); }
            }

            ToolButton {
                label: "^";
                dark: root.dark;
                clicked => { root.go_parent(); }
            }
        }

        Rectangle {
            horizontal-stretch: 1;
            min-width: 120px;
            height: 36px;
            border-radius: 9px;
            border-width: 1px;
            border-color: root.path-focused ? (root.dark ? #56b6dd : #2b86b7) : (root.dark ? #303840 : #d8e0e8);
            background: root.path-focused ? (root.dark ? #14181c : #ffffff) : (root.dark ? #161b20 : #f3f6f9);

            Text {
                visible: root.path-text == "";
                x: 13px;
                width: parent.width - 26px;
                height: parent.height;
                text: "/path/to/folder";
                color: root.dark ? #74808a : #687381;
                font-size: 14px;
                overflow: elide;
                vertical-alignment: center;
            }

            TextInput {
                x: 13px;
                width: parent.width - 26px;
                height: parent.height;
                text <=> root.path-text;
                single-line: true;
                font-size: 14px;
                vertical-alignment: center;
                color: root.dark ? #f4f7fa : #202832;
                selection-background-color: root.dark ? #51a9d4 : #2b86b7;
                selection-foreground-color: root.dark ? #0f172a : #ffffff;
                accepted => { root.path_submitted(self.text); }
                changed has-focus => {
                    root.path-focused = self.has-focus;
                    if (!self.has-focus) {
                        self.text = root.current-path;
                    } else if (self.text == "") {
                        self.text = root.current-path;
                    }
                }
            }
        }

        HorizontalLayout {
            padding-left: 10px;
            spacing: 6px;

            if (!root.search-active): Rectangle {
                height: 36px;
                width: 62px;
                border-radius: 9px;
                border-width: root.split-view-open ? 1px : 0px;
                border-color: root.dark ? #3f829e : #9bcfe4;
                background: root.split-view-open ? (root.dark ? #173443 : #e1f2f9) : (split-touch.has-hover ? (root.dark ? #2a3036 : #edf1f5) : transparent);

                split-touch := TouchArea {
                    clicked => { root.toggle_split_view(); }
                }

                Text {
                    text: "Split";
                    color: root.split-view-open ? (root.dark ? #e8f8ff : #0f526c) : (root.dark ? #dce3ea : #526071);
                    font-size: 13px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            if (!root.search-active): ToolButton {
                label: "S";
                dark: root.dark;
                clicked => { root.search_requested(); }
            }

            if (root.search-active): Rectangle {
                width: 248px;
                height: 36px;
                border-radius: 9px;
                border-width: 1px;
                border-color: root.search-focused ? (root.dark ? #56b6dd : #2b86b7) : (root.dark ? #303840 : #d8e0e8);
                background: root.search-focused ? (root.dark ? #14181c : #ffffff) : (root.dark ? #161b20 : #f3f6f9);

                Text {
                    x: 12px;
                    width: 18px;
                    height: parent.height;
                    text: "S";
                    color: root.dark ? #8b98a5 : #667586;
                    font-size: 13px;
                    font-weight: 800;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                Text {
                    visible: root.search-query == "";
                    x: 38px;
                    width: parent.width - 74px;
                    height: parent.height;
                    text: "Search";
                    color: root.dark ? #74808a : #687381;
                    font-size: 14px;
                    overflow: elide;
                    vertical-alignment: center;
                }

                TextInput {
                    x: 38px;
                    width: parent.width - 74px;
                    height: parent.height;
                    text <=> root.search-query;
                    single-line: true;
                    font-size: 14px;
                    vertical-alignment: center;
                    color: root.dark ? #f4f7fa : #202832;
                    selection-background-color: root.dark ? #51a9d4 : #2b86b7;
                    selection-foreground-color: root.dark ? #0f172a : #ffffff;
                    accepted => { root.search_submitted(self.text); }
                    changed has-focus => {
                        root.search-focused = self.has-focus;
                    }
                }

                close-search-touch := TouchArea {
                    x: parent.width - 32px;
                    width: 32px;
                    height: parent.height;
                    clicked => { root.search_close_requested(); }
                }

                Rectangle {
                    x: parent.width - 27px;
                    y: (parent.height - self.height) / 2;
                    width: 22px;
                    height: 22px;
                    border-radius: 7px;
                    background: close-search-touch.has-hover ? (root.dark ? #2a3036 : #edf1f5) : transparent;

                    Text {
                        text: "X";
                        color: root.dark ? #dce3ea : #526071;
                        font-size: 12px;
                        font-weight: 800;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }

            ToolButton {
                label: root.dark ? "L" : "D";
                dark: root.dark;
                clicked => { root.dark_toggled(); }
            }
        }
    }

    Rectangle {
        y: parent.height - 1px;
        width: parent.width;
        height: 1px;
        background: root.dark ? #252b31 : #e7edf3;
    }
}
