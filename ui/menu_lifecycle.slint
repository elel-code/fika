export global MenuLifecycle {
    in-out property <bool> open-with-open: false;
    in-out property <length> open-with-row-y: 0px;
    in-out property <bool> create-new-open: false;
    in-out property <length> create-new-row-y: 0px;
    in-out property <int> close-kind: 0;

    public function cancel-close() {
        root.close-kind = 0;
    }

    public function close-child-submenu(menu: int) {
        if (menu == 1) {
            root.open-with-open = false;
        } else if (menu == 2) {
            root.create-new-open = false;
        }
        if (root.close-kind == menu) {
            root.close-kind = 0;
        }
    }

    public function close-child-submenus() {
        root.open-with-open = false;
        root.create-new-open = false;
        root.close-kind = 0;
    }

    public function begin-close(menu: int) {
        if (menu == 1 || menu == 2) {
            root.close-kind = menu;
        }
    }

    public function show-open-with(row-y: length) {
        root.close-child-submenu(2);
        root.open-with-row-y = row-y;
        root.open-with-open = true;
        root.close-kind = 0;
    }

    public function show-create-new(row-y: length) {
        root.close-child-submenu(1);
        root.create-new-row-y = row-y;
        root.create-new-open = true;
        root.close-kind = 0;
    }

    public function close-pending-child-submenu() {
        root.close-child-submenu(root.close-kind);
    }
}

export component MenuLifecycleController inherits Rectangle {
    callback prepare_open_with(string);

    width: 0px;
    height: 0px;
    background: transparent;

    public function stop-close-timer() {
        close-timer.stop();
        MenuLifecycle.cancel-close();
    }

    public function close-child-submenus() {
        root.stop-close-timer();
        MenuLifecycle.close-child-submenus();
    }

    public function set-child-submenu-hover(menu: int, is-hovered: bool) {
        close-timer.stop();
        if (is-hovered) {
            MenuLifecycle.cancel-close();
        } else if (menu == 1 || menu == 2) {
            MenuLifecycle.begin-close(menu);
            close-timer.start();
        }
    }

    public function show-child-submenu(menu: int, path: string, row-y: length) {
        root.stop-close-timer();
        if (menu == 1) {
            root.prepare_open_with(path);
            MenuLifecycle.show-open-with(row-y);
        } else if (menu == 2) {
            MenuLifecycle.show-create-new(row-y);
        }
    }

    public function show-open-with-submenu(path: string, row-y: length) {
        root.show-child-submenu(1, path, row-y);
    }

    public function show-create-new-submenu(row-y: length) {
        root.show-child-submenu(2, "", row-y);
    }

    public function open-with-submenu-hover(path: string, row-y: length, is-hovered: bool) {
        if (is-hovered) {
            root.show-open-with-submenu(path, row-y);
        } else {
            root.set-child-submenu-hover(1, false);
        }
    }

    public function create-new-submenu-hover(row-y: length, is-hovered: bool) {
        if (is-hovered) {
            root.show-create-new-submenu(row-y);
        } else {
            root.set-child-submenu-hover(2, false);
        }
    }

    close-timer := Timer {
        running: false;
        interval: 240ms;
        triggered => {
            self.running = false;
            MenuLifecycle.close-pending-child-submenu();
        }
    }
}
