import { CheckOption, FilterButton, SidebarAction, ToolButton } from "widgets.slint";

component FilterChoiceChip inherits Rectangle {
    in property <string> label;
    in property <bool> selected;
    in property <bool> dark;
    callback clicked();

    height: 26px;
    border-radius: 7px;
    border-width: root.selected ? 1px : 0px;
    border-color: root.selected ? (root.dark ? #58b4d8 : #2f8dbc) : transparent;
    background: root.selected ? (root.dark ? #12303d : #e4f3fa) : (touch.has-hover ? (root.dark ? #1f262d : #f2f5f8) : transparent);

    touch := TouchArea {
        clicked => { root.clicked(); }
    }

    Text {
        width: parent.width;
        height: parent.height;
        text: root.label;
        color: root.selected ? (root.dark ? #e8f6fb : #17445a) : (root.dark ? #dfe7ee : #24303b);
        font-size: 12px;
        font-weight: root.selected ? 700 : 500;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
    }
}

component FilterChoiceRow inherits Rectangle {
    in property <string> title;
    in property <[string]> labels;
    in property <int> selected-index;
    in property <bool> dark;
    callback selected(int);

    height: 26px;
    background: transparent;

    HorizontalLayout {
        spacing: 6px;

        Text {
            width: 72px;
            text: root.title;
            color: root.dark ? #9aa5af : #64748b;
            font-size: 12px;
            font-weight: 700;
            vertical-alignment: center;
            overflow: elide;
        }

        for option[index] in root.labels: FilterChoiceChip {
            horizontal-stretch: 1;
            min-width: 48px;
            preferred-width: 76px;
            label: option;
            selected: root.selected-index == index;
            dark: root.dark;
            clicked => { root.selected(index); }
        }
    }
}

export component SearchPanel inherits Rectangle {
    in property <bool> dark;
    in property <bool> loading;
    in property <bool> filters-active;
    in property <string> kind-label;
    in property <string> modified-label;
    in property <string> size-label;
    in property <int> focus-request: 0;
    in-out property <string> query;
    in-out property <bool> recursive;
    in-out property <int> kind-filter;
    in-out property <int> modified-filter;
    in-out property <int> size-filter;
    in-out property <bool> filters-expanded: false;
    callback submitted(string, bool);
    callback cancel_requested();
    callback filters_changed(int, int, int);
    callback close_requested();
    callback focus_changed(bool);

    function clear-search-state() {
        root.query = "";
        root.recursive = false;
        root.kind-filter = 0;
        root.modified-filter = 0;
        root.size-filter = 0;
        root.filters-expanded = false;
        root.filters_changed(root.kind-filter, root.modified-filter, root.size-filter);
        root.submitted("", root.recursive);
    }

    function set-kind-filter(value: int) {
        root.kind-filter = value;
        root.filters_changed(root.kind-filter, root.modified-filter, root.size-filter);
    }

    function set-modified-filter(value: int) {
        root.modified-filter = value;
        root.filters_changed(root.kind-filter, root.modified-filter, root.size-filter);
    }

    function set-size-filter(value: int) {
        root.size-filter = value;
        root.filters_changed(root.kind-filter, root.modified-filter, root.size-filter);
    }

    background: transparent;
    border-width: 0px;

    private property <color> separator-color: root.dark ? #242b33 : #e5eaf0;
    private property <color> field-background: root.dark ? #151b20 : #ffffff;
    private property <color> field-focus-background: root.dark ? #12181d : #ffffff;
    private property <color> field-border: root.dark ? #2f3841 : #d8e1ea;
    private property <color> field-focus-border: root.dark ? #58b4d8 : #2f8dbc;
    private property <color> field-text-color: root.dark ? #eef3f7 : #24303b;
    private property <color> muted-text-color: root.dark ? #8b97a3 : #667381;
    private property <length> main-row-height: root.width < 760px ? 78px : 44px;

    changed focus-request => {
        if (root.focus-request > 0) {
            search-input.focus();
        }
    }

    Rectangle {
        y: parent.height - 1px;
        width: parent.width;
        height: 1px;
        background: root.separator-color;
    }

    FlexboxLayout {
        height: root.main-row-height;
        padding-left: 16px;
        padding-right: 16px;
        padding-top: 7px;
        padding-bottom: 7px;
        flex-wrap: wrap;
        align-content: start;
        align-items: center;
        spacing: 8px;

        Rectangle {
            min-width: 190px;
            preferred-width: 280px;
            max-width: 420px;
            height: 32px;
            flex-shrink: 1;
            border-radius: 8px;
            border-width: 1px;
            border-color: search-input.has-focus ? root.field-focus-border : root.field-border;
            background: search-input.has-focus ? root.field-focus-background : root.field-background;

            Text {
                x: 11px;
                width: 18px;
                height: parent.height;
                text: "S";
                color: root.muted-text-color;
                font-size: 13px;
                font-weight: 800;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            Text {
                visible: root.query == "";
                x: 36px;
                width: max(1px, parent.width - 48px);
                height: parent.height;
                text: "Search";
                color: root.muted-text-color;
                font-size: 14px;
                overflow: elide;
                vertical-alignment: center;
            }

            search-input := TextInput {
                x: 36px;
                width: max(1px, parent.width - 48px);
                height: parent.height;
                text <=> root.query;
                single-line: true;
                font-size: 14px;
                vertical-alignment: center;
                color: root.field-text-color;
                selection-background-color: root.dark ? #58b4d8 : #2f8dbc;
                selection-foreground-color: root.dark ? #0f172a : #ffffff;
                accepted => { root.submitted(self.text, root.recursive); }
                changed has-focus => { root.focus_changed(self.has-focus); }
                init => {
                    if (root.focus-request > 0) {
                        self.focus();
                    }
                }
            }
        }

        CheckOption {
            width: 148px;
            flex-shrink: 0;
            label: "Search subfolders";
            dark: root.dark;
            checked <=> root.recursive;
            toggled(_) => {
                if (root.query != "") {
                    root.submitted(root.query, root.recursive);
                }
            }
        }

        FilterButton {
            width: 116px;
            flex-shrink: 0;
            label: root.filters-active ? "Filters: On" : "Filters";
            dark: root.dark;
            clicked => {
                root.filters-expanded = !root.filters-expanded;
            }
        }

        Rectangle {
            flex-grow: 1;
            min-width: 1px;
            height: 1px;
            background: transparent;
        }

        if (root.loading): SidebarAction {
            width: 70px;
            flex-shrink: 0;
            label: "Cancel";
            dark: root.dark;
            clicked => { root.cancel_requested(); }
        }

        if (root.query != "" || root.filters-active): SidebarAction {
            width: 64px;
            flex-shrink: 0;
            label: "Clear";
            dark: root.dark;
            clicked => { root.clear-search-state(); }
        }

        ToolButton {
            flex-shrink: 0;
            label: "X";
            dark: root.dark;
            clicked => {
                root.clear-search-state();
                root.close_requested();
            }
        }
    }

    if (root.filters-expanded): Rectangle {
        x: 16px;
        y: root.main-row-height;
        width: max(1px, parent.width - 32px);
        height: parent.height - root.main-row-height - 7px;
        border-radius: 8px;
        border-width: 1px;
        border-color: root.field-border;
        background: root.field-background;

        VerticalLayout {
            padding-left: 10px;
            padding-right: 10px;
            padding-top: 7px;
            padding-bottom: 7px;
            spacing: 5px;

            FilterChoiceRow {
                width: parent.width;
                title: "Type";
                labels: ["All", "Folders", "Files", "Images"];
                selected-index: root.kind-filter;
                dark: root.dark;
                selected(index) => { root.set-kind-filter(index); }
            }

            FilterChoiceRow {
                width: parent.width;
                title: "Modified";
                labels: ["Any", "Today", "7 days", "30 days"];
                selected-index: root.modified-filter;
                dark: root.dark;
                selected(index) => { root.set-modified-filter(index); }
            }

            FilterChoiceRow {
                width: parent.width;
                title: "Size";
                labels: ["Any", "<1 MB", "1-100 MB", ">100 MB"];
                selected-index: root.size-filter;
                dark: root.dark;
                selected(index) => { root.set-size-filter(index); }
            }
        }
    }
}
