import { CheckOption, FilterButton, SidebarAction, ToolButton } from "widgets.slint";

export component SearchPanel inherits Rectangle {
    in property <bool> dark;
    in property <bool> loading;
    in property <bool> filters-active;
    in property <string> kind-label;
    in property <string> modified-label;
    in property <string> size-label;
    in-out property <string> query;
    in-out property <bool> recursive;
    in-out property <int> kind-filter;
    in-out property <int> modified-filter;
    in-out property <int> size-filter;
    callback submitted(string);
    callback cancel_requested();
    callback filters_changed(int, int, int);
    callback close_requested();

    function clear-search-state() {
        root.query = "";
        root.kind-filter = 0;
        root.modified-filter = 0;
        root.size-filter = 0;
        root.filters_changed(root.kind-filter, root.modified-filter, root.size-filter);
        root.submitted("");
    }

    background: root.dark ? #101316 : #f7f8fa;
    border-width: 0px;

    Rectangle {
        y: parent.height - 1px;
        width: parent.width;
        height: 1px;
        background: root.dark ? #242a30 : #e2e7ec;
    }

    FlexboxLayout {
        padding-left: 12px;
        padding-right: 12px;
        padding-top: 6px;
        padding-bottom: 6px;
        flex-wrap: wrap;
        align-content: start;
        align-items: center;
        spacing: 8px;

        CheckOption {
            width: 164px;
            flex-shrink: 0;
            label: "Search subfolders";
            dark: root.dark;
            checked <=> root.recursive;
            toggled(_) => {
                if (root.query != "") {
                    root.submitted(root.query);
                }
            }
        }

        FilterButton {
            width: 126px;
            flex-shrink: 0;
            label: root.kind-label;
            dark: root.dark;
            clicked => {
                root.kind-filter = mod(root.kind-filter + 1, 4);
                root.filters_changed(root.kind-filter, root.modified-filter, root.size-filter);
            }
        }

        FilterButton {
            width: 154px;
            flex-shrink: 0;
            label: root.modified-label;
            dark: root.dark;
            clicked => {
                root.modified-filter = mod(root.modified-filter + 1, 4);
                root.filters_changed(root.kind-filter, root.modified-filter, root.size-filter);
            }
        }

        FilterButton {
            width: 144px;
            flex-shrink: 0;
            label: root.size-label;
            dark: root.dark;
            clicked => {
                root.size-filter = mod(root.size-filter + 1, 4);
                root.filters_changed(root.kind-filter, root.modified-filter, root.size-filter);
            }
        }

        Rectangle {
            flex-grow: 1;
            min-width: 1px;
            height: 1px;
            background: transparent;
        }

        if (root.loading): SidebarAction {
            width: 70px;
            flex-shrink: 0;
            label: "Cancel";
            dark: root.dark;
            clicked => { root.cancel_requested(); }
        }

        if (root.query != "" || root.filters-active): SidebarAction {
            width: 64px;
            flex-shrink: 0;
            label: "Clear";
            dark: root.dark;
            clicked => { root.clear-search-state(); }
        }

        ToolButton {
            flex-shrink: 0;
            label: "X";
            dark: root.dark;
            clicked => {
                root.clear-search-state();
                root.close_requested();
            }
        }
    }
}
