import { FilterButton, SidebarAction, ToolButton } from "widgets.slint";

component SearchPopupOptionRow inherits Rectangle {
    in property <string> label;
    in property <bool> selected;
    in property <bool> dark;
    callback clicked();

    height: 30px;
    border-radius: 5px;
    background: root.selected ? (root.dark ? #1b2730 : #e8eef4) : (touch.has-hover ? (root.dark ? #1f262d : #f2f5f8) : transparent);

    touch := TouchArea {
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 8px;

        Text {
            width: 18px;
            height: parent.height;
            text: root.selected ? "X" : "";
            color: root.dark ? #dfe7ee : #24303b;
            font-size: 12px;
            font-weight: 800;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        Text {
            horizontal-stretch: 1;
            text: root.label;
            color: root.selected ? (root.dark ? #eef6fb : #1f3a4a) : (root.dark ? #dfe7ee : #24303b);
            font-size: 13px;
            font-weight: root.selected ? 700 : 500;
            overflow: elide;
            vertical-alignment: center;
        }
    }
}

component SearchPopupSelectorRow inherits Rectangle {
    in property <string> title;
    in property <string> value;
    in property <bool> dark;
    callback clicked();

    height: 32px;
    border-radius: 5px;
    background: touch.has-hover ? (root.dark ? #1f262d : #f2f5f8) : transparent;

    touch := TouchArea {
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 10px;

        Text {
            width: 104px;
            text: root.title;
            color: root.dark ? #9aa5af : #64748b;
            font-size: 12px;
            font-weight: 700;
            vertical-alignment: center;
            overflow: elide;
        }

        Text {
            horizontal-stretch: 1;
            text: root.value;
            color: root.dark ? #dfe7ee : #24303b;
            font-size: 13px;
            font-weight: 500;
            vertical-alignment: center;
            overflow: elide;
        }

        Text {
            width: 18px;
            height: parent.height;
            text: "v";
            color: root.dark ? #aeb8c2 : #64748b;
            font-size: 12px;
            font-weight: 800;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}

component SearchLocationButton inherits Rectangle {
    in property <string> label;
    in property <bool> selected;
    in property <bool> dark;
    callback clicked();

    height: 30px;
    border-radius: 5px;
    border-width: root.selected ? 1px : 0px;
    border-color: root.selected ? (root.dark ? #4a6170 : #c9d7e2) : transparent;
    background: root.selected ? (root.dark ? #1b2730 : #e8eef4) : (touch.has-hover ? (root.dark ? #1f262d : #f2f5f8) : transparent);

    touch := TouchArea {
        clicked => { root.clicked(); }
    }

    Text {
        x: 10px;
        width: max(1px, parent.width - 20px);
        height: parent.height;
        text: root.label;
        color: root.selected ? (root.dark ? #eef6fb : #1f3a4a) : (root.dark ? #dfe7ee : #24303b);
        font-size: 13px;
        font-weight: root.selected ? 700 : 500;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
    }
}

component SearchFilterChip inherits Rectangle {
    in property <string> label;
    in property <bool> dark;
    callback clicked();
    callback remove_requested();

    height: 30px;
    border-radius: 5px;
    border-width: 1px;
    border-color: root.dark ? #3f474f : #cdd8e3;
    background: root.dark ? #151b20 : #ffffff;

    HorizontalLayout {
        spacing: 0px;

        Rectangle {
            horizontal-stretch: 1;
            min-width: 54px;
            height: parent.height;
            background: open-touch.has-hover ? (root.dark ? #1f262d : #f2f5f8) : transparent;

            open-touch := TouchArea {
                clicked => { root.clicked(); }
            }

            Text {
                x: 10px;
                width: max(1px, parent.width - 34px);
                height: parent.height;
                text: root.label;
                color: root.dark ? #dfe7ee : #24303b;
                font-size: 13px;
                font-weight: 500;
                vertical-alignment: center;
                overflow: elide;
            }

            Text {
                x: max(10px, parent.width - 22px);
                width: 12px;
                height: parent.height;
                text: "v";
                color: root.dark ? #aeb8c2 : #64748b;
                font-size: 11px;
                font-weight: 800;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        Rectangle {
            width: 1px;
            height: parent.height;
            background: root.dark ? #303840 : #dde5ed;
        }

        Rectangle {
            width: 30px;
            height: parent.height;
            background: remove-touch.has-hover ? (root.dark ? #25303a : #eef3f7) : transparent;

            remove-touch := TouchArea {
                clicked => { root.remove_requested(); }
            }

            Text {
                width: parent.width;
                height: parent.height;
                text: "x";
                color: root.dark ? #aeb8c2 : #64748b;
                font-size: 13px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
}

export component SearchPanel inherits Rectangle {
    in property <bool> dark;
    in property <bool> loading;
    in property <bool> filters-active;
    in property <string> kind-label;
    in property <string> modified-label;
    in property <string> size-label;
    in property <int> focus-request: 0;
    in-out property <string> query;
    in-out property <bool> recursive;
    in-out property <int> kind-filter;
    in-out property <int> modified-filter;
    in-out property <int> size-filter;
    callback submitted(string, bool);
    callback cancel_requested();
    callback filters_changed(int, int, int);
    callback filter_menu_requested(length, length, int, int, int, int);
    callback close_requested();
    callback focus_changed(bool);

    function clear-search-state() {
        root.query = "";
        root.recursive = false;
        root.kind-filter = 0;
        root.modified-filter = 0;
        root.size-filter = 0;
        root.filters_changed(root.kind-filter, root.modified-filter, root.size-filter);
        root.submitted("", root.recursive);
    }

    function set-kind-filter(value: int) {
        root.kind-filter = value;
        root.filters_changed(root.kind-filter, root.modified-filter, root.size-filter);
    }

    function set-modified-filter(value: int) {
        root.modified-filter = value;
        root.filters_changed(root.kind-filter, root.modified-filter, root.size-filter);
    }

    function set-size-filter(value: int) {
        root.size-filter = value;
        root.filters_changed(root.kind-filter, root.modified-filter, root.size-filter);
    }

    function set-recursive-search(value: bool) {
        if (root.recursive == value) {
            return;
        }
        root.recursive = value;
        if (root.query != "") {
            root.submitted(root.query, root.recursive);
        }
    }

    function request-filter-menu(x: length, y: length, target-filter: int) {
        root.filter_menu_requested(x, y, root.kind-filter, root.modified-filter, root.size-filter, target-filter);
    }

    background: transparent;
    border-width: 0px;

    private property <color> separator-color: root.dark ? #242b33 : #e5eaf0;
    private property <color> field-background: root.dark ? #151b20 : #ffffff;
    private property <color> field-focus-background: root.dark ? #12181d : #ffffff;
    private property <color> field-border: root.dark ? #2f3841 : #d8e1ea;
    private property <color> field-focus-border: root.dark ? #58b4d8 : #2f8dbc;
    private property <color> field-text-color: root.dark ? #eef3f7 : #24303b;
    private property <color> muted-text-color: root.dark ? #8b97a3 : #667381;
    private property <length> second-row-height: root.width < 620px ? 64px : 30px;

    changed focus-request => {
        if (root.focus-request > 0) {
            search-input.focus();
        }
    }

    Rectangle {
        y: parent.height - 1px;
        width: parent.width;
        height: 1px;
        background: root.separator-color;
    }

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        padding-left: 8px;
        padding-right: 8px;
        padding-top: 7px;
        padding-bottom: 7px;
        spacing: 7px;

        HorizontalLayout {
            height: 32px;
            spacing: 8px;

            Rectangle {
                horizontal-stretch: 1;
                min-width: 190px;
                preferred-width: 420px;
                height: 32px;
                border-radius: 8px;
                border-width: 1px;
                border-color: search-input.has-focus ? root.field-focus-border : root.field-border;
                background: search-input.has-focus ? root.field-focus-background : root.field-background;

                Text {
                    x: 11px;
                    width: 18px;
                    height: parent.height;
                    text: "S";
                    color: root.muted-text-color;
                    font-size: 13px;
                    font-weight: 800;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                Text {
                    visible: root.query == "";
                    x: 36px;
                    width: max(1px, parent.width - 48px);
                    height: parent.height;
                    text: "Search...";
                    color: root.muted-text-color;
                    font-size: 14px;
                    overflow: elide;
                    vertical-alignment: center;
                }

                search-input := TextInput {
                    x: 36px;
                    width: max(1px, parent.width - 48px);
                    height: parent.height;
                    text <=> root.query;
                    single-line: true;
                    font-size: 14px;
                    vertical-alignment: center;
                    color: root.field-text-color;
                    selection-background-color: root.dark ? #58b4d8 : #2f8dbc;
                    selection-foreground-color: root.dark ? #0f172a : #ffffff;
                    accepted => { root.submitted(self.text, root.recursive); }
                    changed has-focus => { root.focus_changed(self.has-focus); }
                    init => {
                        if (root.focus-request > 0) {
                            self.focus();
                        }
                    }
                }
            }

            FilterButton {
                width: 104px;
                label: "Filter";
                dark: root.dark;
                clicked => {
                    root.request-filter-menu(self.absolute-position.x, self.absolute-position.y + self.height, 0);
                }
            }

            if (root.loading): SidebarAction {
                width: 70px;
                label: "Cancel";
                dark: root.dark;
                clicked => { root.cancel_requested(); }
            }

            ToolButton {
                label: "X";
                dark: root.dark;
                clicked => {
                    root.clear-search-state();
                    root.close_requested();
                }
            }
        }

        FlexboxLayout {
            height: root.second-row-height;
            flex-wrap: wrap;
            align-content: start;
            align-items: center;
            spacing: 6px;

            SearchLocationButton {
                width: 66px;
                flex-shrink: 0;
                label: "Here";
                selected: !root.recursive;
                dark: root.dark;
                clicked => { root.set-recursive-search(false); }
            }

            SearchLocationButton {
                width: 112px;
                flex-shrink: 0;
                label: "Everywhere";
                selected: root.recursive;
                dark: root.dark;
                clicked => { root.set-recursive-search(true); }
            }

            if (root.kind-filter != 0): SearchFilterChip {
                width: 150px;
                flex-shrink: 1;
                label: root.kind-label;
                dark: root.dark;
                clicked => {
                    root.request-filter-menu(self.absolute-position.x, self.absolute-position.y + self.height, 1);
                }
                remove_requested => { root.set-kind-filter(0); }
            }

            if (root.modified-filter != 0): SearchFilterChip {
                width: 166px;
                flex-shrink: 1;
                label: root.modified-label;
                dark: root.dark;
                clicked => {
                    root.request-filter-menu(self.absolute-position.x, self.absolute-position.y + self.height, 2);
                }
                remove_requested => { root.set-modified-filter(0); }
            }

            if (root.size-filter != 0): SearchFilterChip {
                width: 166px;
                flex-shrink: 1;
                label: root.size-label;
                dark: root.dark;
                clicked => {
                    root.request-filter-menu(self.absolute-position.x, self.absolute-position.y + self.height, 3);
                }
                remove_requested => { root.set-size-filter(0); }
            }

            Rectangle {
                flex-grow: 1;
                min-width: 1px;
                height: 1px;
                background: transparent;
            }
        }
    }
}

export component SearchFilterPopup inherits Rectangle {
    in property <bool> dark;
    in-out property <int> target-filter: 0;
    in-out property <int> kind-filter;
    in-out property <int> modified-filter;
    in-out property <int> size-filter;
    callback filters_changed(int, int, int);
    callback close_requested();

    function kind-label(value: int) -> string {
        if (value == 1) {
            return "Folders";
        }
        if (value == 2) {
            return "Files";
        }
        if (value == 3) {
            return "Images";
        }
        return "Any Type";
    }

    function modified-label(value: int) -> string {
        if (value == 1) {
            return "Today";
        }
        if (value == 2) {
            return "7 days";
        }
        if (value == 3) {
            return "30 days";
        }
        return "Any Date";
    }

    function size-label(value: int) -> string {
        if (value == 1) {
            return "<1 MB";
        }
        if (value == 2) {
            return "1-100 MB";
        }
        if (value == 3) {
            return ">100 MB";
        }
        return "Any";
    }

    function set-kind-filter(value: int) {
        root.kind-filter = value;
        root.filters_changed(root.kind-filter, root.modified-filter, root.size-filter);
        root.close_requested();
    }

    function set-modified-filter(value: int) {
        root.modified-filter = value;
        root.filters_changed(root.kind-filter, root.modified-filter, root.size-filter);
        root.close_requested();
    }

    function set-size-filter(value: int) {
        root.size-filter = value;
        root.filters_changed(root.kind-filter, root.modified-filter, root.size-filter);
        root.close_requested();
    }

    border-radius: 8px;
    border-width: 1px;
    border-color: root.dark ? #3f474f : #d9e1e8;
    background: root.dark ? #24282c : #fcfdfe;

    if (root.target-filter == 0): VerticalLayout {
        width: parent.width;
        height: parent.height;
        padding-left: 10px;
        padding-right: 10px;
        padding-top: 8px;
        padding-bottom: 8px;
        spacing: 6px;

        Text {
            width: parent.width;
            height: 24px;
            text: "Filter";
            color: root.dark ? #dfe7ee : #24303b;
            font-size: 13px;
            font-weight: 800;
            vertical-alignment: center;
        }

        SearchPopupSelectorRow {
            width: parent.width;
            title: "File Type:";
            value: root.kind-label(root.kind-filter);
            dark: root.dark;
            clicked => { root.target-filter = 1; }
        }

        SearchPopupSelectorRow {
            width: parent.width;
            title: "Modified since:";
            value: root.modified-label(root.modified-filter);
            dark: root.dark;
            clicked => { root.target-filter = 2; }
        }

        SearchPopupSelectorRow {
            width: parent.width;
            title: "Size:";
            value: root.size-label(root.size-filter);
            dark: root.dark;
            clicked => { root.target-filter = 3; }
        }
    }

    if (root.target-filter == 1): VerticalLayout {
        width: parent.width;
        height: parent.height;
        padding-left: 10px;
        padding-right: 10px;
        padding-top: 8px;
        padding-bottom: 8px;
        spacing: 6px;

        SearchPopupSelectorRow {
            width: parent.width;
            title: "Filter";
            value: "File Type";
            dark: root.dark;
            clicked => { root.target-filter = 0; }
        }

        for option[index] in ["Any Type", "Folders", "Files", "Images"]: SearchPopupOptionRow {
            width: parent.width;
            label: option;
            selected: root.kind-filter == index;
            dark: root.dark;
            clicked => { root.set-kind-filter(index); }
        }
    }

    if (root.target-filter == 2): VerticalLayout {
        width: parent.width;
        height: parent.height;
        padding-left: 10px;
        padding-right: 10px;
        padding-top: 8px;
        padding-bottom: 8px;
        spacing: 6px;

        SearchPopupSelectorRow {
            width: parent.width;
            title: "Filter";
            value: "Modified since";
            dark: root.dark;
            clicked => { root.target-filter = 0; }
        }

        for option[index] in ["Any Date", "Today", "7 days", "30 days"]: SearchPopupOptionRow {
            width: parent.width;
            label: option;
            selected: root.modified-filter == index;
            dark: root.dark;
            clicked => { root.set-modified-filter(index); }
        }
    }

    if (root.target-filter == 3): VerticalLayout {
        width: parent.width;
        height: parent.height;
        padding-left: 10px;
        padding-right: 10px;
        padding-top: 8px;
        padding-bottom: 8px;
        spacing: 6px;

        SearchPopupSelectorRow {
            width: parent.width;
            title: "Filter";
            value: "Size";
            dark: root.dark;
            clicked => { root.target-filter = 0; }
        }

        for option[index] in ["Any", "<1 MB", "1-100 MB", ">100 MB"]: SearchPopupOptionRow {
            width: parent.width;
            label: option;
            selected: root.size-filter == index;
            dark: root.dark;
            clicked => { root.set-size-filter(index); }
        }
    }
}
