import { FilterButton, SidebarAction, ToolButton } from "widgets.slint";

component SearchPopupSectionLabel inherits Text {
    in property <string> label;
    in property <bool> dark;
    in property <length> label-height: 18px;

    height: root.label-height;
    text: root.label;
    color: root.dark ? #9aa5af : #64748b;
    font-size: 12px;
    font-weight: 700;
    vertical-alignment: center;
    overflow: elide;
}

component SearchSelectorOption inherits Rectangle {
    in property <string> label;
    in property <bool> selected;
    in property <bool> dark;
    in property <length> option-height: 28px;
    callback clicked();

    private property <length> option-padding-x: min(8px, root.width / 8);
    private property <length> marker-width: min(18px, max(1px, root.width / 5));
    private property <length> option-gap: min(6px, root.width / 10);
    private property <length> label-x: min(32px, root.option-padding-x + root.marker-width + root.option-gap);

    height: root.option-height;
    border-radius: 4px;
    border-width: 0px;
    background: touch.has-hover ? (root.dark ? #1f262d : #f2f5f8) : transparent;

    touch := TouchArea {
        clicked => { root.clicked(); }
    }

    Text {
        x: root.option-padding-x;
        width: root.marker-width;
        height: parent.height;
        text: root.selected ? "X" : "";
        color: root.dark ? #58b4d8 : #2f8dbc;
        font-size: 11px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    Text {
        x: root.label-x;
        width: max(1px, parent.width - root.label-x - root.option-padding-x);
        height: parent.height;
        text: root.label;
        color: root.selected ? (root.dark ? #eef6fb : #1f3a4a) : (root.dark ? #dfe7ee : #24303b);
        font-size: 12px;
        font-weight: root.selected ? 700 : 500;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
    }
}

component SearchLocationButton inherits Rectangle {
    in property <string> label;
    in property <bool> selected;
    in property <bool> dark;
    callback clicked();

    height: 30px;
    border-radius: 5px;
    border-width: root.selected ? 1px : 0px;
    border-color: root.selected ? (root.dark ? #4a6170 : #c9d7e2) : transparent;
    background: root.selected ? (root.dark ? #1b2730 : #e8eef4) : (touch.has-hover ? (root.dark ? #1f262d : #f2f5f8) : transparent);

    touch := TouchArea {
        clicked => { root.clicked(); }
    }

    Text {
        x: 10px;
        width: max(1px, parent.width - 20px);
        height: parent.height;
        text: root.label;
        color: root.selected ? (root.dark ? #eef6fb : #1f3a4a) : (root.dark ? #dfe7ee : #24303b);
        font-size: 13px;
        font-weight: root.selected ? 700 : 500;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
    }
}

component SearchFilterChip inherits Rectangle {
    in property <string> label;
    in property <bool> dark;
    callback clicked();
    callback remove_requested();

    height: 30px;
    border-radius: 5px;
    border-width: 1px;
    border-color: root.dark ? #3f474f : #cdd8e3;
    background: root.dark ? #151b20 : #ffffff;

    HorizontalLayout {
        spacing: 0px;

        Rectangle {
            horizontal-stretch: 1;
            min-width: 54px;
            height: parent.height;
            background: open-touch.has-hover ? (root.dark ? #1f262d : #f2f5f8) : transparent;

            open-touch := TouchArea {
                clicked => { root.clicked(); }
            }

            Text {
                x: 10px;
                width: max(1px, parent.width - 34px);
                height: parent.height;
                text: root.label;
                color: root.dark ? #dfe7ee : #24303b;
                font-size: 13px;
                font-weight: 500;
                vertical-alignment: center;
                overflow: elide;
            }

            Text {
                x: max(10px, parent.width - 22px);
                width: 12px;
                height: parent.height;
                text: "v";
                color: root.dark ? #aeb8c2 : #64748b;
                font-size: 11px;
                font-weight: 800;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        Rectangle {
            width: 1px;
            height: parent.height;
            background: root.dark ? #303840 : #dde5ed;
        }

        Rectangle {
            width: 30px;
            height: parent.height;
            background: remove-touch.has-hover ? (root.dark ? #25303a : #eef3f7) : transparent;

            remove-touch := TouchArea {
                clicked => { root.remove_requested(); }
            }

            Text {
                width: parent.width;
                height: parent.height;
                text: "x";
                color: root.dark ? #aeb8c2 : #64748b;
                font-size: 13px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
}

export component SearchPanel inherits Rectangle {
    in property <bool> dark;
    in property <bool> loading;
    in property <bool> filters-active;
    in property <string> kind-label;
    in property <string> modified-label;
    in property <string> size-label;
    in property <int> focus-request: 0;
    in-out property <string> query;
    in-out property <bool> recursive;
    in-out property <int> kind-filter;
    in-out property <int> modified-filter;
    in-out property <int> size-filter;
    callback submitted(string, bool);
    callback cancel_requested();
    callback filters_changed(int, int, int);
    callback filter_menu_requested(length, length, int, int, int, int);
    callback close_requested();
    callback focus_changed(bool);

    private property <int> selector-all: 0;
    private property <int> selector-kind: 1;
    private property <int> selector-modified: 2;
    private property <int> selector-size: 3;

    function set-kind-filter(value: int) {
        root.kind-filter = value;
        root.filters_changed(root.kind-filter, root.modified-filter, root.size-filter);
    }

    function set-modified-filter(value: int) {
        root.modified-filter = value;
        root.filters_changed(root.kind-filter, root.modified-filter, root.size-filter);
    }

    function set-size-filter(value: int) {
        root.size-filter = value;
        root.filters_changed(root.kind-filter, root.modified-filter, root.size-filter);
    }

    function set-recursive-search(value: bool) {
        if (root.recursive == value) {
            return;
        }
        root.recursive = value;
        if (root.query != "") {
            root.submitted(root.query, root.recursive);
        }
    }

    function request-filter-menu(x: length, y: length, selector: int) {
        root.filter_menu_requested(x, y, root.kind-filter, root.modified-filter, root.size-filter, selector);
    }

    function schedule-search-submit() {
        search-submit-timer.stop();
        search-submit-timer.start();
    }

    function request-search-input-focus() {
        root.handled-focus-request = root.focus-request;
        if (root.focus-request <= 0) {
            return;
        }
        search-input.focus();
        focus-request-timer.stop();
        focus-request-timer.start();
    }

    background: transparent;
    border-width: 0px;

    private property <color> separator-color: root.dark ? #242b33 : #e5eaf0;
    private property <color> field-background: root.dark ? #151b20 : #ffffff;
    private property <color> field-focus-background: root.dark ? #12181d : #ffffff;
    private property <color> field-border: root.dark ? #2f3841 : #d8e1ea;
    private property <color> field-focus-border: root.dark ? #58b4d8 : #2f8dbc;
    private property <color> field-text-color: root.dark ? #eef3f7 : #24303b;
    private property <color> muted-text-color: root.dark ? #8b97a3 : #667381;
    private property <length> second-row-height: root.width < 620px ? 64px : 30px;
    private property <int> handled-focus-request: 0;

    search-submit-timer := Timer {
        running: false;
        interval: 500ms;
        triggered => {
            self.running = false;
            root.submitted(root.query, root.recursive);
        }
    }

    focus-request-timer := Timer {
        running: false;
        interval: 1ms;
        triggered => {
            self.running = false;
            search-input.focus();
        }
    }

    changed focus-request => {
        if (root.focus-request != root.handled-focus-request) {
            root.request-search-input-focus();
        }
    }

    Rectangle {
        y: parent.height - 1px;
        width: parent.width;
        height: 1px;
        background: root.separator-color;
    }

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        padding-left: 8px;
        padding-right: 8px;
        padding-top: 7px;
        padding-bottom: 7px;
        spacing: 7px;

        HorizontalLayout {
            height: 32px;
            spacing: 8px;

            Rectangle {
                horizontal-stretch: 1;
                min-width: 190px;
                preferred-width: 420px;
                height: 32px;
                border-radius: 8px;
                border-width: 1px;
                border-color: search-input.has-focus ? root.field-focus-border : root.field-border;
                background: search-input.has-focus ? root.field-focus-background : root.field-background;

                Text {
                    x: 11px;
                    width: 18px;
                    height: parent.height;
                    text: "S";
                    color: root.muted-text-color;
                    font-size: 13px;
                    font-weight: 800;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                Text {
                    visible: root.query == "";
                    x: 36px;
                    width: max(1px, parent.width - 48px);
                    height: parent.height;
                    text: "Search...";
                    color: root.muted-text-color;
                    font-size: 14px;
                    overflow: elide;
                    vertical-alignment: center;
                }

                search-input := TextInput {
                    x: 36px;
                    width: max(1px, parent.width - 48px);
                    height: parent.height;
                    text <=> root.query;
                    single-line: true;
                    font-size: 14px;
                    vertical-alignment: center;
                    color: root.field-text-color;
                    selection-background-color: root.dark ? #58b4d8 : #2f8dbc;
                    selection-foreground-color: root.dark ? #0f172a : #ffffff;
                    accepted => {
                        search-submit-timer.stop();
                        root.submitted(self.text, root.recursive);
                    }
                    key_pressed(event) => {
                        if (event.text == Key.Escape) {
                            if (root.query != "") {
                                root.query = "";
                                root.recursive = false;
                                search-submit-timer.stop();
                                root.submitted("", root.recursive);
                            } else {
                                search-submit-timer.stop();
                                root.close_requested();
                            }
                            return accept;
                        }
                        return reject;
                    }
                    changed text => {
                        if (self.has-focus) {
                            root.schedule-search-submit();
                        }
                    }
                    changed has-focus => { root.focus_changed(self.has-focus); }
                    init => {
                        root.request-search-input-focus();
                    }
                }
            }

            FilterButton {
                width: 104px;
                label: "Filter";
                dark: root.dark;
                clicked => {
                    root.request-filter-menu(self.absolute-position.x, self.absolute-position.y + self.height, root.selector-all);
                }
            }

            if (root.loading): SidebarAction {
                width: 70px;
                label: "Cancel";
                dark: root.dark;
                clicked => { root.cancel_requested(); }
            }

            ToolButton {
                label: "X";
                dark: root.dark;
                clicked => {
                    search-submit-timer.stop();
                    root.close_requested();
                }
            }
        }

        FlexboxLayout {
            height: root.second-row-height;
            flex-wrap: wrap;
            align-content: start;
            align-items: center;
            spacing: 6px;

            SearchLocationButton {
                width: 66px;
                flex-shrink: 0;
                label: "Here";
                selected: !root.recursive;
                dark: root.dark;
                clicked => { root.set-recursive-search(false); }
            }

            SearchLocationButton {
                width: 112px;
                flex-shrink: 0;
                label: "Everywhere";
                selected: root.recursive;
                dark: root.dark;
                clicked => { root.set-recursive-search(true); }
            }

            Rectangle {
                flex-grow: 1;
                min-width: 1px;
                height: 1px;
                background: transparent;
            }

            if (root.kind-filter != 0): SearchFilterChip {
                width: 150px;
                flex-shrink: 1;
                label: root.kind-label;
                dark: root.dark;
                clicked => {
                    root.request-filter-menu(self.absolute-position.x, self.absolute-position.y + self.height, root.selector-kind);
                }
                remove_requested => { root.set-kind-filter(0); }
            }

            if (root.modified-filter != 0): SearchFilterChip {
                width: 166px;
                flex-shrink: 1;
                label: root.modified-label;
                dark: root.dark;
                clicked => {
                    root.request-filter-menu(self.absolute-position.x, self.absolute-position.y + self.height, root.selector-modified);
                }
                remove_requested => { root.set-modified-filter(0); }
            }

            if (root.size-filter != 0): SearchFilterChip {
                width: 166px;
                flex-shrink: 1;
                label: root.size-label;
                dark: root.dark;
                clicked => {
                    root.request-filter-menu(self.absolute-position.x, self.absolute-position.y + self.height, root.selector-size);
                }
                remove_requested => { root.set-size-filter(0); }
            }
        }
    }
}

component SearchFilterSelectorButton inherits Rectangle {
    in property <string> label;
    in property <bool> dark;
    in property <length> control-height: 30px;
    callback clicked();

    private property <length> control-padding-x: min(9px, root.width / 6);
    private property <length> arrow-width: min(14px, max(1px, root.width / 5));
    private property <length> arrow-x: max(0px, root.width - root.control-padding-x - root.arrow-width);

    height: root.control-height;
    border-radius: 4px;
    border-width: 1px;
    border-color: root.dark ? #3c444c : #cfd8e3;
    background: touch.has-hover ? (root.dark ? #20272e : #eef3f7) : (root.dark ? #151b20 : #ffffff);

    touch := TouchArea {
        clicked => { root.clicked(); }
    }

    Text {
        x: root.control-padding-x;
        width: max(1px, root.arrow-x - root.control-padding-x - 4px);
        height: parent.height;
        text: root.label;
        color: root.dark ? #dfe7ee : #24303b;
        font-size: 13px;
        vertical-alignment: center;
        overflow: elide;
    }

    Text {
        x: root.arrow-x;
        width: root.arrow-width;
        height: parent.height;
        text: "v";
        color: root.dark ? #aeb8c2 : #64748b;
        font-size: 11px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

export component SearchFilterPopup inherits Rectangle {
    in property <bool> dark;
    in-out property <int> kind-filter;
    in-out property <int> modified-filter;
    in-out property <int> size-filter;
    callback filters_changed(int, int, int);
    callback selector_requested(length, length, length, int);
    callback close_requested();

    private property <int> selector-kind: 1;
    private property <int> selector-modified: 2;
    private property <int> selector-size: 3;
    private property <length> popup-padding-x: 12px;
    private property <length> popup-padding-y: 10px;
    private property <length> popup-title-height: 22px;
    private property <length> popup-body-spacing: 8px;
    private property <length> selector-available-height: max(1px, root.height - root.popup-padding-y * 2 - root.popup-title-height - root.popup-body-spacing * 2);
    private property <length> selector-group-height: max(1px, root.selector-available-height / 2);
    private property <length> selector-label-height: min(16px, max(1px, root.selector-group-height / 3));
    private property <length> selector-gap: min(4px, root.selector-group-height / 12);
    private property <length> selector-height: max(1px, root.selector-group-height - root.selector-label-height - root.selector-gap);
    private property <length> content-width: max(1px, root.width - root.popup-padding-x * 2);
    private property <length> selector-column-gap: min(10px, root.content-width / 8);
    private property <length> selector-column-width: max(1px, (root.content-width - root.selector-column-gap) / 2);
    private property <string> kind-selector-label: root.kind-filter == 1 ? "Folders" : (root.kind-filter == 2 ? "Files" : (root.kind-filter == 3 ? "Images" : "Any Type"));
    private property <string> modified-selector-label: root.modified-filter == 1 ? "Today" : (root.modified-filter == 2 ? "7 days" : (root.modified-filter == 3 ? "30 days" : "Any Date"));
    private property <string> size-selector-label: root.size-filter == 1 ? "<1 MB" : (root.size-filter == 2 ? "1-100 MB" : (root.size-filter == 3 ? ">100 MB" : "Any"));

    border-radius: 6px;
    border-width: 1px;
    border-color: root.dark ? #3f474f : #d9e1e8;
    background: root.dark ? #24282c : #fcfdfe;

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        padding-left: root.popup-padding-x;
        padding-right: root.popup-padding-x;
        padding-top: root.popup-padding-y;
        padding-bottom: root.popup-padding-y;
        spacing: root.popup-body-spacing;

        Text {
            width: root.content-width;
            height: root.popup-title-height;
            text: "Filter";
            color: root.dark ? #dfe7ee : #24303b;
            font-size: 13px;
            font-weight: 800;
            vertical-alignment: center;
        }

        HorizontalLayout {
            width: root.content-width;
            height: root.selector-group-height;
            spacing: root.selector-column-gap;

            Rectangle {
                width: root.selector-column-width;
                height: root.selector-group-height;
                background: transparent;

                SearchPopupSectionLabel {
                    width: parent.width;
                    label-height: root.selector-label-height;
                    label: "File Type:";
                    dark: root.dark;
                }

                SearchFilterSelectorButton {
                    y: root.selector-label-height + root.selector-gap;
                    width: parent.width;
                    control-height: root.selector-height;
                    label: root.kind-selector-label;
                    dark: root.dark;
                    clicked => { root.selector_requested(self.absolute-position.x, self.absolute-position.y + self.height, self.width, root.selector-kind); }
                }
            }

            Rectangle {
                width: root.selector-column-width;
                height: root.selector-group-height;
                background: transparent;

                SearchPopupSectionLabel {
                    width: parent.width;
                    label-height: root.selector-label-height;
                    label: "Modified since:";
                    dark: root.dark;
                }

                SearchFilterSelectorButton {
                    y: root.selector-label-height + root.selector-gap;
                    width: parent.width;
                    control-height: root.selector-height;
                    label: root.modified-selector-label;
                    dark: root.dark;
                    clicked => { root.selector_requested(self.absolute-position.x, self.absolute-position.y + self.height, self.width, root.selector-modified); }
                }
            }
        }

        Rectangle {
            width: root.selector-column-width;
            height: root.selector-group-height;
            background: transparent;

            SearchPopupSectionLabel {
                width: parent.width;
                label-height: root.selector-label-height;
                label: "Size:";
                dark: root.dark;
            }

            SearchFilterSelectorButton {
                y: root.selector-label-height + root.selector-gap;
                width: parent.width;
                control-height: root.selector-height;
                label: root.size-selector-label;
                dark: root.dark;
                clicked => { root.selector_requested(self.absolute-position.x, self.absolute-position.y + self.height, self.width, root.selector-size); }
            }
        }
    }
}

export component SearchFilterDropdown inherits Rectangle {
    in property <bool> dark;
    in property <int> selector-mode: 1;
    in-out property <int> kind-filter;
    in-out property <int> modified-filter;
    in-out property <int> size-filter;
    callback filters_changed(int, int, int);
    callback close_requested();

    private property <int> selector-kind: 1;
    private property <int> selector-modified: 2;
    private property <int> selector-size: 3;
    private property <length> popup-padding: min(4px, root.width / 6);
    private property <length> content-width: max(1px, root.width - root.popup-padding * 2);
    private property <length> option-height: max(1px, (root.height - root.popup-padding * 2) / 4);

    function set-kind-filter(value: int) {
        if (root.kind-filter != value) {
            root.kind-filter = value;
            root.filters_changed(root.kind-filter, root.modified-filter, root.size-filter);
        }
        root.close_requested();
    }

    function set-modified-filter(value: int) {
        if (root.modified-filter != value) {
            root.modified-filter = value;
            root.filters_changed(root.kind-filter, root.modified-filter, root.size-filter);
        }
        root.close_requested();
    }

    function set-size-filter(value: int) {
        if (root.size-filter != value) {
            root.size-filter = value;
            root.filters_changed(root.kind-filter, root.modified-filter, root.size-filter);
        }
        root.close_requested();
    }

    border-radius: 6px;
    border-width: 1px;
    border-color: root.dark ? #3f474f : #d9e1e8;
    background: root.dark ? #24282c : #fcfdfe;

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        padding: root.popup-padding;
        spacing: 0px;

        if (root.selector-mode == root.selector-kind): SearchSelectorOption {
            width: root.content-width;
            option-height: root.option-height;
            label: "Any Type";
            selected: root.kind-filter == 0;
            dark: root.dark;
            clicked => { root.set-kind-filter(0); }
        }
        if (root.selector-mode == root.selector-kind): SearchSelectorOption {
            width: root.content-width;
            option-height: root.option-height;
            label: "Folders";
            selected: root.kind-filter == 1;
            dark: root.dark;
            clicked => { root.set-kind-filter(1); }
        }
        if (root.selector-mode == root.selector-kind): SearchSelectorOption {
            width: root.content-width;
            option-height: root.option-height;
            label: "Files";
            selected: root.kind-filter == 2;
            dark: root.dark;
            clicked => { root.set-kind-filter(2); }
        }
        if (root.selector-mode == root.selector-kind): SearchSelectorOption {
            width: root.content-width;
            option-height: root.option-height;
            label: "Images";
            selected: root.kind-filter == 3;
            dark: root.dark;
            clicked => { root.set-kind-filter(3); }
        }

        if (root.selector-mode == root.selector-modified): SearchSelectorOption {
            width: root.content-width;
            option-height: root.option-height;
            label: "Any Date";
            selected: root.modified-filter == 0;
            dark: root.dark;
            clicked => { root.set-modified-filter(0); }
        }
        if (root.selector-mode == root.selector-modified): SearchSelectorOption {
            width: root.content-width;
            option-height: root.option-height;
            label: "Today";
            selected: root.modified-filter == 1;
            dark: root.dark;
            clicked => { root.set-modified-filter(1); }
        }
        if (root.selector-mode == root.selector-modified): SearchSelectorOption {
            width: root.content-width;
            option-height: root.option-height;
            label: "7 days";
            selected: root.modified-filter == 2;
            dark: root.dark;
            clicked => { root.set-modified-filter(2); }
        }
        if (root.selector-mode == root.selector-modified): SearchSelectorOption {
            width: root.content-width;
            option-height: root.option-height;
            label: "30 days";
            selected: root.modified-filter == 3;
            dark: root.dark;
            clicked => { root.set-modified-filter(3); }
        }

        if (root.selector-mode == root.selector-size): SearchSelectorOption {
            width: root.content-width;
            option-height: root.option-height;
            label: "Any";
            selected: root.size-filter == 0;
            dark: root.dark;
            clicked => { root.set-size-filter(0); }
        }
        if (root.selector-mode == root.selector-size): SearchSelectorOption {
            width: root.content-width;
            option-height: root.option-height;
            label: "<1 MB";
            selected: root.size-filter == 1;
            dark: root.dark;
            clicked => { root.set-size-filter(1); }
        }
        if (root.selector-mode == root.selector-size): SearchSelectorOption {
            width: root.content-width;
            option-height: root.option-height;
            label: "1-100 MB";
            selected: root.size-filter == 2;
            dark: root.dark;
            clicked => { root.set-size-filter(2); }
        }
        if (root.selector-mode == root.selector-size): SearchSelectorOption {
            width: root.content-width;
            option-height: root.option-height;
            label: ">100 MB";
            selected: root.size-filter == 3;
            dark: root.dark;
            clicked => { root.set-size-filter(3); }
        }
    }
}
