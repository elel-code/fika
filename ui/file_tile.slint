import { FileEntry } from "models.slint";
import { FolderGlyph } from "widgets.slint";

export component FileTile inherits Rectangle {
    in property <FileEntry> entry;
    in property <bool> selected;
    in property <bool> dark;
    in property <int> zoom-level;
    in property <bool> drop-target;
    in property <bool> show-location;
    callback activated(string);
    callback request_select(string, bool, bool);
    callback request_context_menu(string, string, length, length);
    callback zoom_in();
    callback zoom_out();
    callback pan_horizontal(length);

    height: root.zoom-level == 0 ? 72px : (root.zoom-level == 1 ? 84px : (root.zoom-level == 2 ? 98px : (root.zoom-level == 3 ? 116px : 136px)));
    border-radius: 6px;
    border-width: selected || drop-target ? 1px : 0px;
    border-color: drop-target ? (dark ? #f59e0b : #d97706) : (dark ? #38bdf8 : #0284c7);
    background: drop-target ? (dark ? #3a2a12 : #fff7dd) : (selected ? (dark ? #132b3a : #e6f4ff) : (touch-area.has-hover ? (dark ? #191e23 : #f3f7fb) : transparent));

    drag-area := DragArea {
        enabled: root.entry.path != "";
        mime-type: root.entry.is_dir ? "application/x-fika-folder-path" : "application/x-fika-file-path";
        data: root.entry.path;

        touch-area := TouchArea {
            width: parent.width;
            height: parent.height;

            pointer-event(event) => {
                if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                    root.request_select(root.entry.path, event.modifiers.control, event.modifiers.shift);
                } else if (event.button == PointerEventButton.right && event.kind == PointerEventKind.down) {
                    root.request_context_menu(root.entry.path, root.entry.name, self.absolute-position.x + self.mouse-x, self.absolute-position.y + self.mouse-y);
                }
            }

            double-clicked => {
                root.activated(root.entry.path);
            }

            scroll-event(event) => {
                if (event.modifiers.control && event.delta-y < 0px) {
                    root.zoom_out();
                    return accept;
                } else if (event.modifiers.control && event.delta-y > 0px) {
                    root.zoom_in();
                    return accept;
                } else {
                    root.pan_horizontal(-(event.delta-y + event.delta-x));
                    return accept;
                }
            }
        }

        HorizontalLayout {
            padding-left: root.zoom-level < 2 ? 12px : 16px;
            padding-right: root.zoom-level < 2 ? 12px : 16px;
            spacing: root.zoom-level < 2 ? 10px : 12px;

            if (!root.entry.is_dir && root.entry.thumbnail_state == 2): Image {
                width: root.zoom-level == 0 ? 52px : (root.zoom-level == 1 ? 64px : (root.zoom-level == 2 ? 80px : (root.zoom-level == 3 ? 96px : 112px)));
                height: root.zoom-level == 0 ? 46px : (root.zoom-level == 1 ? 58px : (root.zoom-level == 2 ? 70px : (root.zoom-level == 3 ? 84px : 98px)));
                source: root.entry.thumbnail;
                image-fit: contain;
            }

            if (root.entry.is_dir || root.entry.thumbnail_state != 2): FolderGlyph {
                dir: root.entry.is_dir;
                dark: root.dark;
                zoom-level: root.zoom-level;
            }

            VerticalLayout {
                alignment: center;
                spacing: 2px;

                if (root.show-location && root.entry.group != ""): Text {
                    text: root.entry.group;
                    color: root.dark ? #93c5fd : #2563eb;
                    font-size: root.zoom-level < 2 ? 10px : 11px;
                    font-weight: 700;
                    overflow: elide;
                }

                Text {
                    text: root.entry.name;
                    color: root.dark ? #e7e7e7 : #17212b;
                    font-size: root.zoom-level == 0 ? 12px : (root.zoom-level == 1 ? 13px : (root.zoom-level == 2 ? 15px : (root.zoom-level == 3 ? 16px : 18px)));
                    overflow: elide;
                    vertical-alignment: center;
                }

                if (root.show-location && root.entry.location != ""): Text {
                    text: root.entry.location;
                    color: root.dark ? #9ca3af : #64748b;
                    font-size: root.zoom-level < 2 ? 10px : 11px;
                    overflow: elide;
                }
            }
        }
    }
}
