export struct ItemViewEntry {
    name: string,
    path: string,
    is_dir: bool,
    thumbnail_state: int,
    media: image,
    media_token: int,
}

export struct ItemViewHighlightEntry {
    slice_index: int,
}

export struct ItemViewMetadataEntry {
    slice_index: int,
    text: string,
    text_x: float,
    text_width: float,
    y: float,
    line_height: float,
    font_size: float,
    is_group: bool,
}

export struct PlaceEntry {
    label: string,
    path: string,
    marker: string,
    is_builtin: bool,
}

export struct DeviceEntry {
    label: string,
    path: string,
    device_path: string,
    kind: string,
    marker: string,
    mounted: bool,
    can_mount: bool,
    can_unmount: bool,
    can_eject: bool,
    pending_action: string,
    error: string,
}

export struct DesktopApp {
    id: string,
    name: string,
    is_default: bool,
}

export struct ContextServiceAction {
    id: string,
    name: string,
    icon: image,
    has_icon: bool,
    group: string,
    action_index: int,
    row_kind: int,
}

export struct ContextServicePolicyAction {
    id: string,
    name: string,
    icon: image,
    has_icon: bool,
    group: string,
    enabled: bool,
}

export struct ChooserChoiceOption {
    label: string,
}

export struct ChooserChoice {
    label: string,
    selected_label: string,
    selected_index: int,
    options: [ChooserChoiceOption],
}

export struct PaneViewData {
    slot: int,
    entry_count: int,
    virtual_start_column: int,
    virtual_start_row: int,
    viewport_x: float,
    item_view_rows_per_column: int,
    item_view_cell_width: float,
    item_view_column_width: float,
    item_view_column_offset: float,
    item_view_row_height: float,
    item_view_padding: float,
    item_view_content_width: float,
    item_view_virtual_slice_width: float,
    item_view_scroll_max_x: float,
    item_view_media_x: float,
    item_view_media_y: float,
    item_view_media_width: float,
    item_view_media_height: float,
    item_view_text_x: float,
    item_view_text_width: float,
    item_view_title_y: float,
    item_view_title_line_height: float,
    item_view_title_font_size: float,
    item_view_folder_media: image,
    item_view_file_media: image,
    show_location: bool,
    content_interactive: bool,
    drop_ready: bool,
    empty_message_visible: bool,
    empty_title: string,
    empty_subtitle: string,
}

export struct PaneSlotData {
    slot: int,
    current_path: string,
    path_text: string,
    path_focused: bool,
    can_go_back: bool,
    can_go_forward: bool,
    search_panel_visible: bool,
    search_panel_height_px: float,
    search_loading: bool,
    search_query: string,
    recursive_search: bool,
    search_kind_filter: int,
    search_modified_filter: int,
    search_size_filter: int,
    search_filters_active: bool,
    search_focus_request: int,
    search_kind_label: string,
    search_modified_label: string,
    search_size_label: string,
    drop_trace_prefix: string,
    status: string,
    selected_count: int,
    selected_status: string,
    external_edit_active: bool,
    external_edit_status: string,
    undo_available: bool,
    undo_label: string,
    chooser_mode: bool,
    chooser_select_directories: bool,
    chooser_save_mode: bool,
    chooser_accept_label: string,
    focused_selected_path: string,
    chooser_filter_count: int,
    chooser_filter_label: string,
    chooser_choices: [ChooserChoice],
}
