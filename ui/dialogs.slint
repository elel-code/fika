export component ServiceMenuPolicyDialog inherits Rectangle {
    in property <bool> dark;
    in property <[ContextServicePolicyAction]> actions;
    callback action_toggled(string, bool);
    callback closed();

    border-radius: 8px;
    background: root.dark ? #24282c : #fcfdfe;
    border-width: 1px;
    border-color: root.dark ? #3f474f : #d9e1e8;

    VerticalLayout {
        padding: 14px;
        spacing: 10px;

        Text {
            text: "Service Actions";
            color: root.dark ? #f1f1f1 : #17212b;
            font-size: 14px;
            font-weight: 700;
        }

        ScrollView {
            vertical-stretch: 1;
            horizontal-scrollbar-policy: as-needed;
            vertical-scrollbar-policy: as-needed;
            viewport-width: parent.width;
            viewport-height: max(38px, root.actions.length * 38px);

            if (root.actions.length == 0): Text {
                text: "No service actions for this selection.";
                height: 38px;
                x: 12px;
                width: parent.width - 24px;
                color: root.dark ? #d8d8d8 : #475569;
                font-size: 13px;
                overflow: elide;
                vertical-alignment: center;
            }

            for action[index] in root.actions: CheckOption {
                y: index * 38px;
                height: 34px;
                width: parent.width;
                label: action.group == "" ? action.name : (action.group + " / " + action.name);
                dark: root.dark;
                checked: action.enabled;
                toggled(enabled) => { root.action_toggled(action.id, enabled); }
            }
        }

        HorizontalLayout {
            spacing: 8px;
            Rectangle { horizontal-stretch: 1; }

            MenuItem {
                width: 82px;
                label: "Close";
                dark: root.dark;
                clicked => { root.closed(); }
            }
        }
    }
}

export component ServiceMenuPolicyPopup inherits Rectangle {
    in property <bool> dark;
    in property <[ContextServicePolicyAction]> actions;
    callback action_toggled(string, bool);
    callback closed();

    background: transparent;

    ServiceMenuPolicyDialog {
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;
        width: 460px;
        height: 420px;
        dark: root.dark;
        actions: root.actions;
        action_toggled(id, enabled) => { root.action_toggled(id, enabled); }
        closed => { root.closed(); }
    }
}

export component OtherApplicationsDialog inherits Rectangle {
    in property <bool> dark;
    in property <[DesktopApp]> apps;
    in-out property <string> filter;
    in-out property <string> custom-command;
    in-out property <bool> set-default;
    callback filter_changed(string);
    callback app_selected(string, bool);
    callback custom_open(string);
    callback cancelled();

    border-radius: 8px;
    background: root.dark ? #24282c : #fcfdfe;
    border-width: 1px;
    border-color: root.dark ? #3f474f : #d9e1e8;

    VerticalLayout {
        padding: 14px;
        spacing: 10px;

        Text {
            text: "Other Applications";
            color: root.dark ? #f1f1f1 : #17212b;
            font-size: 14px;
            font-weight: 700;
        }

        CheckOption {
            label: "Set selected application as default";
            dark: root.dark;
            checked <=> root.set-default;
        }

        LineEdit {
            text <=> root.filter;
            height: 34px;
            placeholder-text: "Filter applications";
            changed text => { root.filter_changed(self.text); }
        }

        ScrollView {
            vertical-stretch: 1;
            horizontal-scrollbar-policy: as-needed;
            vertical-scrollbar-policy: as-needed;
            viewport-width: parent.width;
            viewport-height: max(38px, root.apps.length * 38px);

            if (root.apps.length == 0): Text {
                text: "Loading applications...";
                height: 38px;
                x: 12px;
                width: parent.width - 24px;
                color: root.dark ? #d8d8d8 : #475569;
                font-size: 13px;
                overflow: elide;
                vertical-alignment: center;
            }

            for app[index] in root.apps: MenuItem {
                y: index * 38px;
                height: 38px;
                width: parent.width;
                label: (app.is_default ? "Default: " : "Open: ") + app.name;
                dark: root.dark;
                clicked => { root.app_selected(app.id, root.set-default); }
            }
        }

        LineEdit {
            text <=> root.custom-command;
            height: 36px;
            placeholder-text: "Custom command...";
            accepted => { root.custom_open(self.text); }
        }

        HorizontalLayout {
            spacing: 8px;
            Rectangle { horizontal-stretch: 1; }

            MenuItem {
                width: 82px;
                label: "Cancel";
                dark: root.dark;
                clicked => { root.cancelled(); }
            }

            MenuItem {
                width: 82px;
                label: "Open";
                dark: root.dark;
                clicked => { root.custom_open(root.custom-command); }
            }
        }
    }
}

export component OtherApplicationsPopup inherits Rectangle {
    in property <bool> dark;
    in property <[DesktopApp]> apps;
    in-out property <string> filter;
    in-out property <string> custom-command;
    in-out property <bool> set-default;
    callback filter_changed(string);
    callback app_selected(string, bool);
    callback custom_open(string);
    callback cancelled();

    background: transparent;

    OtherApplicationsDialog {
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;
        width: 460px;
        height: 460px;
        dark: root.dark;
        apps: root.apps;
        filter <=> root.filter;
        custom-command <=> root.custom-command;
        set-default <=> root.set-default;
        filter_changed(query) => { root.filter_changed(query); }
        app_selected(app-id, set-default) => { root.app_selected(app-id, set-default); }
        custom_open(command) => { root.custom_open(command); }
        cancelled => { root.cancelled(); }
    }
}

export component TransferConflictDialog inherits Rectangle {
    in property <bool> dark;
    in property <string> source;
    in property <string> target;
    in-out property <string> rename-name;
    in-out property <bool> apply-all;
    callback choice(string);

    border-radius: 8px;
    background: root.dark ? #24282c : #fcfdfe;
    border-width: 1px;
    border-color: root.dark ? #3f474f : #d9e1e8;

    VerticalLayout {
        padding: 16px;
        spacing: 10px;

        Text {
            text: "File Already Exists";
            color: root.dark ? #f8fafc : #17212b;
            font-size: 15px;
            font-weight: 700;
        }

        Text {
            text: "A file or folder named \"" + root.target + "\" already exists.";
            color: root.dark ? #d8dee5 : #334155;
            font-size: 13px;
            wrap: word-wrap;
            max-height: 42px;
        }

        Text {
            text: "Source: " + root.source;
            color: root.dark ? #a8a8a8 : #64748b;
            font-size: 12px;
            overflow: elide;
        }

        HorizontalLayout {
            spacing: 10px;

            Text {
                text: "Rename to";
                color: root.dark ? #d8dee5 : #334155;
                font-size: 13px;
                min-width: 74px;
                vertical-alignment: center;
            }

            LineEdit {
                horizontal-stretch: 1;
                height: 34px;
                text <=> root.rename-name;
                accepted => {
                    root.choice(root.apply-all ? ("all:rename:" + self.text) : ("rename:" + self.text));
                }
            }
        }

        CheckOption {
            width: 300px;
            label: "Apply this choice to remaining conflicts";
            dark: root.dark;
            checked <=> root.apply-all;
        }

        if (root.apply-all): Text {
            text: "Rename uses unique suggested names for each remaining conflict.";
            color: root.dark ? #a8b2bd : #64748b;
            font-size: 12px;
        }

        Rectangle { vertical-stretch: 1; }

        HorizontalLayout {
            spacing: 8px;
            Rectangle { horizontal-stretch: 1; }

            MenuItem {
                width: 74px;
                label: "Skip";
                dark: root.dark;
                clicked => { root.choice(root.apply-all ? "all:skip" : "skip"); }
            }

            MenuItem {
                width: 86px;
                label: "Rename";
                dark: root.dark;
                clicked => { root.choice(root.apply-all ? ("all:rename:" + root.rename-name) : ("rename:" + root.rename-name)); }
            }

            MenuItem {
                width: 88px;
                label: "Keep Both";
                dark: root.dark;
                clicked => { root.choice(root.apply-all ? "all:keep-both" : "keep-both"); }
            }

            MenuItem {
                width: 92px;
                label: "Overwrite";
                dark: root.dark;
                clicked => { root.choice(root.apply-all ? "all:overwrite" : "overwrite"); }
            }
        }
    }
}

export component TransferConflictPopup inherits Rectangle {
    in property <bool> dark;
    in property <string> source;
    in property <string> target;
    in-out property <string> rename-name;
    in-out property <bool> apply-all;
    callback choice(string);

    background: transparent;

    TransferConflictDialog {
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;
        width: 480px;
        height: 310px;
        dark: root.dark;
        source: root.source;
        target: root.target;
        rename-name <=> root.rename-name;
        apply-all <=> root.apply-all;
        choice(decision) => { root.choice(decision); }
    }
}
