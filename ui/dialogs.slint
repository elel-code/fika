import { LineEdit, ScrollView } from "std-widgets.slint";
import { ContextServicePolicyAction, DesktopApp } from "models.slint";
import { CheckOption, MenuItem } from "widgets.slint";

export component TextInputDialog inherits Rectangle {
    in property <bool> dark;
    in property <string> title;
    in property <string> accept-label;
    in-out property <string> value;
    callback accepted(string);
    callback cancelled();

    border-radius: 8px;
    background: root.dark ? #24282c : #fcfdfe;
    border-width: 1px;
    border-color: root.dark ? #3f474f : #d9e1e8;

    VerticalLayout {
        padding: 14px;
        spacing: 10px;

        Text {
            text: root.title;
            color: root.dark ? #f1f1f1 : #17212b;
            font-size: 14px;
            font-weight: 700;
        }

        LineEdit {
            text <=> root.value;
            accepted => { root.accepted(self.text); }
        }

        HorizontalLayout {
            spacing: 8px;
            Rectangle { horizontal-stretch: 1; }

            MenuItem {
                width: 82px;
                label: "Cancel";
                dark: root.dark;
                clicked => { root.cancelled(); }
            }

            MenuItem {
                width: 82px;
                label: root.accept-label;
                dark: root.dark;
                clicked => { root.accepted(root.value); }
            }
        }
    }
}

export component TextInputPopup inherits Rectangle {
    in property <bool> dark;
    in property <string> title;
    in property <string> accept-label;
    in-out property <string> value;
    in property <length> dialog-width: 360px;
    callback accepted(string);
    callback cancelled();

    background: transparent;

    TextInputDialog {
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;
        width: root.dialog-width;
        height: 132px;
        dark: root.dark;
        title: root.title;
        accept-label: root.accept-label;
        value <=> root.value;
        accepted(value) => { root.accepted(value); }
        cancelled => { root.cancelled(); }
    }
}

export component PropertiesDialog inherits Rectangle {
    in property <bool> dark;
    in property <string> name;
    in property <string> kind;
    in property <string> size;
    in property <string> modified-label: "Modified";
    in property <string> modified;
    in property <string> path;
    callback closed();

    border-radius: 8px;
    background: root.dark ? #24282c : #fcfdfe;
    border-width: 1px;
    border-color: root.dark ? #3f474f : #d9e1e8;

    VerticalLayout {
        padding: 16px;
        spacing: 10px;

        Text {
            text: "Properties";
            color: root.dark ? #f8fafc : #17212b;
            font-size: 15px;
            font-weight: 700;
            overflow: elide;
        }

        Text {
            text: root.name;
            color: root.dark ? #f1f5f9 : #17212b;
            font-size: 14px;
            font-weight: 700;
            overflow: elide;
        }

        Text {
            text: "Type: " + root.kind;
            color: root.dark ? #d8dee5 : #334155;
            font-size: 13px;
            overflow: elide;
        }

        Text {
            text: "Size: " + root.size;
            color: root.dark ? #d8dee5 : #334155;
            font-size: 13px;
            overflow: elide;
        }

        Text {
            text: root.modified-label + ": " + root.modified;
            color: root.dark ? #d8dee5 : #334155;
            font-size: 13px;
            overflow: elide;
        }

        Text {
            text: "Location: " + root.path;
            color: root.dark ? #a8a8a8 : #64748b;
            font-size: 12px;
            wrap: word-wrap;
            max-height: 50px;
        }

        Rectangle { vertical-stretch: 1; }

        HorizontalLayout {
            Rectangle { horizontal-stretch: 1; }

            MenuItem {
                width: 82px;
                label: "Close";
                dark: root.dark;
                clicked => { root.closed(); }
            }
        }
    }
}

export component PropertiesPopup inherits Rectangle {
    in property <bool> dark;
    in property <string> name;
    in property <string> kind;
    in property <string> size;
    in property <string> modified-label: "Modified";
    in property <string> modified;
    in property <string> path;
    callback closed();

    background: transparent;

    PropertiesDialog {
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;
        width: 440px;
        height: 260px;
        dark: root.dark;
        name: root.name;
        kind: root.kind;
        size: root.size;
        modified-label: root.modified-label;
        modified: root.modified;
        path: root.path;
        closed => { root.closed(); }
    }
}

export component PrivilegedPromptDialog inherits Rectangle {
    in property <bool> dark;
    in property <string> title;
    in property <string> message;
    in property <string> detail;
    callback cancelled();
    callback accepted();

    border-radius: 8px;
    background: root.dark ? #24282c : #fcfdfe;
    border-width: 1px;
    border-color: root.dark ? #3f474f : #d9e1e8;

    VerticalLayout {
        padding: 16px;
        spacing: 10px;

        Text {
            text: root.title;
            color: root.dark ? #f8fafc : #17212b;
            font-size: 15px;
            font-weight: 700;
            overflow: elide;
        }

        Text {
            text: root.message;
            color: root.dark ? #d8dee5 : #334155;
            font-size: 13px;
            wrap: word-wrap;
            max-height: 44px;
        }

        Text {
            text: root.detail;
            color: root.dark ? #a8a8a8 : #64748b;
            font-size: 12px;
            wrap: word-wrap;
            max-height: 36px;
        }

        Rectangle { vertical-stretch: 1; }

        HorizontalLayout {
            spacing: 8px;
            Rectangle { horizontal-stretch: 1; }

            MenuItem {
                width: 92px;
                label: "Cancel";
                dark: root.dark;
                clicked => { root.cancelled(); }
            }

            MenuItem {
                width: 118px;
                label: "Authenticate";
                dark: root.dark;
                clicked => { root.accepted(); }
            }
        }
    }
}

