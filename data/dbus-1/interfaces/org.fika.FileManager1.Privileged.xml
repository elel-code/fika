<!DOCTYPE node PUBLIC
 "-//freedesktop//DTD D-BUS Object Introspection 1.0//EN"
 "http://www.freedesktop.org/standards/dbus/1.0/introspect.dtd">
<node>
  <interface name="org.fika.FileManager1.Privileged">
    <method name="CreateFolder">
      <arg name="parent" type="s" direction="in"/>
      <arg name="name" type="s" direction="in"/>
      <arg name="created_path" type="s" direction="out"/>
    </method>

    <method name="CreateFile">
      <arg name="parent" type="s" direction="in"/>
      <arg name="name" type="s" direction="in"/>
      <arg name="created_path" type="s" direction="out"/>
    </method>

    <method name="Rename">
      <arg name="path" type="s" direction="in"/>
      <arg name="new_name" type="s" direction="in"/>
      <arg name="renamed_path" type="s" direction="out"/>
    </method>

    <method name="Trash">
      <arg name="paths" type="as" direction="in"/>
      <arg name="summary" type="s" direction="out"/>
    </method>

    <method name="Transfer">
      <arg name="operation" type="s" direction="in"/>
      <arg name="source" type="s" direction="in"/>
      <arg name="target_dir" type="s" direction="in"/>
      <arg name="destination" type="s" direction="out"/>
    </method>

    <method name="PrepareExternalEdit">
      <arg name="path" type="s" direction="in"/>
      <arg name="scratch_path" type="s" direction="out"/>
      <arg name="token" type="s" direction="out"/>
    </method>

    <method name="CommitExternalEdit">
      <arg name="token" type="s" direction="in"/>
      <arg name="scratch_path" type="s" direction="in"/>
      <arg name="committed_path" type="s" direction="out"/>
    </method>

    <method name="DiscardExternalEdit">
      <arg name="token" type="s" direction="in"/>
    </method>

    <method name="AssociateExternalEditUnit">
      <arg name="token" type="s" direction="in"/>
      <arg name="unit" type="s" direction="in"/>
      <arg name="session_bus_address" type="s" direction="in"/>
    </method>
  </interface>
</node>
